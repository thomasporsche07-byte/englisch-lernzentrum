// HELPER-FUNKTIONEN
function saveProgress(key,val){try{localStorage.setItem(key,JSON.stringify(val));}catch(e){}}
function loadProgress(key,def){try{const v=localStorage.getItem(key);return v?JSON.parse(v):def;}catch(e){return def;}}
function shuffle(arr){for(let i=arr.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[arr[i],arr[j]]=[arr[j],arr[i]];}return arr;}

function initProgressBar(el,total){
  const fill=el.querySelector('.progress-fill');
  const text=el.parentNode.querySelector('.progress-text');
  return{
    update(correct,total){
      const pct=total>0?Math.round(correct/total*100):0;
      if(fill)fill.style.width=pct+'%';
      if(text)text.textContent=`Fortschritt: ${correct}/${total} richtig (${pct}%)`;
    },
    setTotal(n){},
  };
}

function renderTask(task,idx,secKey){
  let html='<div class="task" id="task-'+secKey+'-'+idx+'">';
  if(task.type==='mc'){
    html+='<span class="task-type-badge badge-mc">Multiple Choice</span>';
    html+='<div class="prompt">'+task.prompt+'</div>';
    html+='<div class="mc-options">';
    task.options.forEach((opt,i)=>{
      const isCorrect=i===task.correct;
      html+='<div class="mc-opt" data-opt="'+i+'" data-correct="'+isCorrect+'" data-answer="'+task.answer+'"><span class="mc-letter">'+String.fromCharCode(65+i)+'</span><span>'+opt+'</span></div>';
    });
    html+='</div>';
  }else if(task.words){
    html+='<span class="task-type-badge badge-ordne">Wörter Ordnen</span>';
    html+='<div class="prompt">'+task.prompt+'</div>';
    html+='<div class="word-tiles-wrap">';
    html+='<div class="word-tiles-label">'+task.label+'</div>';
    html+='<div class="word-tiles wt-source" id="src-'+secKey+'-'+idx+'">';
    const shuffled=shuffle([...task.words]);
    shuffled.forEach(w=>{html+='<span class="word-tile" data-word="'+w+'">'+w+'</span>';});
    html+='</div>';
    html+='<div class="word-tiles wt-target" id="target-'+secKey+'-'+idx+'"></div>';
    html+='</div>';
  }else{
    html+='<span class="task-type-badge badge-frei">Freitext</span>';
    html+='<div class="prompt">'+task.prompt+'</div>';
    html+='<input type="text" class="task-input" placeholder="Antwort eingeben..." data-answer="'+JSON.stringify(task.answer).replace(/"/g,'&quot;')+'" />';
    if(task.explanation){html+='<div class="solution">'+task.explanation+'</div>';}
  }
  html+='<div class="controls" style="display:none;">';
  html+='<button class="btn blue task-check">Prüfen</button>';
  html+='<button class="btn ghost task-show">Lösung zeigen</button>';
  html+='</div>';
  html+='<div class="feedback"></div>';
  html+='</div>';
  return html;
}

function checkCelebration(container){
  const allTasks=container.querySelectorAll('.task');
  const solved=Array.from(allTasks).filter(t=>t.classList.contains('task--solved')).length;
  if(solved===allTasks.length){
    const banner=document.createElement('div');
    banner.className='celebrate-banner';
    banner.innerHTML='🎉 Perfekt! Du hast alles gelöst!';
    container.insertBefore(banner,container.firstChild);
    setTimeout(()=>banner.remove(),4000);
  }
}

function setupSection(secKey,lvlSwitch,tasksDiv,pools,checkAllBtn,resetBtn,isMultiLevel){
  let currentLevel=1;
  let taskStates={};
  const savedStates=loadProgress(secKey+'_states',{});
  Object.assign(taskStates,savedStates);

  function renderTasks(){
    tasksDiv.innerHTML='';
    const pool=pools[currentLevel]||[];
    pool.forEach((task,idx)=>{
      const taskId=currentLevel+'-'+idx;
      tasksDiv.innerHTML+=renderTask(task,idx,secKey);
      const taskEl=tasksDiv.querySelector('#task-'+secKey+'-'+idx);
      if(taskStates[taskId]==='solved')taskEl.classList.add('task--solved');

      const checkBtn=taskEl.querySelector('.task-check');
      const showBtn=taskEl.querySelector('.task-show');
      const feedback=taskEl.querySelector('.feedback');
      const input=taskEl.querySelector('.task-input');

      if(task.type==='mc'){
        const opts=taskEl.querySelectorAll('.mc-opt');
        opts.forEach(o=>{
          o.addEventListener('click',()=>{
            if(taskEl.classList.contains('task--solved'))return;
            opts.forEach(x=>x.classList.remove('mc-selected','mc-correct','mc-wrong'));
            o.classList.add('mc-selected');
            checkBtn.style.display='flex';
          });
        });
        checkBtn?.addEventListener('click',()=>{
          const sel=taskEl.querySelector('.mc-opt.mc-selected');
          if(!sel)return;
          const correct=sel.dataset.correct==='true';
          opts.forEach(x=>x.disabled=true);
          if(correct){
            sel.classList.add('mc-correct');
            feedback.textContent='✓ Richtig!';
            feedback.className='feedback ok';
            taskEl.classList.add('task--solved');
            taskStates[taskId]='solved';
            saveProgress(secKey+'_states',taskStates);
          }else{
            sel.classList.add('mc-wrong');
            const corrOpt=Array.from(opts).find(x=>x.dataset.correct==='true');
            if(corrOpt)corrOpt.classList.add('mc-correct');
            feedback.innerHTML='✗ Falsch! Richtig: <b>'+corrOpt?.textContent+'</b>';
            feedback.className='feedback bad';
          }
          updateProgress();
          setTimeout(()=>checkCelebration(tasksDiv),300);
        });
      }else if(task.words){
        const src=taskEl.querySelector('#src-'+secKey+'-'+idx);
        const target=taskEl.querySelector('#target-'+secKey+'-'+idx);
        src.querySelectorAll('.word-tile').forEach(tile=>{
          tile.addEventListener('click',()=>{
            if(tile.classList.contains('wt-used')||tile.classList.contains('wt-correct'))return;
            tile.classList.toggle('wt-placed');
            if(tile.classList.contains('wt-placed')){
              target.appendChild(tile.cloneNode(true));
              tile.classList.add('wt-used');
              const cloned=target.querySelector('.word-tile:last-child');
              cloned.classList.remove('wt-placed','wt-used');
              cloned.addEventListener('click',()=>{
                src.appendChild(cloned);
                tile.classList.remove('wt-used','wt-placed');
                cloned.remove();
              });
            }
          });
        });
        checkBtn?.addEventListener('click',()=>{
          if(taskEl.classList.contains('task--solved'))return;
          const ordered=Array.from(target.querySelectorAll('.word-tile')).map(t=>t.textContent.trim());
          const isCorrect=ordered.join(',')===task.answer.join(',');
          if(isCorrect){
            feedback.textContent='✓ Richtig!';
            feedback.className='feedback ok';
            taskEl.classList.add('task--solved');
            taskStates[taskId]='solved';
            saveProgress(secKey+'_states',taskStates);
            Array.from(target.querySelectorAll('.word-tile')).forEach(t=>{t.classList.add('wt-correct');t.disabled=true;});
          }else{
            feedback.innerHTML='✗ Falsch! Richtig: <b>'+task.answer.join(' ')+'</b>';
            feedback.className='feedback bad';
          }
          updateProgress();
          setTimeout(()=>checkCelebration(tasksDiv),300);
        });
      }else{
        checkBtn?.addEventListener('click',()=>{
          if(taskEl.classList.contains('task--solved'))return;
          const val=input.value.trim().toLowerCase();
          const correct=task.answer.map(a=>a.toLowerCase());
          const isCorrect=correct.includes(val);
          if(isCorrect){
            feedback.textContent='✓ Richtig!';
            feedback.className='feedback ok';
            input.disabled=true;
            taskEl.classList.add('task--solved');
            taskStates[taskId]='solved';
            saveProgress(secKey+'_states',taskStates);
          }else{
            feedback.innerHTML='✗ Falsch! Lösung: <b>'+task.answer.join(' / ')+'</b>';
            feedback.className='feedback bad';
          }
          updateProgress();
          setTimeout(()=>checkCelebration(tasksDiv),300);
        });
        showBtn?.addEventListener('click',()=>{
          taskEl.querySelector('.solution').style.display='block';
        });
      }
    });
  }

  function updateProgress(){
    const all=tasksDiv.querySelectorAll('.task');
    const solved=tasksDiv.querySelectorAll('.task.task--solved').length;
    const pct=all.length>0?Math.round(solved/all.length*100):0;
    const prog=lvlSwitch.parentNode.parentNode.querySelector('.progress-fill');
    const txt=lvlSwitch.parentNode.parentNode.querySelector('.progress-text');
    if(prog)prog.style.width=pct+'%';
    if(txt)txt.textContent=`Fortschritt: ${solved}/${all.length} richtig (${pct}%)`;
  }

  if(isMultiLevel&&lvlSwitch){
    lvlSwitch.querySelectorAll('.level-btn').forEach(btn=>{
      btn.addEventListener('click',()=>{
        lvlSwitch.querySelectorAll('.level-btn').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
        currentLevel=+btn.dataset.level;
        renderTasks();
        updateProgress();
      });
    });
  }

  checkAllBtn?.addEventListener('click',()=>{
    tasksDiv.querySelectorAll('.task-check').forEach(btn=>btn.click());
    const prog=lvlSwitch.parentNode.parentNode.querySelector('.progress');
    const txt=lvlSwitch.parentNode.parentNode.querySelector('.progress-text');
    const all=tasksDiv.querySelectorAll('.task');
    const solved=tasksDiv.querySelectorAll('.task.task--solved').length;
    const pct=all.length>0?Math.round(solved/all.length*100):0;
    const bannerClass=pct===100?'result-green':pct>=70?'result-orange':'result-red';
    const banner=document.createElement('div');
    banner.className='result-banner '+bannerClass;
    banner.innerHTML=(pct===100?'✅ Alle gelöst!':pct>=70?'🟡 Guter Fortschritt':'🔴 Noch üben')+' – '+solved+'/'+all.length+' richtig ('+pct+'%)';
    const errorList=document.createElement('div');
    errorList.className='error-list';
    tasksDiv.querySelectorAll('.task.task--wrong').forEach(t=>{
      errorList.innerHTML+='<li>Fehler: '+t.querySelector('.prompt')?.textContent.substring(0,60)+'...</li>';
    });
    tasksDiv.insertBefore(banner,tasksDiv.firstChild);
    if(errorList.querySelectorAll('li').length)tasksDiv.insertBefore(errorList,banner.nextSibling);
  });

  resetBtn?.addEventListener('click',()=>{
    taskStates={};
    saveProgress(secKey+'_states',{});
    renderTasks();
    updateProgress();
    tasksDiv.querySelectorAll('.result-banner,.result-banner,.celebrate-banner,.error-list').forEach(el=>el.remove());
  });

  renderTasks();
}

// Setup alle Sektionen
setupSection('aus',document.getElementById('aus-levels'),document.getElementById('aus-tasks'),{1:ausL1,2:ausL2,3:ausL3},document.getElementById('aus-check-all'),document.getElementById('aus-reset'),true);
setupSection('kf',document.getElementById('kf-levels'),document.getElementById('kf-tasks'),{1:kfL1,2:kfL2,3:kfL3},document.getElementById('kf-check-all'),document.getElementById('kf-reset'),true);
setupSection('vern',document.getElementById('vern-levels'),document.getElementById('vern-tasks'),{1:vernL1,2:vernL2,3:vernL3},document.getElementById('vern-check-all'),document.getElementById('vern-reset'),true);
setupSection('frag',document.getElementById('frag-levels'),document.getElementById('frag-tasks'),{1:fragL1,2:fragL2,3:fragL3},document.getElementById('frag-check-all'),document.getElementById('frag-reset'),true);

// --- QUIZ POOL (15 Fragen) ---
const quizPool=[
  // d=1 (4 Fragen – Grundregel-Erkennung)
  {prompt:"Welche Form ist richtig? <i>I ___ happy.</i>",options:["am","is","are","be"],correct:0,tip:"I → <b>am</b>",explanation:"✅ <b>am</b> – I nimmt immer „am“.",d:1},
  {prompt:"Welche Form ist richtig? <i>He ___ from Germany.</i>",options:["are","am","is","be"],correct:2,tip:"He → <b>is</b>",explanation:"✅ <b>is</b> – He nimmt immer „is“.",d:1},
  {prompt:"Welche Form ist richtig? <i>They ___ in the classroom.</i>",options:["is","am","are","be"],correct:2,tip:"They → <b>are</b>",explanation:"✅ <b>are</b> – They nimmt immer „are“.",d:1},
  {prompt:"Welche Kurzform ist richtig? <i>I ___ happy.</i> (Kurzform)",options:["I'm","I is","I are","Iam"],correct:0,tip:"I am → <b>I'm</b>",explanation:"✅ <b>I'm</b> – Kurzform von „I am“.",d:1},
  // d=2 (5 Fragen – Kontextverständnis)
  {prompt:"Welche Verneinung ist richtig? <i>I ___ happy.</i>",options:["I not am","I amn't","I'm not","I'm am not"],correct:2,tip:"I am + not → <b>I'm not</b> oder <b>I am not</b>",explanation:"✅ <b>I'm not</b> – Die richtige Negation.",d:2},
  {prompt:"Welche Frage ist richtig? <i>___ you cool?</i>",options:["You are","Do you","Are you","Is you"],correct:2,tip:"You → <b>Are you</b>",explanation:"✅ <b>Are you cool?</b> – Form kommt nach vorne.",d:2},
  {prompt:"Welche Kurzantwort ist richtig? <i>Is he from England? ___</i>",options:["Yes, he are.","Yes, he is.","Yes, I am.","Yes, is."],correct:1,tip:"He → <b>he is</b>",explanation:"✅ <b>Yes, he is.</b> – Passendes Pronomen + to be.",d:2},
  {prompt:"Welcher Satz ist richtig?",options:["She are happy.","She is happy.","She am happy.","She be happy."],correct:1,tip:"She → <b>is</b>",explanation:"✅ <b>She is happy.</b>",d:2},
  {prompt:"Welcher Satz ist richtig? <i>You ___ my friends.</i>",options:["You am","You is","You are","You be"],correct:2,tip:"You → <b>are</b>",explanation:"✅ <b>You are my friends.</b> – You nimmt immer „are“.",d:2},
  // d=3 (6 Fragen – Transfer/Edge Cases)
  {prompt:"Welche Kurzantwort passt? <i>Are you from Italy? ___</i>",options:["Yes, I'm.","Yes, I am.","Yes, you are.","No, I'm not am."],correct:1,tip:"Volle Kurzantwort mit Pronomen + to be.",explanation:"✅ <b>Yes, I am.</b> – Oder auch „Yes, I'm.“ – Pronomen muss passen.",d:3},
  {prompt:"Welcher Satz ist FALSCH?",options:["She's not happy.","She isn't happy.","She's isn't happy.","She is not happy."],correct:2,tip:"Nicht „is“ + „isn't“ zusammen – nur eine Negation!",explanation:"❌ <b>She's isn't happy.</b> ist Fehler – doppelte Negation. ✅ Richtig: „She's not happy.“ oder „She isn't happy.“",d:3},
  {prompt:"Welche Umformung ist richtig? Positiv: <i>I am tired.</i> → Negativ: <i>___</i>",options:["I not am tired.","I amn't tired.","I'm not tired.","I not tired."],correct:2,tip:"I am + not → „I'm not“ ODER „I am not“",explanation:"✅ <b>I'm not tired.</b> (oder „I am not tired.“) – Das ist die einzige korrekte Negation.",d:3},
  {prompt:"Welches Pronomen + to be passt? <i>___ very clever.</i>",options:["I is","She are","We is","They are"],correct:3,tip:"They = Mehrzahl → „are“",explanation:"✅ <b>They are very clever.</b> – Mehrzahl nimmt immer „are“.",d:3},
  {prompt:"Welcher Satz ist RICHTIG? (Verneinung korrekt)",options:["We're not happy.","We're aren't happy.","We not are happy.","We are not aren't."],correct:0,tip:"We are + not → „We're not“ ODER „We are not“ (nicht doppelt)",explanation:"✅ <b>We're not happy.</b> (oder „We are not happy.“) – Nur EINmal negiert, nicht zweimal!",d:3},
  {prompt:"Welche Frage mit Kurzantwort ist komplett richtig?",options:["Is she student? – Yes, she is.","Are they happy? – No, he is not.","Are you tired? – Yes, I are.","Is he here? – Yes, she is."],correct:0,tip:"Pronomen in Frage und Antwort müssen passen (they → they; he → he)",explanation:"✅ <b>Is she a student? – Yes, she is.</b> – Frage-Pronomen (she) = Antwort-Pronomen (she).",d:3}

];

(function initQuiz(){
  const AMOUNTS=['50 €','100 €','200 €','300 €','500 €','1.000 €','2.000 €','4.000 €','8.000 €','16.000 €','32.000 €','64.000 €','125.000 €','500.000 €','1.000.000 €'];
  const MILESTONES=[4,9];
  const container=document.getElementById('quiz-tasks');
  const resultDiv=document.getElementById('quiz-result');
  const progressRoot=document.querySelector('#quiz-progress .progress');
  const progressCtrl=initProgressBar(progressRoot,15);
  let questions=[],current=0,correctCount=0,phoneUsed=false,audienceUsed=false,fiftyUsed=false;
  let lastHiddenIndices=[];

  function buildLadder(cur){
    let html='';
    for(let i=AMOUNTS.length-1;i>=0;i--){
      let cls='wwm-ladder-row';
      if(MILESTONES.includes(i))cls+=' milestone';
      if(i<cur)cls+=' done';
      if(i===cur)cls+=' current';
      const icon=MILESTONES.includes(i)?(i<cur?'✅':i===cur?'🏆':'🛡️'):(i<cur?'✓':i===cur?'▶':'');
      html+='<div class="'+cls+'"><span class="wwm-qnum">'+(i+1)+'</span><span class="wwm-amount">'+AMOUNTS[i]+'</span><span style="font-size:11px;margin-left:2px">'+icon+'</span></div>';
    }
    return html;
  }

  function showQuestion(idx){
    if(idx>=questions.length){showFinal(correctCount,questions.length);return;}
    const q=questions[idx];
    const letters=['A','B','C','D'];
    const optIndices=[...Array(q.options.length).keys()];
    for(let i=optIndices.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[optIndices[i],optIndices[j]]=[optIndices[j],optIndices[i]];}
    const shuffled=optIndices.map(i=>q.options[i]);
    const correctShuffled=optIndices.indexOf(q.correct);
    lastHiddenIndices=[];
    const lifelines=[
      {id:'fifty',label:'50/50',used:fiftyUsed},
      {id:'phone',label:'📞 Joker',used:phoneUsed},
      {id:'audience',label:'👥 Publikum',used:audienceUsed}
    ];
    const lifelineHtml=lifelines.map(l=>'<span class="chip'+(l.used?' chip-used':'')+'" data-joker="'+l.id+'">'+l.label+'</span>').join('');
    const html='<div class="wwm-layout quiz-question-enter">'+
      '<div class="wwm-main">'+
        '<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:10px">'+
          '<div class="wwm-qbadge">Frage '+(idx+1)+' / '+questions.length+' &nbsp;·&nbsp; '+AMOUNTS[idx]+'</div>'+
          '<div class="quiz-streak" id="quiz-streak"></div>'+
        '</div>'+
        '<div class="wwm-lifelines">'+lifelineHtml+'</div>'+
        '<div class="task wwm-stage">'+
          '<div class="prompt">'+q.prompt+'</div>'+
          '<div class="wwm-joker-options" id="wwm-options">'+
            shuffled.map((opt,i)=>'<button class="wwm-option-btn" data-opt="'+i+'"><span class="wwm-opt-letter">'+letters[i]+'</span><span>'+opt+'</span></button>').join('')+
          '</div>'+
          '<div id="wwm-joker-extra"></div>'+
          '<div class="feedback" id="wwm-feedback"></div>'+
          '<div id="wwm-explanation" style="display:none" class="quiz-explanation-box"></div>'+
          '<div class="controls" style="margin-top:14px;display:none" id="wwm-next-ctrl">'+
            '<button class="btn green" id="wwm-next">Weiter →</button>'+
          '</div>'+
        '</div>'+
      '</div>'+
      '<div class="wwm-ladder">'+buildLadder(idx)+'</div>'+
    '</div>';
    container.innerHTML=html;
    progressCtrl.update(correctCount,idx);

    document.querySelectorAll('.wwm-option-btn').forEach(btn=>{
      btn.addEventListener('click',()=>{
        const chosen=+btn.dataset.opt;
        document.querySelectorAll('.wwm-option-btn').forEach(b=>b.disabled=true);
        const fb=document.getElementById('wwm-feedback');
        const expl=document.getElementById('wwm-explanation');
        const nctrl=document.getElementById('wwm-next-ctrl');
        if(chosen===correctShuffled){
          btn.style.background='linear-gradient(90deg,rgba(0,180,80,.3),rgba(0,150,60,.2))';
          btn.style.borderColor='#00e676';
          fb.textContent='✓ Richtig! +'+AMOUNTS[idx];fb.className='feedback ok';
          correctCount++;
          progressCtrl.update(correctCount,idx+1);
        }else{
          btn.style.background='linear-gradient(90deg,rgba(180,0,0,.3),rgba(140,0,0,.2))';
          btn.style.borderColor='#ff5555';
          const correctBtn=document.querySelectorAll('.wwm-option-btn')[correctShuffled];
          if(correctBtn){correctBtn.style.background='linear-gradient(90deg,rgba(0,180,80,.3),rgba(0,150,60,.2))';correctBtn.style.borderColor='#00e676';}
          fb.innerHTML='✗ Falsch! Richtige Antwort: <b>'+shuffled[correctShuffled]+'</b>';fb.className='feedback bad';
          if(q.explanation){expl.innerHTML=q.explanation;expl.style.display='block';}
          if(q.tip){const tb=document.createElement('div');tb.className='quiz-tip-box';tb.innerHTML='💡 <b>Tipp:</b> '+q.tip;nctrl.parentNode.insertBefore(tb,nctrl);}
          nctrl.style.display='flex';
          const nextBtn=document.getElementById('wwm-next');
          if(nextBtn){nextBtn.textContent='Ergebnis ansehen →';nextBtn.className='btn gray';nextBtn.dataset.next='1';nextBtn.addEventListener('click',()=>showFinal(correctCount,questions.length));}
          return;
        }
        if(q.explanation){expl.innerHTML=q.explanation;expl.style.display='block';}
        nctrl.style.display='flex';
        const nextBtn=document.getElementById('wwm-next');
        if(nextBtn){
          nextBtn.addEventListener('click',()=>{
            current++;
            showQuestion(current);
            setTimeout(()=>typeof TTS!=='undefined'&&TTS.injectAll&&TTS.injectAll(),60);
          });
        }
      });
    });

    document.querySelectorAll('.chip[data-joker]').forEach(chip=>{
      chip.addEventListener('click',()=>{
        const joker=chip.dataset.joker;
        if(chip.classList.contains('chip-used'))return;
        chip.classList.add('chip-used');
        if(joker==='fifty'){
          fiftyUsed=true;
          const wrong=[];
          document.querySelectorAll('.wwm-option-btn').forEach((b,i)=>{if(i!==correctShuffled)wrong.push(i);});
          const hide=wrong.sort(()=>Math.random()-.5).slice(0,2);
          lastHiddenIndices=hide;
          hide.forEach(i=>{const b=document.querySelectorAll('.wwm-option-btn')[i];if(b){b.style.opacity='0.2';b.disabled=true;}});
        }else if(joker==='phone'){
          phoneUsed=true;
          const ruleHint=q.tip||'Denk an das Grundprinzip: Passiv = Form von to be + past participle';
          const extra=document.getElementById('wwm-joker-extra');
          extra.innerHTML='<div class="wwm-phone-bubble"><div class="wwm-phone-icon">📞</div><div class="wwm-phone-text"><b>Dein Lehrer meldet sich:</b><br>'+ruleHint+'</div></div>';
        }else if(joker==='audience'){
          audienceUsed=true;
          const pcts=[];
          for(let i=0;i<4;i++){const v=i===correctShuffled?Math.floor(40+Math.random()*35):Math.floor(5+Math.random()*20);pcts.push(v);}
          const sum=pcts.reduce((a,b)=>a+b,0);const scale=100/sum;const scaled=pcts.map(v=>Math.round(v*scale));
          const colors=['#4fc3f7','#ef5350','#66bb6a','#ffb74d'];
          const extra=document.getElementById('wwm-joker-extra');
          const barsHtml=shuffled.map((opt,i)=>'<div class="wwm-audience-col"><div class="wwm-audience-pct">'+scaled[i]+'%</div><div class="wwm-audience-bar" style="height:'+Math.max(4,Math.round(scaled[i]*0.8))+'px;background:'+colors[i]+';align-self:flex-end"></div><div class="wwm-audience-label">'+letters[i]+'</div></div>').join('');
          extra.innerHTML='<div class="wwm-audience-box"><div class="wwm-audience-title">👥 Publikumsjoker</div><div class="wwm-audience-bars">'+barsHtml+'</div></div>';
        }
      });
    });
    setTimeout(()=>typeof TTS!=='undefined'&&TTS.injectAll&&TTS.injectAll(),60);
  }

  function showFinal(correct,total){
    const pct=Math.round(correct/total*100);
    let msg,emoji;
    if(pct===100){msg='EINE MILLION! 🎉 PERFEKT! am, is und are sitzen perfekt!';emoji='🏆';}
    else if(pct>=90){msg='Fast perfekt – to be sitzt schon sehr gut!';emoji='🥇';}
    else if(pct>=80){msg='Richtig stark – die Formen am/is/are sind klar!';emoji='🥈';}
    else if(pct>=60){msg='Gut gemacht – noch etwas üben, dann sitzt es!';emoji='👍';}
    else if(pct>=40){msg='Weiter üben – besonders die Pronomen + Form!';emoji='💪';}
    else{msg='Nochmal von vorne – schau dir die Regelkarten an!';emoji='📚';}
    container.innerHTML='';
    resultDiv.style.display='block';
    resultDiv.innerHTML='<div style="padding:28px 22px;text-align:center">'+
      '<div style="font-size:52px;margin-bottom:8px">'+emoji+'</div>'+
      '<div style="font-size:26px;font-weight:900;color:#ffcc00;margin-bottom:8px" class="score">'+correct+' / '+total+'</div>'+
      '<div style="font-size:17px;font-weight:700;color:#fff;margin-bottom:16px">'+msg+'</div>'+
      '<button class="btn" style="background:linear-gradient(135deg,#0d3080,#1e4db5);color:#ffecb3;border:1px solid rgba(255,204,0,.4);padding:12px 28px;font-size:15px" onclick="document.getElementById(\'quiz-reset\').click()">🔄 Nochmal spielen</button>'+
    '</div>';
    progressCtrl.update(correct,total);
  }

  function startGame(){
    current=0;correctCount=0;phoneUsed=false;audienceUsed=false;fiftyUsed=false;lastHiddenIndices=[];
    resultDiv.style.display='none';
    const byDiff=(d)=>quizPool.filter(q=>q.d===d);
    const d1=shuffle(byDiff(1)).slice(0,4);
    const d2=shuffle(byDiff(2)).slice(0,5);
    const d3=shuffle(byDiff(3)).slice(0,6);
    questions=[...d1,...d2,...d3];
    progressCtrl.setTotal(questions.length);
    progressCtrl.update(0,0);
    showQuestion(0);
  }

  document.getElementById('quiz-reset').addEventListener('click',startGame);
  startGame();
  saveProgress('quiz_started',true);
})();


</script>

</body>
</html>
