var TTS={
  enabled:false,
  synth:window.speechSynthesis||null,
  current:null,
  voices:[],
  getLang(lang){
    if(!this.synth)return null;
    if(!this.voices.length)this.voices=this.synth.getVoices();
    let v=this.voices.find(v=>v.lang===lang&&v.localService);
    if(!v)v=this.voices.find(v=>v.lang===lang);
    if(!v)v=this.voices.find(v=>v.lang.startsWith(lang.split('-')[0]));
    return v||null;
  },
  speak(text,lang){
    if(!this.synth)return;
    try{this.synth.cancel();}catch(e){}
    const u=new SpeechSynthesisUtterance(text.replace(/<[^>]+>/g,''));
    u.lang=lang||'en-GB';u.rate=0.9;u.pitch=1;
    const v=this.getLang(lang||'en-GB');
    if(v)u.voice=v;
    this.current=u;
    try{this.synth.speak(u);}catch(e){}
  },
  createBtn(text,lang,extraStyle){
    const btn=document.createElement('button');
    btn.className='tts-btn tts-flag-btn';
    btn.title='Vorlesen ('+(lang==='de-DE'?'Deutsch':'Englisch')+')';
    btn.textContent=lang==='de-DE'?'🇩🇪':'🇬🇧';
    if(extraStyle)btn.style.cssText=extraStyle;
    btn.addEventListener('click',(e)=>{e.stopPropagation();if(!TTS.enabled)return;TTS.speak(text,lang);});
    return btn;
  },
  injectAll(){
    if(!this.enabled)return;
    const processed=new WeakSet();
    document.querySelectorAll('.task .prompt, .solution, .quiz-explanation-box, .wwm-stage .prompt').forEach(el=>{
      if(processed.has(el))return;processed.add(el);
      const raw=el.getAttribute('data-tts-text')||el.textContent.replace(/<[^>]+>/g,' ').trim();
      if(!raw)return;
      if(!el.querySelector('.tts-flag-btn')){
        const de=TTS.createBtn(raw,'de-DE');
        const en=TTS.createBtn(raw,'en-GB');
        el.appendChild(de);el.appendChild(en);
      }
    });
  }
};
if(TTS.synth&&TTS.synth.onvoiceschanged!==undefined){TTS.synth.onvoiceschanged=()=>{TTS.voices=TTS.synth.getVoices();};}
setTimeout(()=>{if(TTS.synth)TTS.voices=TTS.synth.getVoices();},300);

