var TTS={
  enabled:false,
  synth:(function(){try{return window.speechSynthesis||null;}catch(e){return null;}})(),
  speaking:false,
  
  toggle(){
    this.enabled=!this.enabled;
    document.body.classList.toggle('tts-enabled',this.enabled);
    const btn=document.getElementById('tts-toggle');
    if(btn){btn.textContent=this.enabled?'🔊 Vorlesen ✓':'🔊 Vorlesen';btn.classList.toggle('tts-on',this.enabled);}
    
    document.dispatchEvent(new Event('ttsToggle'));
    if(this.enabled){
      this.injectAll();
    }else{
      // TTS deaktiviert: alle Buttons entfernen
      if(this.synth)this.synth.cancel();
      document.querySelectorAll('.tts-btn').forEach(b=>b.remove());
      document.querySelectorAll('.task').forEach(t=>delete t.dataset.ttsReady);
      document.querySelectorAll('.solution').forEach(s=>delete s.dataset.ttsReady);
    }
  },
  
  speak(text,lang){
    if(!this.synth||!text)return;
    this.synth.cancel();
    // Text säubern: HTML-Tags, Sonderzeichen entfernen
    const clean=text.replace(/<[^>]*>/g,' ').replace(/[→←·•📌✅❌❓🔵🕐⚠️💡✓✗]/g,' ').replace(/\s+/g,' ').trim();
    if(!clean)return;
    const utt=new SpeechSynthesisUtterance(clean);
    utt.lang=lang||'en-GB';
    utt.rate=lang==='de-DE'?0.95:0.85;// Englisch etwas langsamer
    utt.pitch=1;
    utt.onstart=()=>{this.speaking=true;};
    utt.onend=()=>{this.speaking=false;document.querySelectorAll('.tts-btn.tts-playing').forEach(b=>b.classList.remove('tts-playing'));};
    utt.onerror=()=>{this.speaking=false;};
    this.synth.speak(utt);
  },
  
  createBtn(text,lang,style){
    const btn=document.createElement('button');
    btn.className='tts-btn';
    btn.type='button';
    btn.setAttribute('aria-label','Vorlesen');
    btn.textContent='🔊';
    if(style)btn.style.cssText=style;
    btn.addEventListener('click',(e)=>{
      e.preventDefault();e.stopPropagation();
      if(this.speaking){this.synth.cancel();this.speaking=false;btn.classList.remove('tts-playing');return;}
      document.querySelectorAll('.tts-btn.tts-playing').forEach(b=>b.classList.remove('tts-playing'));
      btn.classList.add('tts-playing');
      this.speak(typeof text==='function'?text():text,lang);
    });
    return btn;
  },
  
  injectRuleCards(){},
  
  injectAll(){
    if(!this.enabled)return;
    // Buttons in bereits gerenderten Aufgaben
    document.querySelectorAll('.task').forEach(task=>{
      if(task.dataset.ttsReady)return;
      task.dataset.ttsReady='1';
      const prompt=task.querySelector('.prompt');
      if(prompt){
        const pText=prompt.textContent||'';
        const hasDe=/Ordne|Bilde|Verneine|Setze|Frage nach|Welch|Wann|Was ist/i.test(pText);
        const hl=prompt.querySelector('.highlight');
        const srcTiles=task.querySelector('.wt-source');
        if(srcTiles){
          // Wörter-Ordnen: 🇩🇪 Prompt + 🇬🇧 alle Wörter vorlesen
          const ttsWrap=document.createElement('span');
          ttsWrap.style.cssText='display:inline-flex;align-items:center;gap:5px;white-space:nowrap;vertical-align:middle;margin-left:6px;';
          const makeFlag=function(flag,getTextFn,lang){
            const b=document.createElement('button');
            b.type='button';b.className='tts-btn tts-flag-btn';
            b.textContent=flag;
            b.style.cssText='font-size:18px;padding:1px 3px;line-height:1;';
            b.setAttribute('aria-label','Vorlesen');
            b.addEventListener('click',function(e){
              e.preventDefault();e.stopPropagation();
              const txt=typeof getTextFn==='function'?getTextFn():getTextFn;
              if(TTS.speaking){TTS.synth.cancel();TTS.speaking=false;return;}
              TTS.speak(txt,lang);
            });
            return b;
          };
          const deBtn=makeFlag('🇩🇪',pText,'de-DE');
          const wordsText=Array.from(srcTiles.querySelectorAll('.word-tile')).map(t=>t.textContent).join(', ');
          ttsWrap.appendChild(deBtn);
          if(wordsText){
            const enBtn=makeFlag('🇬🇧',()=>Array.from(task.querySelectorAll('.wt-source .word-tile')).map(t=>t.textContent).join(', '),'en-GB');
            ttsWrap.appendChild(enBtn);
          }
          prompt.appendChild(ttsWrap);
        }else if(hl){
          const words=hl.textContent;
          const btn=this.createBtn(words.replace(/\s*\/\s*/g,', '),'en-GB');
          prompt.appendChild(btn);
        }else{
          const btn=this.createBtn(pText,hasDe?'de-DE':'en-GB');
          prompt.appendChild(btn);
        }
      }
    });
    // Lösungsboxen die sichtbar sind
    document.querySelectorAll('.solution').forEach(sol=>{
      if(sol.style.display==='none'||!sol.textContent.trim())return;
      if(sol.dataset.ttsReady)return;
      sol.dataset.ttsReady='1';
      const solText=sol.textContent.replace(/^Lösung:\s*/,'');
      const btn=this.createBtn(solText,'en-GB','font-size:14px;margin-left:6px;');
      sol.prepend(btn);
    });
  },
  
  init(){
    const btn=document.getElementById('tts-toggle');
    if(!this.synth){if(btn)btn.style.display='none';return;}
    // TTS startet immer deaktiviert – kein localStorage-Restore
    if(btn)btn.addEventListener('click',()=>this.toggle());
    // Nach jedem Accordion-Toggle neu injizieren
    document.querySelectorAll('details.accordion').forEach(d=>{
      d.addEventListener('toggle',()=>{if(d.open&&this.enabled)setTimeout(()=>this.injectAll(),100);});
    });
  }
};

