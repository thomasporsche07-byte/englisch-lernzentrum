// === DARK-MODE-TOGGLE (Persistenz via localStorage 'tobe_dark_v1') ===
(function initDarkMode(){
  const KEY='tobe_dark_v1';
  const btn=document.getElementById('dark-toggle');
  function apply(isDark){
    document.body.classList.toggle('dark-mode',isDark);
    if(btn){btn.textContent=isDark?'☀️ Light Mode':'🌙 Dark Mode';btn.setAttribute('aria-pressed',isDark?'true':'false');}
  }
  let saved=false;
  try{saved=localStorage.getItem(KEY)==='1';}catch(e){}
  apply(saved);
  if(btn){
    btn.addEventListener('click',()=>{
      const next=!document.body.classList.contains('dark-mode');
      apply(next);
      try{localStorage.setItem(KEY,next?'1':'0');}catch(e){}
    });
  }
})();

// === TTS-TOGGLE (LRS-Vorlese-Modus, LocalStorage 'tobe_tts_v1') ===
var TTS={
  enabled:false,
  synth:(function(){try{return window.speechSynthesis||null;}catch(e){return null;}})(),
  speaking:false,
  toggle(){
    this.enabled=!this.enabled;
    document.body.classList.toggle('tts-enabled',this.enabled);
    const btn=document.getElementById('tts-toggle');
    if(btn){btn.textContent=this.enabled?'🔊 Vorlesen ✓':'🔊 Vorlesen';btn.classList.toggle('tts-on',this.enabled);}
    try{localStorage.setItem('tobe_tts_v1',this.enabled?'1':'0');}catch(e){}
    if(this.enabled){this.injectAll();}
    else{
      if(this.synth)this.synth.cancel();
      document.querySelectorAll('.tts-btn').forEach(b=>b.remove());
      document.querySelectorAll('[data-tts-ready]').forEach(el=>delete el.dataset.ttsReady);
    }
  },
  speak(text,lang){
    if(!this.synth||!text)return;
    this.synth.cancel();
    const clean=text.replace(/<[^>]*>/g,' ').replace(/[→←·•📌✅❌❓🔵🕐⚠️💡✓✗📝]/g,' ').replace(/\s+/g,' ').trim();
    if(!clean)return;
    const utt=new SpeechSynthesisUtterance(clean);
    utt.lang=lang||'en-GB';
    utt.rate=lang==='de-DE'?0.95:0.85;
    utt.pitch=1;
    utt.onstart=()=>{this.speaking=true;};
    utt.onend=()=>{this.speaking=false;document.querySelectorAll('.tts-btn.tts-playing').forEach(b=>b.classList.remove('tts-playing'));};
    utt.onerror=()=>{this.speaking=false;};
    this.synth.speak(utt);
  },
  createBtn(text,lang,style){
    const btn=document.createElement('button');
    btn.className='tts-btn';btn.type='button';
    btn.setAttribute('aria-label','Vorlesen');
    btn.textContent=lang==='de-DE'?'🇩🇪':'🇬🇧';
    if(style)btn.style.cssText=style;
    else btn.style.cssText='font-size:14px;margin-left:6px;padding:1px 4px;background:transparent;border:1px solid var(--border);border-radius:6px;cursor:pointer;line-height:1;vertical-align:middle';
    btn.addEventListener('click',(e)=>{
      e.preventDefault();e.stopPropagation();
      if(this.speaking){this.synth.cancel();this.speaking=false;btn.classList.remove('tts-playing');return;}
      document.querySelectorAll('.tts-btn.tts-playing').forEach(b=>b.classList.remove('tts-playing'));
      btn.classList.add('tts-playing');
      this.speak(typeof text==='function'?text():text,lang);
    });
    return btn;
  },
  injectAll(){
    if(!this.enabled)return;
    document.querySelectorAll('.task').forEach(task=>{
      if(task.closest('#wwm-quiz'))return;
      if(task.dataset.ttsReady)return;
      task.dataset.ttsReady='1';
      const prompt=task.querySelector('.prompt');
      if(prompt){
        const pText=prompt.textContent||'';
        const hasDe=/Ordne|Bilde|Verneine|Setze|Frage|Welch|Wann|Was ist|Antworte/i.test(pText);
        const btn=this.createBtn(pText,hasDe?'de-DE':'en-GB');
        prompt.appendChild(btn);
      }
    });
    document.querySelectorAll('.solution').forEach(sol=>{
      if(sol.style.display==='none'||!sol.textContent.trim())return;
      if(sol.dataset.ttsReady)return;
      sol.dataset.ttsReady='1';
      const solText=sol.textContent.replace(/^Lösung:\s*/,'');
      const btn=this.createBtn(solText,'en-GB');
      sol.prepend(btn);
    });
  },
  init(){
    const btn=document.getElementById('tts-toggle');
    if(!this.synth){if(btn)btn.style.display='none';return;}
    let saved=false;
    try{saved=localStorage.getItem('tobe_tts_v1')==='1';}catch(e){}
    if(saved){this.enabled=true;document.body.classList.add('tts-enabled');if(btn){btn.textContent='🔊 Vorlesen ✓';btn.classList.add('tts-on');}}
    if(btn)btn.addEventListener('click',()=>this.toggle());
    document.querySelectorAll('details.accordion').forEach(d=>{
      d.addEventListener('toggle',()=>{if(d.open&&this.enabled)setTimeout(()=>this.injectAll(),100);});
    });
    if(this.enabled)setTimeout(()=>this.injectAll(),100);
  }
};
try{TTS.init();}catch(e){console.error('TTS init:',e);}

