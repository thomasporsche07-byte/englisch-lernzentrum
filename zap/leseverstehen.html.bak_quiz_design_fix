/* ============= SHARED ENGINE: Helpers + renderTasks + Quiz + Dark/TTS/Reset ============= */
function _norm(s){return (s||'').toString().trim().toLowerCase().replace(/\s+/g,' ').replace(/[‘’ʼ]/g,"'").replace(/[“”]/g,'"').replace(/[.,!?;:]+$/,'');}
function shuffle(a){a=a.slice();for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function pickN(arr,n){return shuffle(arr).slice(0,Math.min(n,arr.length));}
function pb_load(key){try{return JSON.parse(localStorage.getItem(key)||'{}');}catch(e){return{};}}
function pb_save(key,obj){try{localStorage.setItem(key,JSON.stringify(obj));}catch(e){}}
function taskHash(t){return (JSON.stringify(t.prompt||t.q||t.text||'')+'|'+JSON.stringify(t.answer||t.options||'')).slice(0,90);}
function initBar(wrap){const fill=wrap.querySelector('.progress-fill');const txt=wrap.querySelector('.progress-text');return{set(c,t){const pct=t?Math.round(c/t*100):0;fill.style.width=pct+'%';txt.textContent='Fortschritt: '+c+'/'+t+' richtig ('+pct+'%)';},reset(){fill.style.width='0%';txt.textContent='Fortschritt: 0/0 richtig (0%)';}};}
function isCorrect(user,answers){if(!Array.isArray(answers))answers=[answers];const u=_norm(user);return answers.some(a=>_norm(a)===u);}

/* ===== renderTasks: MC, Freitext, Notizaufgabe ===== */
function renderTasks(container,tasks,storageKey){
  container.innerHTML='';
  const state=pb_load(storageKey);
  const wrap=container.parentElement.querySelector('.progress-wrap');
  const bar=wrap?initBar(wrap):null;
  let correct=0;
  tasks.forEach((t,idx)=>{
    const card=document.createElement('div');card.className='task';
    const hash=taskHash(t);
    const saved=state[hash];
    if(t.type==='mc' || (Array.isArray(t.options) && typeof t.correct==='number')){
      // Multiple Choice
      const promptHtml='<div class="task-prompt"><span class="task-num">'+(idx+1)+'</span> '+(t.prompt||t.q)+'</div>';
      card.innerHTML=promptHtml;
      const opts=document.createElement('div');opts.className='mc-options';
      const shuffled=t.shuffleOptions===false?t.options.map((o,i)=>({o,i})):shuffle(t.options.map((o,i)=>({o,i})));
      shuffled.forEach(({o,i})=>{
        const btn=document.createElement('button');btn.className='mc-opt';btn.textContent=o;
        btn.onclick=()=>{
          if(card.dataset.done)return;
          card.dataset.done='1';
          const ok=(i===t.correct);
          btn.classList.add(ok?'correct':'wrong');
          if(!ok){
            const right=opts.children[shuffled.findIndex(x=>x.i===t.correct)];
            if(right)right.classList.add('correct');
          }
          const fb=document.createElement('div');fb.className='feedback '+(ok?'ok':'bad');
          fb.innerHTML=ok?'✅ Richtig!':'❌ Leider falsch.'+(t.explanation?' <em>'+t.explanation+'</em>':'');
          card.appendChild(fb);
          if(ok){correct++;state[hash]=1;pb_save(storageKey,state);}else{state[hash]=0;pb_save(storageKey,state);}
          if(bar)bar.set(correct,tasks.length);
        };
        opts.appendChild(btn);
      });
      card.appendChild(opts);
      if(saved===1){correct++;card.dataset.done='1';opts.querySelectorAll('.mc-opt').forEach((b,bi)=>{if(shuffled[bi].i===t.correct)b.classList.add('correct');b.disabled=true;});}
    } else if(t.type==='tf' && Array.isArray(t.items)){
      // True/False/Not given Mehrfach-Item-Karte
      card.innerHTML='<div class="task-prompt"><span class="task-num">'+(idx+1)+'</span> '+(t.prompt||'True / False / Not given')+'</div>';
      const list=document.createElement('div');list.className='tf-list';
      t.items.forEach((it,ii)=>{
        const row=document.createElement('div');row.className='tf-row';
        row.innerHTML='<div class="tf-stmt">'+it.s+'</div>';
        const btns=document.createElement('div');btns.className='tf-btns';
        ['True','False','Not given'].forEach((label,bi)=>{
          const b=document.createElement('button');b.className='mc-opt tf-btn';b.textContent=label;
          b.onclick=()=>{
            if(row.dataset.done)return;
            row.dataset.done='1';
            const want=it.a;
            const ok=(label.toLowerCase().replace(' ','')===want.toLowerCase().replace(' ',''));
            b.classList.add(ok?'correct':'wrong');
            if(!ok){btns.querySelectorAll('.tf-btn').forEach(x=>{if(x.textContent.toLowerCase().replace(' ','')===want.toLowerCase().replace(' ',''))x.classList.add('correct');});}
            const fb=document.createElement('div');fb.className='feedback '+(ok?'ok':'bad');fb.style.fontSize='13px';fb.innerHTML=(ok?'✅ ':'❌ Korrekt: '+want+'. ')+(it.why||'');
            row.appendChild(fb);
            const itemHash=hash+'_'+ii;state[itemHash]=ok?1:0;pb_save(storageKey,state);
            if(ok){correct++;}
            if(bar)bar.set(correct,tasks.length);
          };
          btns.appendChild(b);
        });
        row.appendChild(btns);
        list.appendChild(row);
      });
      card.appendChild(list);
    } else {
      // Freitext / Lückenfüller
      card.innerHTML='<div class="task-prompt"><span class="task-num">'+(idx+1)+'</span> '+(t.prompt||t.q)+'</div>';
      const inp=document.createElement('input');inp.type='text';inp.className='ft-input';inp.placeholder=t.placeholder||'Antwort eingeben…';
      const btn=document.createElement('button');btn.className='btn';btn.textContent='Prüfen';
      const sol=document.createElement('button');sol.className='btn gray';sol.textContent='Lösung';
      const wrap2=document.createElement('div');wrap2.className='ft-wrap';
      wrap2.appendChild(inp);wrap2.appendChild(btn);wrap2.appendChild(sol);
      card.appendChild(wrap2);
      const fb=document.createElement('div');fb.className='feedback';card.appendChild(fb);
      btn.onclick=()=>{
        if(card.dataset.done)return;
        const ok=isCorrect(inp.value,t.answer);
        if(ok){
          card.dataset.done='1';
          fb.classList.add('ok');fb.innerHTML='✅ Richtig!'+(t.explanation?' <em>'+t.explanation+'</em>':'');
          state[hash]=1;correct++;pb_save(storageKey,state);
          if(bar)bar.set(correct,tasks.length);
          inp.disabled=true;
        } else {
          fb.classList.remove('ok');fb.classList.add('bad');
          fb.innerHTML='❌ Versuche es nochmal.'+(t.hint?' <em>Tipp: '+t.hint+'</em>':'');
        }
      };
      sol.onclick=()=>{
        const a=Array.isArray(t.answer)?t.answer[0]:t.answer;
        inp.value=a;fb.classList.remove('bad');fb.classList.add('ok');
        fb.innerHTML='💡 Lösung: <b>'+a+'</b>'+(t.explanation?' <em>'+t.explanation+'</em>':'');
        card.dataset.done='1';inp.disabled=true;
      };
      inp.addEventListener('keydown',e=>{if(e.key==='Enter')btn.click();});
      if(saved===1){correct++;card.dataset.done='1';inp.value=Array.isArray(t.answer)?t.answer[0]:t.answer;inp.disabled=true;fb.classList.add('ok');fb.innerHTML='✅ Bereits richtig gelöst.';}
    }
    container.appendChild(card);
  });
  if(bar)bar.set(correct,tasks.length);
}

/* ===== Section-Setup ===== */
function setupSection(key,pool,n,resetBtn,rerollBtn,checkBtn){
  const tasksEl=document.getElementById(key+'-tasks');
  const storageKey='pb_'+(window.PAGE_KEY||'page')+'_'+key;
  function render(){const picks=pickN(pool,n);renderTasks(tasksEl,picks,storageKey);}
  if(resetBtn)resetBtn.onclick=()=>{if(confirm('Diesen Abschnitt zurücksetzen?')){localStorage.removeItem(storageKey);render();}};
  if(rerollBtn)rerollBtn.onclick=render;
  if(checkBtn)checkBtn.onclick=()=>{tasksEl.querySelectorAll('.task').forEach(c=>{if(!c.dataset.done){const b=c.querySelector('.btn');if(b)b.click();}});};
  render();
}

/* ===== Quiz (WWM-Style, 15 Fragen aus >=40 Pool, 3 Joker, Geldleiter) ===== */
const WWM_AMOUNTS=['50€','100€','200€','300€','500€','1.000€','2.000€','4.000€','8.000€','16.000€','32.000€','64.000€','125.000€','500.000€','1 Mio. €'];
function pickByDifficulty(pool,d1n,d2n,d3n){
  const d1=pool.filter(q=>q.d===1),d2=pool.filter(q=>q.d===2),d3=pool.filter(q=>q.d===3);
  return shuffle([...pickN(d1,d1n),...pickN(d2,d2n),...pickN(d3,d3n)]);
}
function initQuiz(pool,quizContainer){
  const tasksEl=quizContainer.querySelector('#quiz-tasks');
  const resBtn=quizContainer.querySelector('#quiz-reset');
  const resultEl=quizContainer.querySelector('#quiz-result');
  const progress=quizContainer.querySelector('#quiz-progress');
  let questions=[],idx=0,correct=0,wrongs=[],streak=0,jokerUsed={fifty:false,phone:false,aud:false},startTime=0;
  function render(){
    if(idx>=questions.length){return showFinal();}
    const q=questions[idx];
    const lvlIdx=Math.min(idx,WWM_AMOUNTS.length-1);
    const ladder='<div class="wwm-ladder">'+WWM_AMOUNTS.map((amt,i)=>'<div class="wwm-rung'+(i===lvlIdx?' active':'')+(i<idx?' won':'')+([4,9,14].includes(i)?' milestone':'')+'">'+(i+1)+'. '+amt+'</div>').reverse().join('')+'</div>';
    const jokers='<div class="wwm-jokers"><button class="jk" id="jk-fifty"'+(jokerUsed.fifty?' disabled':'')+'>50:50</button><button class="jk" id="jk-phone"'+(jokerUsed.phone?' disabled':'')+'>📞 Telefon</button><button class="jk" id="jk-aud"'+(jokerUsed.aud?' disabled':'')+'>👥 Publikum</button></div>';
    const streakBox=streak>=3?'<div class="streak-box">🔥 '+streak+'er-Streak!</div>':'';
    tasksEl.innerHTML=ladder+'<div class="wwm-card"><div class="wwm-q">Frage '+(idx+1)+'/'+questions.length+': '+q.prompt+'</div>'+jokers+streakBox+'<div class="wwm-options" id="wwm-opts"></div><div class="wwm-fb" id="wwm-fb"></div></div>';
    const optsEl=tasksEl.querySelector('#wwm-opts');
    const optMap=q.options.map((o,i)=>({o,i}));
    optMap.forEach(({o,i})=>{
      const b=document.createElement('button');b.className='mc-opt';b.textContent=String.fromCharCode(65+i)+'. '+o;
      b.onclick=()=>answer(i,b);
      optsEl.appendChild(b);
    });
    document.getElementById('jk-fifty').onclick=()=>{if(jokerUsed.fifty)return;jokerUsed.fifty=true;document.getElementById('jk-fifty').disabled=true;
      // 50:50 entfernt 2 falsche Antworten
      const wrongOpts=[];optMap.forEach(({i})=>{if(i!==q.correct)wrongOpts.push(i);});
      shuffle(wrongOpts).slice(0,2).forEach(wi=>{const b=optsEl.children[wi];if(b){b.style.opacity='0.25';b.disabled=true;}});};
    document.getElementById('jk-phone').onclick=()=>{if(jokerUsed.phone)return;jokerUsed.phone=true;document.getElementById('jk-phone').disabled=true;
      const correct70=Math.random()>0.3;const guess=correct70?q.correct:Math.floor(Math.random()*q.options.length);
      alert('📞 Telefonjoker:\n"Hmm, ich glaube es ist '+String.fromCharCode(65+guess)+'."'+(correct70?'':' (klingt aber unsicher…)'));};
    document.getElementById('jk-aud').onclick=()=>{if(jokerUsed.aud)return;jokerUsed.aud=true;document.getElementById('jk-aud').disabled=true;
      // Publikum: 60% richtig, Rest verteilt
      const dist=[0,0,0,0];const correctPct=Math.random()>0.3?(50+Math.random()*30):(20+Math.random()*30);dist[q.correct]=Math.round(correctPct);
      let rem=100-dist[q.correct];for(let i=0;i<q.options.length;i++){if(i===q.correct)continue;const v=i===q.options.length-1?rem:Math.round(Math.random()*rem);dist[i]=v;rem-=v;if(rem<0)rem=0;}
      alert('👥 Publikumsjoker:\n'+q.options.map((o,i)=>String.fromCharCode(65+i)+': '+dist[i]+'%').join('\n'));};
  }
  function answer(i,btn){
    const q=questions[idx];const ok=(i===q.correct);
    btn.classList.add(ok?'correct':'wrong');
    const fb=document.getElementById('wwm-fb');
    if(ok){correct++;streak++;fb.className='wwm-fb ok';fb.innerHTML='✅ Richtig! <em>'+(q.explanation||'')+'</em>';}
    else{wrongs.push({q:q.prompt,correct:q.options[q.correct],chosen:q.options[i],expl:q.explanation||''});streak=0;fb.className='wwm-fb bad';fb.innerHTML='❌ Falsch. Richtig wäre: <b>'+q.options[q.correct]+'</b>. '+(q.explanation||'');
      const right=Array.from(document.querySelectorAll('#wwm-opts .mc-opt')).find(b=>b.textContent.startsWith(String.fromCharCode(65+q.correct)+'.'));
      if(right)right.classList.add('correct');}
    document.querySelectorAll('#wwm-opts .mc-opt').forEach(b=>b.disabled=true);
    updateBar();
    setTimeout(()=>{idx++;if(idx>=questions.length||(!ok && idx<questions.length)){if(!ok){idx=questions.length;showFinal();return;}}render();},1700);
  }
  function updateBar(){const fill=progress.querySelector('.progress-fill');const txt=progress.querySelector('.progress-text');const pct=Math.round(correct/questions.length*100);fill.style.width=pct+'%';txt.textContent='Fortschritt: '+correct+'/'+questions.length+' richtig ('+pct+'%)';}
  function showFinal(){
    const won=correct>=14?WWM_AMOUNTS[14]:correct>=9?WWM_AMOUNTS[9]:correct>=4?WWM_AMOUNTS[4]:'0€';
    const emoji=correct>=14?'🏆':correct>=10?'🎉':correct>=6?'👍':'📚';
    const head=correct>=14?'Millionär!':correct>=10?'Stark!':correct>=6?'Solide.':'Üben hilft.';
    let html='<div class="result-card"><div style="font-size:48px">'+emoji+'</div><h3>'+head+'</h3><p>'+correct+' von '+questions.length+' richtig · gewonnen: <b>'+won+'</b></p>';
    if(wrongs.length){html+='<details><summary>Fehler ansehen ('+wrongs.length+')</summary><ul style="text-align:left;font-size:14px;line-height:1.6;margin-top:8px">';
      wrongs.forEach(w=>{html+='<li><b>Frage:</b> '+w.q+'<br><b>Du:</b> '+w.chosen+' · <b>Richtig:</b> '+w.correct+(w.expl?'<br><em>'+w.expl+'</em>':'')+'</li>';});html+='</ul></details>';}
    html+='<button class="btn" onclick="location.reload()">Nochmal versuchen</button></div>';
    resultEl.innerHTML=html;resultEl.style.display='block';tasksEl.style.display='none';
  }
  function start(){questions=pickByDifficulty(pool,4,5,6);if(questions.length<15){const rest=pool.filter(p=>!questions.includes(p));questions=questions.concat(pickN(rest,15-questions.length));}idx=0;correct=0;wrongs=[];streak=0;jokerUsed={fifty:false,phone:false,aud:false};startTime=Date.now();resultEl.style.display='none';tasksEl.style.display='block';render();updateBar();}
  resBtn.onclick=()=>{if(confirm('Quiz neu starten?'))start();};
  // Erst beim ersten Öffnen rendern
  const acc=quizContainer.closest('details');
  let started=false;
  acc.addEventListener('toggle',()=>{if(acc.open && !started){started=true;start();}});
  if(acc.open){started=true;start();}
}

/* ===== Dark Mode (System-Default + manueller Override) ===== */
(function(){const stored=localStorage.getItem('darkMode');const sysDark=window.matchMedia('(prefers-color-scheme: dark)').matches;const useDark=stored==='1'||(stored===null && sysDark);if(useDark)document.body.classList.add('dark-mode');const btn=document.getElementById('dark-toggle');if(btn){btn.textContent=useDark?'☀️ Hell':'🌙 Dark Mode';btn.onclick=()=>{const on=document.body.classList.toggle('dark-mode');btn.textContent=on?'☀️ Hell':'🌙 Dark Mode';try{localStorage.setItem('darkMode',on?'1':'0');}catch(e){}};}})();

/* ===== TTS (Web Speech API) ===== */
const TTS={enabled:false,toggle(){this.enabled=!this.enabled;const b=document.getElementById('tts-toggle');if(b)b.textContent=this.enabled?'🔇 TTS aus':'🔊 Vorlesen';},speak(text,lang,rate){if(!this.enabled || !window.speechSynthesis)return;window.speechSynthesis.cancel();const u=new SpeechSynthesisUtterance(text);u.lang=lang||'en-US';u.rate=rate||0.95;window.speechSynthesis.speak(u);},stop(){if(window.speechSynthesis)window.speechSynthesis.cancel();}};
(function(){const b=document.getElementById('tts-toggle');if(b)b.onclick=()=>TTS.toggle();})();

/* ===== Reset-All Button ===== */
function resetAllProgress(prefix){if(!confirm('Gesamten Fortschritt dieser Seite zurücksetzen?'))return;const keys=[];for(let i=0;i<localStorage.length;i++){const k=localStorage.key(i);if(k && k.startsWith('pb_'+prefix))keys.push(k);}keys.forEach(k=>localStorage.removeItem(k));location.reload();}


</script>
