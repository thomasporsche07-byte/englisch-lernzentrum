  const resultBox=document.getElementById('quiz-result');
  let current=0,correct=0,wrongCount=0,wrongTasks=[],streak=0,earnedLevel=0,securedFloor=0;
  let timerStart=null,timerInterval=null,elapsedSeconds=0;
