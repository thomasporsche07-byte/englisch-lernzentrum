        target.querySelectorAll('.word-tile').forEach(t=>tgtTiles.push(t));
      }

      const notify=()=>{if(typeof onStatusChange==='function')onStatusChange();};

      function checkTiles(){
        if(locked)return input._correct;
        if(placed.length===0){feedback.textContent="Bitte ordne die Wörter.";feedback.className="feedback warn";return false;}
        const userSentence=placed.map(p=>p.word).join(' ');
        const userNorm=normalizeAnswer(userSentence);
        const okSet=answers.map(normalizeAnswer);
        if(okSet.some(a=>a===userNorm)){
          feedback.textContent="✓ Richtig!";feedback.className="feedback ok";
          input._correct=true;input._done=true;locked=true;
          tgtTiles.forEach(t=>{t.classList.remove('wt-placed');t.classList.add('wt-correct');});
          if(!isSolved){const updated=[...solvedTasks,tHash];saveProgress(progressKey,updated);savedAnswers[tHash]=userSentence+punct;saveProgress(answersKey,savedAnswers);wrap.classList.add('task--solved');solvedLabel.innerHTML=`✓ Bereits gelöst: <i>${userSentence}${punct}</i>`;}
          // TTS-Button am "Bereits gelöst"-Label nachinjizieren
          if(typeof TTS!=='undefined'&&TTS.enabled){delete solvedLabel.dataset.ttsReady;setTimeout(()=>TTS.injectAll(),30);}
          notify();return true;
        }else{
          failCount++;
          const hint=analyzeError(userSentence,answers);
          if(hint&&failCount<=2){feedback.innerHTML=`✗ Das passt noch nicht. ${hint}`;feedback.className="feedback bad";}
          else{feedback.textContent="✗ Das passt noch nicht. Versuche es erneut.";feedback.className="feedback bad";}
          tgtTiles.forEach(t=>{t.classList.add('wt-wrong');setTimeout(()=>t.classList.remove('wt-wrong'),500);});
          if(enableSolution){
            if(failCount>=2&&!hintShown)hintBtn.style.display="inline-flex";
            if(failCount>=3||(hintShown&&failCount>=2))solBtn.style.display="inline-flex";
          }
          input._correct=false;notify();return false;
        }
      }
      checkBtn.addEventListener('click',()=>checkTiles());
      clearBtn.addEventListener('click',()=>{
        if(locked)return;
        placed.length=0;target.innerHTML='';tgtTiles.length=0;
        srcTiles.forEach(t=>t.classList.remove('wt-used'));
        feedback.textContent='';feedback.className='feedback';
      });
      hintBtn.addEventListener('click',()=>{
        hintShown=true;
        hintBtn.style.display='none';
        const partial=buildPartialHint(answers[0]||'');
        hintBox.innerHTML=partial?`💡 <b>Tipp:</b> Fang so an: <i>${partial} …</i>`:`💡 <b>Tipp:</b> Schau dir die Regel im Akkordeon-Kopf an.`;
        hintBox.style.display='block';
      });
      solBtn.addEventListener('click',()=>{
        input._done=true;notify();solBox.style.display='block';locked=true;
