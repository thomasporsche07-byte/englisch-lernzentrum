(function initQuiz(){
  function pickByDifficulty(pool,total){
    function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
    const d1=shuffle(pool.filter(q=>q.d===1));
    const d2=shuffle(pool.filter(q=>q.d===2));
    const d3=shuffle(pool.filter(q=>q.d===3));
    const n1=Math.min(4,d1.length);
    const n3=Math.min(6,d3.length);
    const n2=Math.min(total-n1-n3,d2.length);
    return [...d1.slice(0,n1),...d2.slice(0,n2),...d3.slice(0,n3)];
  }
  let tasks=pickByDifficulty(quizPool,15);
  const total=tasks.length;
  const wrap=document.getElementById('quiz-tasks');
