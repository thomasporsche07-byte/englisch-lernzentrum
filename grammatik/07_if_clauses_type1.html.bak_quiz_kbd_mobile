(function initQuiz(){
  const AMOUNTS=['50 €','100 €','200 €','300 €','500 €','1.000 €','2.000 €','4.000 €','8.000 €','16.000 €','32.000 €','64.000 €','125.000 €','500.000 €','1.000.000 €'];
  const MILESTONES=[4,9];
  const container=document.getElementById('quiz-tasks');
  const resultDiv=document.getElementById('quiz-result');
  const progressRoot=document.querySelector('#quiz-progress .progress');
  const progressCtrl=initProgressBar(progressRoot,15);
  let questions=[],current=0,correctCount=0,phoneUsed=false,audienceUsed=false,fiftyUsed=false;
  let lastHiddenIndices=[];

  function buildLadder(cur){
    let html='';
    for(let i=AMOUNTS.length-1;i>=0;i--){
      let cls='wwm-ladder-row';
      if(MILESTONES.includes(i))cls+=' milestone';
      if(i<cur)cls+=' done';
      if(i===cur)cls+=' current';
      const icon=MILESTONES.includes(i)?(i<cur?'✅':i===cur?'🏆':'🛡️'):(i<cur?'✓':i===cur?'▶':'');
      html+='<div class="'+cls+'"><span class="wwm-qnum">'+(i+1)+'</span><span class="wwm-amount">'+AMOUNTS[i]+'</span><span style="font-size:11px;margin-left:2px">'+icon+'</span></div>';
    }
    return html;
  }

  function showQuestion(idx){
    if(idx>=questions.length){showFinal(correctCount,questions.length);return;}
    const q=questions[idx];
    const letters=['A','B','C','D'];
    const optIndices=[...Array(q.options.length).keys()];
    for(let i=optIndices.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[optIndices[i],optIndices[j]]=[optIndices[j],optIndices[i]];}
    const shuffled=optIndices.map(i=>q.options[i]);
    const correctShuffled=optIndices.indexOf(q.correct);
    lastHiddenIndices=[];
    const lifelines=[
      {id:'fifty',label:'50/50',used:fiftyUsed},
      {id:'phone',label:'📞 Joker',used:phoneUsed},
      {id:'audience',label:'👥 Publikum',used:audienceUsed}
    ];
    const lifelineHtml=lifelines.map(l=>`<span class="chip${l.used?' chip-used':''}" data-joker="${l.id}">${l.label}</span>`).join('');
    const html=`
    <div class="wwm-layout quiz-question-enter">
      <div class="wwm-main">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:10px">
          <div class="wwm-qbadge">Frage ${idx+1} / ${questions.length} &nbsp;·&nbsp; ${AMOUNTS[idx]}</div>
          <div class="quiz-streak" id="quiz-streak"></div>
        </div>
        <div class="wwm-lifelines">${lifelineHtml}</div>
        <div class="task wwm-stage">
          <div class="prompt">${q.prompt}</div>
          <div class="wwm-joker-options" id="wwm-options">
            ${shuffled.map((opt,i)=>`<button class="wwm-option-btn" data-opt="${i}"><span class="wwm-opt-letter">${letters[i]}</span><span>${opt}</span></button>`).join('')}
          </div>
          <div id="wwm-joker-extra"></div>
          <div class="feedback" id="wwm-feedback"></div>
          <div id="wwm-explanation" style="display:none" class="quiz-explanation-box"></div>
          <div class="controls" style="margin-top:14px;display:none" id="wwm-next-ctrl">
            <button class="btn green" id="wwm-next">Weiter →</button>
          </div>
        </div>
      </div>
      <div class="wwm-ladder">${buildLadder(idx)}</div>
    </div>`;
    container.innerHTML=html;
    progressCtrl.update(correctCount,idx);

    document.querySelectorAll('.wwm-option-btn').forEach(btn=>{
      btn.addEventListener('click',()=>{
        const chosen=+btn.dataset.opt;
        document.querySelectorAll('.wwm-option-btn').forEach(b=>b.disabled=true);
        const fb=document.getElementById('wwm-feedback');
        const expl=document.getElementById('wwm-explanation');
        const nctrl=document.getElementById('wwm-next-ctrl');
        if(chosen===correctShuffled){
          btn.style.background='linear-gradient(90deg,rgba(0,180,80,.3),rgba(0,150,60,.2))';
          btn.style.borderColor='#00e676';
          fb.textContent='✓ Richtig! +'+AMOUNTS[idx];fb.className='feedback ok';
          correctCount++;
          progressCtrl.update(correctCount,idx+1);
        }else{
          btn.style.background='linear-gradient(90deg,rgba(180,0,0,.3),rgba(140,0,0,.2))';
          btn.style.borderColor='#ff5555';
          const correctBtn=document.querySelectorAll('.wwm-option-btn')[correctShuffled];
          if(correctBtn){correctBtn.style.background='linear-gradient(90deg,rgba(0,180,80,.3),rgba(0,150,60,.2))';correctBtn.style.borderColor='#00e676';}
          fb.innerHTML='✗ Falsch! Richtige Antwort: <b>'+shuffled[correctShuffled]+'</b>';fb.className='feedback bad';
          if(q.explanation){expl.innerHTML=q.explanation;expl.style.display='block';}
          if(q.tip){const tb=document.createElement('div');tb.className='quiz-tip-box';tb.innerHTML='💡 <b>Tipp:</b> '+q.tip;nctrl.parentNode.insertBefore(tb,nctrl);}
          // WWM: falsche Antwort → nur Ergebnis ansehen, kein Weiterspielen
          nctrl.style.display='flex';
          const nextBtn=document.getElementById('wwm-next');
          if(nextBtn){nextBtn.textContent='Ergebnis ansehen →';nextBtn.className='btn gray';nextBtn.dataset.next='1';nextBtn.addEventListener('click',()=>showFinal(correctCount,questions.length));}
          return;
        }
        if(q.explanation){expl.innerHTML=q.explanation;expl.style.display='block';}
        nctrl.style.display='flex';
        const nextBtn=document.getElementById('wwm-next');
        if(nextBtn){
          nextBtn.addEventListener('click',()=>{
            current++;
            showQuestion(current);
            setTimeout(()=>typeof TTS!=='undefined'&&TTS.injectAll&&TTS.injectAll(),60);
          });
        }
      });
    });

    document.querySelectorAll('.chip[data-joker]').forEach(chip=>{
      chip.addEventListener('click',()=>{
        const joker=chip.dataset.joker;
        if(chip.classList.contains('chip-used'))return;
        chip.classList.add('chip-used');
        if(joker==='fifty'){
          fiftyUsed=true;
          const wrong=[];
          document.querySelectorAll('.wwm-option-btn').forEach((b,i)=>{if(i!==correctShuffled)wrong.push(i);});
          const hide=wrong.sort(()=>Math.random()-.5).slice(0,2);
          lastHiddenIndices=hide;
          hide.forEach(i=>{const b=document.querySelectorAll('.wwm-option-btn')[i];if(b){b.style.opacity='0.2';b.disabled=true;}});
        }else if(joker==='phone'){
          phoneUsed=true;
          const ruleHint=q.tip||'Denk an das Grundprinzip: If-Typ 1 = if + Simple Present, Hauptsatz + will + Grundform. KEIN will im if-Teil! Verneinung: don\'t/doesn\'t + Grundform / won\'t + Grundform. Komma nur wenn if-Teil vorne steht.';
          const extra=document.getElementById('wwm-joker-extra');
          extra.innerHTML=`<div class="wwm-phone-bubble"><div class="wwm-phone-icon">📞</div><div class="wwm-phone-text"><b>Dein Lehrer meldet sich:</b><br>${ruleHint}</div></div>`;
        }else if(joker==='audience'){
          audienceUsed=true;
          const pcts=[];let rem=100;
          for(let i=0;i<4;i++){const v=i===correctShuffled?Math.floor(40+Math.random()*35):Math.floor(5+Math.random()*20);pcts.push(v);}
          const sum=pcts.reduce((a,b)=>a+b,0);const scale=100/sum;const scaled=pcts.map(v=>Math.round(v*scale));
          const colors=['#4fc3f7','#ef5350','#66bb6a','#ffb74d'];
          const extra=document.getElementById('wwm-joker-extra');
          const barsHtml=shuffled.map((opt,i)=>`<div class="wwm-audience-col"><div class="wwm-audience-pct">${scaled[i]}%</div><div class="wwm-audience-bar" style="height:${Math.max(4,Math.round(scaled[i]*0.8))}px;background:${colors[i]};align-self:flex-end"></div><div class="wwm-audience-label">${letters[i]}</div></div>`).join('');
          extra.innerHTML=`<div class="wwm-audience-box"><div class="wwm-audience-title">👥 Publikumsjoker</div><div class="wwm-audience-bars">${barsHtml}</div></div>`;
        }
      });
    });
    setTimeout(()=>typeof TTS!=='undefined'&&TTS.injectAll&&TTS.injectAll(),60);
  }

  function showFinal(correct,total){
    const pct=Math.round(correct/total*100);
    let msg,emoji;
    if(pct===100){msg='EINE MILLION! 🎉 PERFEKT! If-Sätze Typ 1 hast du voll im Griff!';emoji='🏆';}
    else if(pct>=90){msg='Fast perfekt – if + Simple Present und will + Grundform sitzen!';emoji='🥇';}
    else if(pct>=80){msg='Richtig stark – Aufbau, Verneinung und Komma sind klar!';emoji='🥈';}
    else if(pct>=60){msg='Gut gemacht – noch etwas üben, dann sitzt es!';emoji='👍';}
    else if(pct>=40){msg='Weiter üben – besonders: KEIN will im if-Satz und die Komma-Regel!';emoji='💪';}
    else{msg='Nochmal von vorne – schau dir die Regelkarten an. Merke: if + Simple Present, Hauptsatz + will.';emoji='📚';}
    container.innerHTML='';
    resultDiv.style.display='block';
    resultDiv.innerHTML=`<div style="padding:28px 22px;text-align:center">
      <div style="font-size:52px;margin-bottom:8px">${emoji}</div>
      <div style="font-size:26px;font-weight:900;color:#ffcc00;margin-bottom:8px" class="score">${correct} / ${total}</div>
      <div style="font-size:17px;font-weight:700;color:#fff;margin-bottom:16px">${msg}</div>
      <button class="btn" style="background:linear-gradient(135deg,#0d3080,#1e4db5);color:#ffecb3;border:1px solid rgba(255,204,0,.4);padding:12px 28px;font-size:15px" onclick="document.getElementById('quiz-reset').click()">🔄 Nochmal spielen</button>
    </div>`;
    progressCtrl.update(correct,total);
  }

  function startGame(){
    current=0;correctCount=0;phoneUsed=false;audienceUsed=false;fiftyUsed=false;lastHiddenIndices=[];
    resultDiv.style.display='none';
    const byDiff=(d)=>quizPool.filter(q=>q.d===d);
    const d1=shuffle(byDiff(1)).slice(0,5);
    const d2=shuffle(byDiff(2)).slice(0,5);
    const d3=shuffle(byDiff(3)).slice(0,5);
    questions=[...d1,...d2,...d3];
    progressCtrl.setTotal(questions.length);
    progressCtrl.update(0,0);
    showQuestion(0);
  }

  document.getElementById('quiz-reset').addEventListener('click',startGame);
  startGame();
  saveProgress('quiz_started',true);
})();

