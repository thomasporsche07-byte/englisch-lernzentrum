      if(isSolved){input._correct=true;input._done=true;}
      wrap.appendChild(input);
      const feedback=document.createElement("div");feedback.className="feedback";
      let answered=isSolved;
      const optBtns=[];
      // Optionen mischen, damit die richtige Antwort nicht immer an der gleichen Stelle steht
      const optIndices=[...Array(t.options.length).keys()];
      for(let i=optIndices.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[optIndices[i],optIndices[j]]=[optIndices[j],optIndices[i]];}
      const shuffledOpts=optIndices.map(i=>t.options[i]);
      const correctIdx=optIndices.indexOf(t.correct);
      shuffledOpts.forEach((opt,oi)=>{
        const btn=document.createElement("button");btn.className="mc-opt";btn.type="button";
        if(isSolved){btn.classList.add('mc-disabled');if(oi===correctIdx)btn.classList.add('mc-correct');}
        btn.innerHTML=`<span class="mc-letter">${letters[oi]||oi+1}</span><span>${opt}</span>`;
        btn.addEventListener('click',()=>{
          if(answered)return;
          answered=true;
          optBtns.forEach(b=>b.classList.add('mc-disabled'));
          if(oi===correctIdx){
            btn.classList.add('mc-correct');
            feedback.textContent="✓ Richtig!";feedback.className="feedback ok";
            input._correct=true;input._done=true;input.value=opt;
            if(!isSolved){const updated=[...solvedTasks,tHash];saveProgress(progressKey,updated);savedAnswers[tHash]=opt;saveProgress(answersKey,savedAnswers);wrap.classList.add('task--solved');solvedLabel.innerHTML=`✓ Bereits gelöst: <i>${opt}</i>`;}
          }else{
            btn.classList.add('mc-wrong');
            optBtns[correctIdx].classList.add('mc-correct');
            feedback.textContent="✗ Leider falsch.";feedback.className="feedback bad";
            input._correct=false;input._done=true;input.value=opt;
          }
          if(typeof onStatusChange==='function')onStatusChange();
        });
        optBtns.push(btn);
        mcBox.appendChild(btn);
      });
      wrap.appendChild(mcBox);
      wrap.appendChild(feedback);
      input._check=()=>{if(!answered){feedback.textContent="Bitte wähle eine Antwort.";feedback.className="feedback warn";return false;}return input._correct;};
      input._reset=()=>{answered=false;input._correct=false;input._done=false;input.value="";feedback.textContent="";feedback.className="feedback";optBtns.forEach(b=>{b.classList.remove('mc-correct','mc-wrong','mc-selected','mc-disabled');});solvedLabel.textContent='';wrap.classList.remove('task--solved');if(typeof onStatusChange==='function')onStatusChange();};
      container.appendChild(wrap);
      return;
    }

    // ========== Wörter ordnen (Tap-to-Order Tiles) ==========
    if(Array.isArray(t.words)){
      const answers=Array.isArray(t.answer)?t.answer:[t.answer];
      const correct=(answers[0]||'').replace(/[.?!]$/,'').trim();
      const punct=answers[0]&&answers[0].slice(-1).match(/[.?!]/)?answers[0].slice(-1):'.';
      let mixed=shuffle([...t.words]);
      let tries=0;
      while(mixed.join(' ').toLowerCase()===correct.toLowerCase()&&tries<10){mixed=shuffle([...t.words]);tries++;}
      if(mixed.join(' ').toLowerCase()===correct.toLowerCase()&&mixed.length>=2){[mixed[0],mixed[1]]=[mixed[1],mixed[0]];}

      const prompt=document.createElement("p");prompt.className="prompt";prompt.textContent=(t.label||'Ordne')+': Tippe die Wörter in der richtigen Reihenfolge an.';
      wrap.appendChild(prompt);

      const input=document.createElement("input");input.type="hidden";input.id=`${sectionKey}-input-${idx}`;
      if(isSolved){input._correct=true;input._done=true;}
      wrap.appendChild(input);

      const sourceLabel=document.createElement("div");sourceLabel.className="word-tiles-label";sourceLabel.textContent="Verfügbare Wörter:";
      const source=document.createElement("div");source.className="word-tiles wt-source";
      const targetLabel=document.createElement("div");targetLabel.className="word-tiles-label";targetLabel.style.marginTop="10px";targetLabel.textContent="Dein Satz:";
      const target=document.createElement("div");target.className="word-tiles wt-target";
      const feedback=document.createElement("div");feedback.className="feedback";
      const controls=document.createElement("div");controls.className="controls";
      const checkBtn=document.createElement("button");checkBtn.className="btn primary";checkBtn.textContent="Prüfen";
      const clearBtn=document.createElement("button");clearBtn.className="btn ghost";clearBtn.textContent="Zurücksetzen";
      const hintBtn=document.createElement("button");hintBtn.className="btn ghost";hintBtn.textContent="💡 Tipp zeigen";hintBtn.style.display='none';
