function tipsToggle() {
  const body = document.getElementById('writing-tips-body');
  const icon = document.getElementById('tips-toggle-icon');
  const open = body.classList.toggle('open');
  icon.classList.toggle('open', open);
}

function updateWritingTips() {
  const type = document.getElementById('sel-type').value;
  const tip = WRITING_TIPS[type] || WRITING_TIPS['free'];
  const body = document.getElementById('writing-tips-body');
  const title = document.getElementById('writing-tips-title');

  title.innerHTML = tip.title;

  const structureHtml = tip.structure.map((s, i) =>
    s === '→'
      ? `<span class="tips-structure-arrow">→</span>`
      : `<div class="tips-structure-item">${s}</div>`
  ).join('');

  const checksHtml = tip.checks.map(c =>
    `<li>${c}</li>`
  ).join('');

  body.innerHTML = `
    <div class="tips-structure">${structureHtml}</div>
    <ul class="tips-checklist" style="margin-top:10px">${checksHtml}</ul>
    <ul class="tips-checklist" style="margin-top:8px"><li class="tip-note">${tip.note}</li></ul>
  `;
}

function countWords(t) { return t.trim()===''?0:t.trim().split(/\s+/).length; }

let autosaveTimer = null;
function updateWordCount() {
  const n = countWords(document.getElementById('student-text').value);
  const el = document.getElementById('word-counter');
  el.textContent = n + ' Wörter';
  el.className = 'word-counter' + (n >= 60 ? ' ok' : n > 0 ? ' low' : '');
  // Autosave
  const ind = document.getElementById('autosave-indicator');
  const txt = document.getElementById('autosave-text');
  ind.className = 'autosave-indicator visible';
  txt.textContent = 'Wird gespeichert …';
  clearTimeout(autosaveTimer);
  autosaveTimer = setTimeout(() => {
    try {
      localStorage.setItem('wt_draft', document.getElementById('student-text').value);
      localStorage.setItem('wt_draft_cls', document.getElementById('sel-class').value);
      localStorage.setItem('wt_draft_type', document.getElementById('sel-type').value);
    } catch(e) {}
    ind.className = 'autosave-indicator visible saved';
    txt.textContent = 'Entwurf gespeichert ✓';
    setTimeout(() => ind.className = 'autosave-indicator', 2500);
  }, 800);
}

function restoreDraft() {
  try {
    const draft = localStorage.getItem('wt_draft');
    const cls   = localStorage.getItem('wt_draft_cls');
    const type  = localStorage.getItem('wt_draft_type');
    if (draft && draft.trim()) {
      if (cls) { document.getElementById('sel-class').value = cls; updateTextTypes(true); }
      if (type) {
        const sel = document.getElementById('sel-type');
        const opt = [...sel.options].find(o => o.value === type);
        if (opt) sel.value = type;
      }
      document.getElementById('student-text').value = draft;
      updateWordCount();
      updateWritingTips();
      const ind = document.getElementById('autosave-indicator');
      const txt = document.getElementById('autosave-text');
      ind.className = 'autosave-indicator visible saved';
      txt.textContent = 'Entwurf wiederhergestellt ✓';
      setTimeout(() => ind.className = 'autosave-indicator', 3000);
    }
  } catch(e) {}
}

function adoptAndImprove() {
  const corrected = document.getElementById('corrected-text').textContent;
  if (!corrected) return;
  document.getElementById('student-text').value = corrected;
  updateWordCount();
  document.getElementById('student-text').scrollIntoView({behavior:'smooth', block:'start'});
  setTimeout(() => document.getElementById('student-text').focus(), 400);
}

