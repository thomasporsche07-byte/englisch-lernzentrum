function bindLevelTabs(id,cb){document.getElementById(id).addEventListener('click',e=>{const b=e.target.closest('[data-level]');if(!b)return;document.getElementById(id).querySelectorAll('[data-level]').forEach(x=>x.classList.remove('active'));b.classList.add('active');cb(parseInt(b.dataset.level));});}

