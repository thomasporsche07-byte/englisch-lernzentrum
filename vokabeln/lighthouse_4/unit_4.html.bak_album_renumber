// Einmalig pro Browser. Kopiert pb_/lt_/album_-Daten vom alten Norm-Title auf den neuen.
// Die alten Keys bleiben bestehen, falls noch nicht migrierte Schwesterdateien sie brauchen.
(function migrateTitleKeysV1(){
  try{
    const newNorm = PAGE_TITLE.replace(/[^a-zA-Z0-9]/g,'_');
    const FLAG = 'mig_title_v1_'+newNorm;
    if(localStorage.getItem(FLAG)) return;
    const m = newNorm.match(/^Lighthouse_\d+___(.*)$/);
    if(m){
      const oldNorm = m[1];
      const keys = [];
      for(let i=0;i<localStorage.length;i++){
        const k = localStorage.key(i);
        if(!k) continue;
        if(k === 'lt_'+oldNorm || k === 'album_'+oldNorm || k.startsWith('pb_'+oldNorm+'_')){
          keys.push(k);
        }
      }
      keys.forEach(k=>{
        const newK = k.replace(oldNorm, newNorm);
        if(localStorage.getItem(newK) === null){
          localStorage.setItem(newK, localStorage.getItem(k));
        }
      });
    }
    localStorage.setItem(FLAG,'1');
  }catch(e){}
})();

