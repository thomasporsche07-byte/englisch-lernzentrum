  <div class="rules-modal-box" id="rules-modal-box">
    <div class="rules-modal-header" id="rules-modal-header">
      <h3>⚡ Regeln auf einen Blick</h3>
      <span class="rules-modal-drag-hint">↕ verschiebbar</span>
