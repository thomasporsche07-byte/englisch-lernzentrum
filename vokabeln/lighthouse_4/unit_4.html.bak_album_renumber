function lt_load(){try{return JSON.parse(localStorage.getItem(LT_KEY))||{};}catch(e){return {};}}
function lt_save(s){try{localStorage.setItem(LT_KEY,JSON.stringify(s));}catch(e){}}
function lt_score(en){const s=lt_load();return (s[en]||0);}
function lt_record(en, ok){
  if(!en) return;
  const key = String(en);
  const s = lt_load();
  s[key] = (s[key]||0) + (ok?1:-1);
  // clamp
  if(s[key]>5) s[key]=5;
  if(s[key]<-5) s[key]=-5;
  lt_save(s);
  if(ok) album_add(key);
}
// Bias-Pick: 60% aus den schwächsten 50%, 40% random
function lt_pick(arr, n){
  if(!arr || arr.length===0) return [];
  if(arr.length<=n) return shuffle([...arr]);
  const scored = arr.map(item=>{
    const k = item.__key || item.en || item.answer || item.english || '';
    const key = Array.isArray(k) ? k[0] : k;
    return {item, score: lt_score(key), key};
  });
  scored.sort((a,b)=> a.score - b.score);
  const half = Math.max(1, Math.ceil(scored.length/2));
  const weak = scored.slice(0, half).map(r=>r.item);
  const all  = scored.map(r=>r.item);
  const fromWeak = Math.round(n * 0.6);
  const fromAll  = n - fromWeak;
  const picks = [...pickRandom(weak, fromWeak), ...pickRandom(all, fromAll)];
  const seen = new Set();
  const dedup = [];
  picks.forEach(p=>{
    const k = p.__key || p.en || p.answer || p.english || JSON.stringify(p);
    if(!seen.has(k)){seen.add(k); dedup.push(p);}
  });
  // auffüllen falls zu wenig
  let safety = 0;
  while(dedup.length < n && dedup.length < arr.length && safety < 50){
    const cand = pickRandom(all, 1)[0];
    const k = cand.__key || cand.en || cand.answer || cand.english || JSON.stringify(cand);
    if(!seen.has(k)){seen.add(k); dedup.push(cand);}
    safety++;
  }
  return dedup.slice(0, n);
}

