function fireLaserSI(alien,cb){
  // Freeze alien movement during shot
  const savedSpeed=alien.speed;
  alien.speed=0;
  setTimeout(()=>{
    if(!arenaEl)return;
    const arenaRect=arenaEl.getBoundingClientRect();
    // Ship center
    const shipRect=shipEl.getBoundingClientRect();
    const shipX=shipRect.left+shipRect.width/2-arenaRect.left;
    const shipY=shipRect.top+shipRect.height*0.3-arenaRect.top;
    // Alien center (getBoundingClientRect accounts for transform)
    const alienRect=alien.el.getBoundingClientRect();
    const alienX=alienRect.left+alienRect.width/2-arenaRect.left;
    const alienY=alienRect.top+alienRect.height/2-arenaRect.top;
    // Draw SVG laser
    const aw=arenaEl.offsetWidth,ah=arenaEl.offsetHeight;
    const ns='http://www.w3.org/2000/svg';
    const svg=document.createElementNS(ns,'svg');
    svg.setAttribute('class','si-laser-svg');
    svg.setAttribute('viewBox','0 0 '+aw+' '+ah);
    const g=document.createElementNS(ns,'line');
    g.setAttribute('class','glow');
    g.setAttribute('x1',shipX);g.setAttribute('y1',shipY);
    g.setAttribute('x2',alienX);g.setAttribute('y2',alienY);
    svg.appendChild(g);
    const l=document.createElementNS(ns,'line');
    l.setAttribute('x1',shipX);l.setAttribute('y1',shipY);
    l.setAttribute('x2',alienX);l.setAttribute('y2',alienY);
    svg.appendChild(l);
    arenaEl.appendChild(svg);
    alien.speed=savedSpeed;
    if(cb)cb();
    setTimeout(()=>svg.remove(),300);
  },220);
}

function failAlien(alien){
  if(alien.done)return;
  alien.done=true;
  alien.el.classList.add('missed');
  lives--;missed++;
  wrongList.push({...alien.task,chosen:alien.lastWrong||'⏰'});
