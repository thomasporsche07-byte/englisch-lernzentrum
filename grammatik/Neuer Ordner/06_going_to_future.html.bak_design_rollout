        else if(/\bgoing\s+to\b/.test(ans))html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>Grundregel:</b> Subjekt + am/is/are + <b>going to</b> + Verb (Grundform – kein -s, kein -ing!)</div>`;
        else if(/\bwill\b|\bwon'?t\b/.test(ans))html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>will</b> = spontane Entscheidung oder Vermutung. <b>going to</b> = vorher geplant oder Vorhersage mit Beweis.</div>`;
        else html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>Going to Future:</b> am/is/are + going to + Verb in der Grundform</div>`;
      }
      solBox.innerHTML=html;
      // TTS-Button für Lösung
      if(typeof TTS!=='undefined'&&TTS.enabled){const ans=answers[0]||'';const sb=TTS.createBtn(ans,'en-GB','font-size:14px;margin-left:6px;');const bEl=solBox.querySelector('b');if(bEl)bEl.insertAdjacentElement('afterend',sb);}
    });
    input._check=checkOne;
    input._reset=()=>{input.value="";input._correct=false;input._done=false;failCount=0;hintShown=false;notify();feedback.textContent="";feedback.className="feedback";hintBtn.style.display='none';hintBox.style.display='none';hintBox.textContent='';solBtn.style.display='none';solBox.style.display="none";solBox.textContent="";solvedLabel.textContent='';wrap.classList.remove('task--solved');};
  });
  // TTS-Buttons injizieren falls aktiviert
  if(typeof TTS!=='undefined'&&TTS.enabled)setTimeout(()=>TTS.injectAll(),50);
}
function setupSection(sectionKey,levelButtons,container,pools,checkAllBtn,resetBtn,enableSolution){
  const progressRoot=document.querySelector(`#${sectionKey}-progress .progress`);
  const progressCtrl=initProgressBar(progressRoot,15);
  let currentLevel=1;const levelCache={};
  function updateProgress(){
    const inputs=container.querySelectorAll(".task input");let correct=0,done=0;
    inputs.forEach(inp=>{if(inp._correct)correct++;if(inp._done)done++;});
    progressCtrl.update(correct,done);
    const total=inputs.length;
    const activeBtn=levelButtons.querySelector(`button[data-level="${currentLevel}"]`);
    if(activeBtn&&total>0){const base=activeBtn.dataset.label||activeBtn.textContent.replace(' ✓','');activeBtn.dataset.label=base;activeBtn.textContent=correct===total?base+' ✓':base;}
    if(correct===total&&total>0)checkCelebration(container,progressCtrl);
  }
  const renderLevel=(lvl)=>{
    currentLevel=lvl;
    levelButtons.querySelectorAll('button').forEach(b=>{const isActive=+b.dataset.level===lvl;b.classList.toggle('active',isActive);b.setAttribute('aria-pressed',isActive?'true':'false');if(!b.dataset.label)b.dataset.label=b.textContent.replace(' ✓','');});
    container.querySelectorAll('.result-banner').forEach(b=>b.remove());container.querySelectorAll('.error-list').forEach(b=>b.remove());
    if(!levelCache[lvl]){const pickKey=`${sectionKey}_L${lvl}`;const div=document.createElement('div');renderTasks(div,pickRandom(pools[lvl],15,pickKey),sectionKey,{enableSolution,onStatusChange:updateProgress,currentLevel:lvl});levelCache[lvl]=div;}
    Object.values(levelCache).forEach(div=>{if(div.parentNode===container)container.removeChild(div);});
    container.appendChild(levelCache[lvl]);
    progressCtrl.setTotal(levelCache[lvl].querySelectorAll(".task input").length);
    updateProgress();
    const hasFreitext=levelCache[lvl].querySelector('input[type="text"]')!==null;
    checkAllBtn.style.display=hasFreitext?'':'none';
  };
  levelButtons.addEventListener('click',(e)=>{const b=e.target.closest('button[data-level]');if(!b)return;renderLevel(+b.dataset.level);});
  checkAllBtn.addEventListener('click',()=>{
    const inputs=container.querySelectorAll(".task input");let ok=0,total=0;const wrongItems=[];
    inputs.forEach(inp=>{if(typeof inp._check==='function'){total++;if(inp._check(true))ok++;}});
    updateProgress();
    if(total>0){
      container.querySelectorAll('.result-banner').forEach(b=>b.remove());container.querySelectorAll('.error-list').forEach(b=>b.remove());
      inputs.forEach(inp=>{const wrap=inp.closest('.task');if(!wrap)return;if(inp._correct){wrap.classList.remove('task--wrong');}else if(inp.value&&inp.value.trim()){wrap.classList.add('task--wrong');const pEl=wrap.querySelector('.prompt');const nEl=wrap.querySelector('div[style*="color:#b8905a"]');wrongItems.push({num:nEl?nEl.textContent:'',prompt:pEl?pEl.textContent:'',userVal:inp.value.trim()});}});
      const pct=Math.round(ok/total*100);const banner=document.createElement('div');banner.className='result-banner';
      const col=pct===100?'#3d7a2e':pct>=60?'#b85c20':'#b83a22';const em=pct===100?'🏆':pct>=60?'👍':'💪';
      banner.style.cssText=`margin:10px 0 6px;padding:12px 16px;border-radius:12px;border:2px solid ${col};background:${col}18;font-size:15px;font-weight:700;color:${col};display:flex;align-items:center;gap:10px;`;
      banner.innerHTML=`<span style="font-size:22px">${em}</span><span>Ergebnis: <b>${ok} / ${total}</b> richtig (${pct}%)</span>`;
      container.prepend(banner);
      if(wrongItems.length>0){const el=document.createElement('div');el.className='error-list';el.style.cssText='margin:0 0 12px;padding:10px 14px;border-radius:10px;border:1px solid #fca5a5;background:#fff5f5;font-size:13px;';el.innerHTML=`<div style="font-weight:800;color:#b91c1c;margin-bottom:6px;">✗ Noch nicht richtig (${wrongItems.length}):</div>`+wrongItems.map(w=>`<div style="padding:3px 0;border-top:1px solid #fee2e2;color:#374151;"><span style="color:#9ca3af;font-size:11px;">${w.num}</span> <span>${w.prompt}</span></div>`).join('');container.insertBefore(el,banner.nextSibling);}
      setTimeout(()=>banner.scrollIntoView({behavior:'smooth',block:'nearest'}),80);
