function normalizeAnswer(text){
  if(!text) return "";
  let s=(""+text).toLowerCase();
  // Alle Apostroph-Varianten vereinheitlichen
  s=s.replace(/[\u0027\u00B4\u2018\u2019\u201A\u201B\u2032\u2035\u02B9\u02BB\u02BC\u02BE\u02BF\uFF07\u0060`´]/g,"'");
  // Kontraktionen MIT Apostroph auflösen
  s=s.replace(/won't/g,"will not");
  s=s.replace(/don't/g,"do not");
  s=s.replace(/doesn't/g,"does not");
  s=s.replace(/isn't/g,"is not");
  s=s.replace(/aren't/g,"are not");
  s=s.replace(/can't/g,"can not");
  // Kontraktionen OHNE Apostroph (häufige Schülerfehler)
  s=s.replace(/\bdoesnt\b/g,"does not");
  s=s.replace(/\bdont\b/g,"do not");
  s=s.replace(/\bisnt\b/g,"is not");
  s=s.replace(/\barent\b/g,"are not");
  s=s.replace(/\bwont\b/g,"will not");
  s=s.replace(/\bcant\b/g,"can not");
  // Satzzeichen + Leerzeichen normalisieren
  s=s.replace(/[.,!?:;"]+/g," ").replace(/\s+/g," ").trim();
  s=s.normalize("NFD").replace(/[\u0300-\u036f]/g,"");
  return s;
}

