// ===== FEHLERANALYSE =====
// Generische wortweise Diff-Analyse: findet das erste abweichende Wort und
// klassifiziert den Fehler (Endung, Grundform, y→ies, has/have, fehlend/zuviel).
// Themen-unabhängig — funktioniert für Simple Present, Will Future etc.
function diffHint(userInput, correctAnswer){
  const uN=normalizeAnswer(userInput);
  const cN=normalizeAnswer(correctAnswer);
  if(!uN||!cN||uN===cN)return null;
  const uW=uN.split(/\s+/).filter(Boolean);
  const cW=cN.split(/\s+/).filter(Boolean);
  let i=0;const max=Math.max(uW.length,cW.length);
  while(i<max&&uW[i]===cW[i])i++;
  if(i>=max)return null;
  const uWord=uW[i]||'';
  const cWord=cW[i]||'';
  if(!uWord&&cWord){
    if(/^(do|does|is|are|will|has|have|was|were)$/.test(cWord))
      return `💡 Es fehlt das Hilfsverb <b>${cWord}</b>.`;
    return `💡 An Stelle ${i+1} fehlt noch ein Wort.`;
  }
  if(uWord&&!cWord)return `💡 Das Wort <b>${uWord}</b> am Ende gehört nicht dazu.`;
  if(cWord===uWord+'s'||cWord===uWord+'es')
    return `💡 Das Verb braucht hier die Endung <b>-${cWord.slice(uWord.length)}</b>: <i>${uWord}</i> → <b>${cWord}</b>.`;
  if(uWord===cWord+'s'||uWord===cWord+'es')
    return `💡 Hier gehört die <b>Grundform</b>: <i>${uWord}</i> → <b>${cWord}</b>.`;
  if(cWord.endsWith('ies')&&uWord.endsWith('ys')&&cWord.slice(0,-3)===uWord.slice(0,-2))
    return `💡 Verben auf <b>-y</b> werden zu <b>-ies</b>: <i>${uWord}</i> → <b>${cWord}</b>.`;
  const pairs={'has':'have','have':'has','does':'do','do':'does','is':'are','are':'is','was':'were','were':'was'};
  if(pairs[uWord]===cWord)
    return `💡 Hier brauchst du <b>${cWord}</b>, nicht <i>${uWord}</i>.`;
  if(uWord.length>=3&&cWord.length>=3&&uWord[0]===cWord[0]&&Math.abs(uWord.length-cWord.length)<=2)
    return `💡 Das Wort <b>${uWord}</b> stimmt so nicht – richtig: <b>${cWord}</b>.`;
  return `💡 Ab dem Wort <b>${uWord||'…'}</b> stimmt etwas nicht.`;
}

// Liefert einen Teil-Tipp (erste ~40% der Lösung) als gestaffelte Hilfe.
function buildPartialHint(answer){
  if(!answer)return '';
  const words=(''+answer).trim().replace(/[.!?]+$/,'').split(/\s+/).filter(Boolean);
  if(words.length<3)return words[0]||'';
  const n=Math.max(2,Math.ceil(words.length*0.4));
  return words.slice(0,n).join(' ');
}

function analyzeError(userInput, correctAnswers){
  const u=userInput.toLowerCase().trim();
  const ansList=Array.isArray(correctAnswers)?correctAnswers:[correctAnswers];
  const c=(ansList[0]||'').toLowerCase().trim();
  // Themen-spezifische Patterns (Going to Future) – höhere Priorität
  // Verb mit -ing nach going to (häufiger Fehler "going to playing")
  if(/\bgoing\s+to\s+(\w+ing)\b/.test(u))
    return "💡 Nach <b>going to</b> steht das Verb in der <b>Grundform</b> – nicht mit <i>-ing</i>!";
  // Verb + s nach going to (z.B. "is going to plays")
  if(/\bgoing\s+to\s+(\w+)/.test(u)){
    const m=u.match(/\bgoing\s+to\s+(\w+)/);
    const w=m?m[1]:'';
    if(/s$/.test(w)&&!/^(is|was|has|does|this|his|its)$/.test(w))
      return "💡 Nach <b>going to</b> steht das Verb in der <b>Grundform</b> – kein <i>-s</i>!";
  }
  // form von to be fehlt vor going to ("I going to play")
  if(/\bgoing\s+to\b/.test(c)&&/\bgoing\s+to\b/.test(u)&&!/\b(am|is|are|'m|'s|'re)\b/.test(u))
    return "💡 Vor <b>going to</b> fehlt die Form von to be: <b>am · is · are</b>.";
  // Frage: am/is/are vorne vergessen
  if(/^(am|is|are)\b/.test(c)&&!/^(am|is|are)\b/.test(u)&&!/^(where|when|what|who|how|why)\b/.test(u))
    return "💡 Ja/Nein-Fragen beginnen mit <b>Am/Is/Are</b> + Subjekt + going to + Verb.";
  // W-Frage: am/is/are nach dem W-Wort vergessen
  if(/^(where|when|what|who|how|why)\s+(am|is|are)\b/.test(c)&&/^(where|when|what|who|how|why)\b/.test(u)&&!/\b(am|is|are)\b/.test(u))
    return "💡 W-Frage: W-Wort + <b>am/is/are</b> + Subjekt + going to + Verb (Grundform)?";
  // not fehlt in der Verneinung
  if(/\bnot\b.*\bgoing\s+to\b/.test(c)&&!/\b(not|isn'?t|aren'?t)\b/.test(u))
    return "💡 Verneinung: am/is/are + <b>not</b> + going to + Verb (Grundform)!";
  // Wähle die passendste Antwort aus ansList für Diff
  let best=ansList[0],bestDiff=Infinity;
  for(const a of ansList){
    const an=normalizeAnswer(a),un=normalizeAnswer(userInput);
    const aw=an.split(/\s+/),uw=un.split(/\s+/);
    let d=Math.abs(aw.length-uw.length);
    const m=Math.min(aw.length,uw.length);
    for(let i=0;i<m;i++)if(aw[i]!==uw[i])d++;
    if(d<bestDiff){bestDiff=d;best=a;}
  }
  // Generische Diff-Analyse
  return diffHint(userInput,best);
}

