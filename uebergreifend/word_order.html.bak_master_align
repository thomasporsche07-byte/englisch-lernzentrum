function checkCelebration(container,progressCtrl){
  const inputs=container.querySelectorAll('.task input');
  if(!inputs.length)return;
  const allCorrect=Array.from(inputs).every(i=>i._correct);
  if(!allCorrect)return;
  if(container.querySelector('.celebrate-banner'))return;
  const banner=document.createElement('div');
  banner.className='celebrate-banner';
  banner.innerHTML='🎉 Perfekt! Alle Aufgaben richtig – super gemacht!';
  container.prepend(banner);
  setTimeout(()=>banner.scrollIntoView({behavior:'smooth',block:'nearest'}),80);
  // Häkchen im Akkordeon-Titel setzen
  const acc=container.closest('details.accordion');
  if(acc){
    const key=acc.id.replace('acc-','');
    markSectionComplete(key);
  }
}

// ===== AKKORDEON-HÄKCHEN BEI 15/15 =====
function markSectionComplete(sectionKey){
  // Mapping sectionKey → accordion-id
  const map={svo:'acc-svo',adv:'acc-adv',ort:'acc-ort',be:'acc-be'};
  const accId=map[sectionKey];
  if(!accId)return;
  const summary=document.querySelector(`#${accId} > summary`);
  if(!summary||summary.dataset.completed)return;
  summary.dataset.completed='1';
  const check=document.createElement('span');
  check.textContent=' ✓';
  check.style.cssText='color:#2e7d32;font-weight:900;margin-left:4px;';
  summary.appendChild(check);
}

