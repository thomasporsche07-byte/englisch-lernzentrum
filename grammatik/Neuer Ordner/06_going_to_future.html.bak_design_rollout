  timerEl.style.cssText='font-size:13px;font-weight:700;color:#ffcc00;text-align:center;margin:4px 0 8px;letter-spacing:1px;display:none;';
  timerEl.textContent='⏱ 0:00';
  progressRoot.parentElement.insertAdjacentElement('afterend',timerEl);
  function startTimer(){if(timerInterval)return;timerStart=Date.now()-elapsedSeconds*1000;timerInterval=setInterval(()=>{elapsedSeconds=Math.floor((Date.now()-timerStart)/1000);const m=Math.floor(elapsedSeconds/60);const s=String(elapsedSeconds%60).padStart(2,'0');timerEl.textContent=`⏱ ${m}:${s}`;},1000);timerEl.style.display='block';}
  function stopTimer(){clearInterval(timerInterval);timerInterval=null;}
  function resetTimer(){stopTimer();elapsedSeconds=0;timerStart=null;timerEl.textContent='⏱ 0:00';timerEl.style.display='none';}
  function formatTime(sec){return `${Math.floor(sec/60)}:${String(sec%60).padStart(2,'0')}`;}
  function updateProgress(){progressCtrl.update(correct,correct+wrongCount);}
  const wwmAmounts=['100','200','300','500','1.000','2.000','4.000','8.000','16.000','32.000','64.000','125.000','250.000','500.000','1.000.000'];
  const wwmMilestones=[4,9,14];
  function buildLadder(questionIdx,earnedLvl){
    const ladder=document.createElement('div');ladder.className='wwm-ladder';
    for(let i=total-1;i>=0;i--){
      const row=document.createElement('div');row.className='wwm-ladder-row';
      if(wwmMilestones.includes(i))row.classList.add('milestone');
      if(i<earnedLvl)row.classList.add('done');
      if(i===earnedLvl)row.classList.add('current');
