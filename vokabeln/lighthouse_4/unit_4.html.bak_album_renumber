    +'<div class="wo-pool" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px"><\/div>'
    +'<div style="display:flex;gap:6px"><button class="btn ghost wo-clear" style="font-size:13px;padding:6px 12px">\u21ba Alle zur\u00fcck<\/button><button class="btn ghost wo-skip" style="font-size:13px;padding:6px 12px">\u23ed Überspringen<\/button><\/div>'
    +'<div class="feedback" style="margin-top:8px"><\/div>';
  if(item.playSetup)item.playSetup(card);
  var ansEl=card.querySelector('.wo-ans');var poolEl=card.querySelector('.wo-pool');var fbEl=card.querySelector('.feedback');
  var ph_s=document.createElement('span');ph_s.className='wo-ph';ph_s.style.cssText='color:#94a3b8;font-size:14px;pointer-events:none';ph_s.textContent=ph;ansEl.appendChild(ph_s);
  function updatePH(){ph_s.style.display=ansEl.querySelectorAll('.wo-chip').length>0?'none':'';}
  scrambled.forEach(function(tok){
    var chip=document.createElement('button');chip.className='wo-chip';chip.textContent=tok;
    chip.style.cssText='padding:6px 12px;background:#e2e8f0;border:1.5px solid #cbd5e1;border-radius:8px;cursor:pointer;font-size:15px;font-weight:600;transition:.1s';
    chip.addEventListener('click',function(){
      if(card.classList.contains('done'))return;
      if(poolEl.contains(chip)){poolEl.removeChild(chip);chip.style.background='#dbeafe';chip.style.borderColor='#93c5fd';ansEl.appendChild(chip);}
      else{ansEl.removeChild(chip);chip.style.background='#e2e8f0';chip.style.borderColor='#cbd5e1';poolEl.appendChild(chip);fbEl.textContent='';}
      updatePH();
      if(poolEl.querySelectorAll('.wo-chip').length===0)checkAnswer();
    });
    poolEl.appendChild(chip);
  });
  function checkAnswer(){
    var built=[].slice.call(ansEl.querySelectorAll('.wo-chip')).map(function(c){return c.textContent;});
    var result=isMulti?built.join(' '):built.join('');
    if(normalizeAnswer(result)===normalizeAnswer(answer)){
      [].slice.call(ansEl.querySelectorAll('.wo-chip')).forEach(function(c){c.style.background='#bbf7d0';c.style.borderColor='#86efac';});
      card.style.borderColor='#22c55e';card.classList.add('done','was-correct');
      fbEl.innerHTML='<span class="ok">\u2713 Richtig!<\/span>';correct++;done++;
      if(item.onReveal)item.onReveal(card);
      var tb=makeTtsBtn(answer,'en-GB',false);tb.style.marginTop='6px';fbEl.appendChild(document.createTextNode(' '));fbEl.appendChild(tb);
      onS(correct,done,total);
    }else{
      [].slice.call(ansEl.querySelectorAll('.wo-chip')).forEach(function(c){c.style.background='#fecaca';c.style.borderColor='#fca5a5';});
      fbEl.innerHTML='<span class="bad">\u2717 Nicht richtig \u2013 nochmal versuchen!<\/span>';
      setTimeout(function(){
        if(card.classList.contains('done'))return;
        [].slice.call(ansEl.querySelectorAll('.wo-chip')).forEach(function(c){c.style.background='#e2e8f0';c.style.borderColor='#cbd5e1';poolEl.appendChild(c);});
        updatePH();fbEl.textContent='';
      },900);
    }
  }
  card.querySelector('.wo-clear').addEventListener('click',function(){
    if(card.classList.contains('done'))return;
    [].slice.call(ansEl.querySelectorAll('.wo-chip')).forEach(function(c){c.style.background='#e2e8f0';c.style.borderColor='#cbd5e1';poolEl.appendChild(c);});
    updatePH();fbEl.textContent='';
  });
  card.querySelector('.wo-skip').addEventListener('click',function(){
    if(card.classList.contains('done'))return;
    fbEl.innerHTML='<span class="bad">L\u00f6sung: <b>'+answer+'<\/b><\/span>';card.classList.add('done','was-wrong');done++;
    if(item.onReveal)item.onReveal(card);
    var tb=makeTtsBtn(answer,'en-GB',false);tb.style.marginTop='6px';fbEl.appendChild(document.createTextNode(' '));fbEl.appendChild(tb);
