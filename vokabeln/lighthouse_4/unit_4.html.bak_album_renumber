    const topHtml=item.playHtml||`<div class="scr-de" style="font-size:18px;font-weight:800;text-align:center;margin-bottom:8px">${item.de}</div>`;
    const hintHtml=item.hint?`<div class="scr-hint" style="font-size:13px;color:#475569;text-align:center;margin-bottom:6px;font-style:italic">${highlightKeys(item.hint,item.key)}</div>`:'';
    card.innerHTML=`<div style="font-size:12px;font-weight:700;color:#94a3b8;margin-bottom:6px">Aufgabe ${i+1} / ${total}</div>${topHtml}${hintHtml}<div class="scr-built" style="display:flex;flex-wrap:wrap;gap:6px 14px;min-height:36px;margin:10px 0;padding:8px;background:#fff7ed;border-radius:10px;border:1.5px solid #fed7aa;align-items:center;justify-content:center"></div><div class="scr-letters" style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px"></div><div style="display:flex;gap:6px"><button class="btn ghost scr-undo" style="font-size:13px;padding:6px 12px">↩ Zurück</button><button class="btn ghost scr-skip" style="font-size:13px;padding:6px 12px">⏭ Überspringen</button></div><div class="feedback" style="margin-top:8px"></div>`;
    if(item.playSetup)item.playSetup(card);
    const builtEl=card.querySelector('.scr-built');const lettersEl=card.querySelector('.scr-letters');const fbEl=card.querySelector('.feedback');
    const btnEls=[];
    sh.forEach((ch,j)=>{const b=document.createElement('button');b.className='scr-letter';b.textContent=ch;b.dataset.idx=j;
      b.addEventListener('click',()=>{if(b.classList.contains('used')||card.classList.contains('done'))return;b.classList.add('used');built.push({ch,idx:j});renderB();if(built.length===letters.length)checkW();});
      lettersEl.appendChild(b);btnEls.push(b);});
    function renderB(){builtEl.innerHTML='';if(built.length===0){builtEl.innerHTML='<span style="color:#94a3b8;font-size:14px">Buchstaben klicken …</span>';return;}let li=0;let wg=document.createElement('span');wg.className='scr-word-group';for(let pos=0;pos<chars.length;pos++){if(spacePos.has(pos)){if(wg.childNodes.length>0)builtEl.appendChild(wg);wg=document.createElement('span');wg.className='scr-word-group';}else{if(li<built.length){const s=document.createElement('span');s.className='scr-char';s.textContent=built[li].ch;wg.appendChild(s);}li++;}}if(wg.childNodes.length>0)builtEl.appendChild(wg);}
    renderB();
    function checkW(){let res='';let li=0;for(let pos=0;pos<chars.length;pos++){if(spacePos.has(pos))res+=' ';else{res+=built[li].ch;li++;}}
      if(normalizeAnswer(res)===normalizeAnswer(answer)){fbEl.innerHTML='<span class="ok">✓ Richtig!</span>';card.classList.add('done','was-correct');correct++;done++;if(item.onReveal)item.onReveal(card);const tb=makeTtsBtn(answer,'en-GB',false);tb.style.marginTop='6px';fbEl.appendChild(document.createTextNode(' '));fbEl.appendChild(tb);}
      else{fbEl.innerHTML='<span class="bad">✗ Lösung: <b>'+answer+'</b></span>';card.classList.add('done','was-wrong');done++;if(item.onReveal)item.onReveal(card);const tb=makeTtsBtn(answer,'en-GB',false);tb.style.marginTop='6px';fbEl.appendChild(document.createTextNode(' '));fbEl.appendChild(tb);}
      onS(correct,done,total);}
    card.querySelector('.scr-undo').addEventListener('click',()=>{if(card.classList.contains('done')||built.length===0)return;const last=built.pop();btnEls[last.idx].classList.remove('used');renderB();fbEl.textContent='';});
    card.querySelector('.scr-skip').addEventListener('click',()=>{if(card.classList.contains('done'))return;fbEl.innerHTML='<span class="bad">Lösung: <b>'+answer+'</b></span>';card.classList.add('done','was-wrong');done++;if(item.onReveal)item.onReveal(card);const tb=makeTtsBtn(answer,'en-GB',false);tb.style.marginTop='6px';fbEl.appendChild(document.createTextNode(' '));fbEl.appendChild(tb);onS(correct,done,total);});
