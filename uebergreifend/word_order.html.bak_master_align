      .some(id=>{const el=document.getElementById(id);return el&&el.open;});
    fab.style.display=(!rulesVisible&&anyOpen)?'block':'none';
  }
  const obs=new IntersectionObserver(([e])=>{rulesVisible=e.isIntersecting;updateFabVisibility();},{threshold:0});
  obs.observe(rules);
  ['acc-svo','acc-adv','acc-ort','acc-be'].forEach(id=>{
    const el=document.getElementById(id);if(el)el.addEventListener('toggle',updateFabVisibility);
  });

  // Mapping: Akkordeon-ID → Kartenindizes (0-basiert) + Titel
  const ACC_MAP={
    'acc-svo': {indices:[0],    title:'Regel: S-V-O (Aussagesatz)'},
    'acc-adv': {indices:[1],    title:'Regel: Häufigkeitsadverbien'},
    'acc-ort': {indices:[2],    title:'Regel: Ort vor Zeit'},
    'acc-be':  {indices:[3],    title:'Regel: Sätze mit be'},
