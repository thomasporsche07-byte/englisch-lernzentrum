        if(ok){
          result.innerHTML = '<span class="ok">✓ Sehr gut! ('+alts[0]+')</span>';
          lt_record(item.en, true);
          setTimeout(()=>{idx++;next();}, 1300);
        } else {
          result.innerHTML = '<span class="bad">✗ Verstanden: <i>"'+alts[0]+'"</i><br>Gemeint: <b>'+target+'</b></span>';
          lt_record(item.en, false);
          mic.textContent = '🎤 Nochmal versuchen'; mic.disabled = false;
        }
      };
      rec.onerror = ev=>{
        result.innerHTML = '<span class="bad">✗ Fehler: '+ev.error+(ev.error==='not-allowed'?' (Mikrofon-Zugriff verweigert)':'')+'</span>';
        mic.textContent = '🎤 Aufnahme starten'; mic.disabled = false;
      };
      rec.onend = ()=>{ if(mic.disabled){ mic.textContent='🎤 Nochmal versuchen'; mic.disabled=false; } };
      try{ rec.start(); }catch(e){ result.textContent='Fehler beim Start: '+e.message; mic.disabled=false; mic.textContent='🎤 Aufnahme starten'; }
    });
  }
  document.getElementById('speech-topics').addEventListener('click', e=>{
    const b = e.target.closest('button[data-topic]'); if(!b) return;
    document.getElementById('speech-topics').querySelectorAll('button').forEach(x=>x.classList.remove('active'));
    b.classList.add('active'); cur = b.dataset.topic; render();
  });
  acc.addEventListener('toggle', function(){ if(this.open && !cardEl.innerHTML.trim()) render(); });
}

