  document.getElementById('si-wave').textContent=`S04 – BVB ${score}:${missed}`;
  document.getElementById('si-score').textContent=`👾 ${score+missed} / ${tasks.length}`;
  if(lives<=0){endGameSI(false);return;}
  if(activeOnScreen()<lvl.maxOnScreen&&cur<tasks.length) spawnOne();
  setTimeout(()=>{
    if(gameOver)return;
    const next=getLowestAlien();
    if(next)showChoicesForLowest();
    else if(cur>=tasks.length)endGameSI(true);
  },400);
}

function handleChoiceSI(ch,alien,btn){
  if(alien.done||gameOver)return;
  const ok=normalizeAnswer(ch)===normalizeAnswer(alien.task.answer);
  if(ok){
    shipEl.style.left=alien.x+'%';
    btn.classList.add('correct');
    choicesEl.querySelectorAll('.si-choice').forEach(b=>b.classList.add('used'));
    fireLaserSI(alien,()=>{
      alien.done=true;
      alien.el.classList.add('hit');
      score++;
      document.getElementById('si-score').textContent=`👾 ${score+missed} / ${tasks.length}`;
      document.getElementById('si-wave').textContent=`S04 – BVB ${score}:${missed}`;
      if(activeOnScreen()<lvl.maxOnScreen&&cur<tasks.length) spawnOne();
      setTimeout(()=>{
        if(gameOver)return;
        const next=getLowestAlien();
        if(next){showChoicesForLowest();}
        else if(cur>=tasks.length){endGameSI(true);}
      },300);
    });
  }else{
    btn.classList.add('wrong');
    btn.classList.add('used');
    alien.mistakes++;
    alien.lastWrong=ch;
    alien.y+=PENALTY_DROP;
    alien.speed+=PENALTY_SPEED;
    alien.el.style.top=alien.y+'px';
    alien.el.classList.add('si-punished');
    setTimeout(()=>{if(alien.el)alien.el.classList.remove('si-punished');},400);
    if(alien.mistakes>=MAX_MISTAKES){
      setTimeout(()=>failAlien(alien),500);
    }
  }
}

function tick(){
