ctrl.appendChild(cb);w.appendChild(inp);w.appendChild(ctrl);w.appendChild(fb);w.appendChild(enTtsWrap);ct.appendChild(w);const ans=Array.isArray(t.answer)?t.answer:[t.answer];let fc=0;
function fill(txt){const sl=p.querySelector('.gap-slot');if(sl)sl.outerHTML='<span class="gap-filled">'+txt+'</span>';}
