    const d1=shuffle(pool.filter(q=>q.d===1));
    const d2=shuffle(pool.filter(q=>q.d===2));
    const d3=shuffle(pool.filter(q=>q.d===3));
    const n1=Math.min(4,d1.length);
    const n3=Math.min(6,d3.length);
    const n2=Math.min(total-n1-n3,d2.length);
    return [...d1.slice(0,n1),...d2.slice(0,n2),...d3.slice(0,n3)];
  }
  let tasks=pickByDifficulty(quizPool,15);
  const total=tasks.length;
  const wrap=document.getElementById('quiz-tasks');
  const progressRoot=document.querySelector('#quiz-progress .progress');
  const progressCtrl=initProgressBar(progressRoot,total);
  const resultBox=document.getElementById('quiz-result');
  let current=0,correct=0,wrongCount=0,wrongTasks=[],streak=0,earnedLevel=0,securedFloor=0;
  let timerStart=null,timerInterval=null,elapsedSeconds=0;
  const timerEl=document.createElement('div');
  timerEl.style.cssText='font-size:13px;font-weight:700;color:#ffcc00;text-align:center;margin:4px 0 8px;letter-spacing:1px;display:none;';
  timerEl.textContent='⏱ 0:00';
  progressRoot.parentElement.insertAdjacentElement('afterend',timerEl);
  function startTimer(){if(timerInterval)return;timerStart=Date.now()-elapsedSeconds*1000;timerInterval=setInterval(()=>{elapsedSeconds=Math.floor((Date.now()-timerStart)/1000);const m=Math.floor(elapsedSeconds/60);const s=String(elapsedSeconds%60).padStart(2,'0');timerEl.textContent=`⏱ ${m}:${s}`;},1000);timerEl.style.display='block';}
  function stopTimer(){clearInterval(timerInterval);timerInterval=null;}
  function resetTimer(){stopTimer();elapsedSeconds=0;timerStart=null;timerEl.textContent='⏱ 0:00';timerEl.style.display='none';}
  function formatTime(sec){return `${Math.floor(sec/60)}:${String(sec%60).padStart(2,'0')}`;}
  function updateProgress(){progressCtrl.update(correct,correct+wrongCount);}
  const wwmAmounts=['100','200','300','500','1.000','2.000','4.000','8.000','16.000','32.000','64.000','125.000','250.000','500.000','1.000.000'];
  const wwmMilestones=[4,9,14];
  function buildLadder(questionIdx,earnedLvl){
    const ladder=document.createElement('div');ladder.className='wwm-ladder';
    for(let i=total-1;i>=0;i--){
      const row=document.createElement('div');row.className='wwm-ladder-row';
      if(wwmMilestones.includes(i))row.classList.add('milestone');
      if(i<earnedLvl)row.classList.add('done');
      if(i===earnedLvl)row.classList.add('current');
      const qnum=document.createElement('span');qnum.className='wwm-qnum';qnum.textContent=i+1;
      const amt=document.createElement('span');amt.className='wwm-amount';
      amt.textContent=(i===earnedLvl?'▶ ':'')+wwmAmounts[i];
      row.appendChild(qnum);row.appendChild(amt);
      ladder.appendChild(row);
    }
    return ladder;
  }
  const jokerUsed={fifty:false,phone:false,audience:false};
  let currentBtns=[];

  function applyJoker(key,task,correctIdx,btns,stage){
    stage.querySelectorAll('.wwm-phone-bubble,.wwm-audience-box').forEach(el=>el.remove());
    const letters=['A','B','C','D'];
    if(key==='fifty'){
      const wrongIdxs=[0,1,2,3].filter(i=>i!==correctIdx);
      for(let i=wrongIdxs.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[wrongIdxs[i],wrongIdxs[j]]=[wrongIdxs[j],wrongIdxs[i]];}
      wrongIdxs.slice(0,2).forEach(i=>{
        btns[i].style.opacity='0.15';
        btns[i].style.pointerEvents='none';
        btns[i].disabled=true;
      });
    }else if(key==='phone'){
      const isWrong=Math.random()<0.30;
      let answerIdx,confidence;
      if(isWrong){
        const wi=[0,1,2,3].filter(i=>i!==correctIdx);
        answerIdx=wi[Math.floor(Math.random()*wi.length)];
        confidence='Ich bin nicht ganz sicher, aber ich glaube …';
      }else{
        answerIdx=correctIdx;
        confidence='Da bin ich mir ziemlich sicher:';
      }
      const box=document.createElement('div');box.className='wwm-phone-bubble';
      box.innerHTML=`<span class="wwm-phone-icon">📞</span><div class="wwm-phone-text"><b>Dein Freund sagt:</b><br>${confidence}<br><em style="display:block;margin-top:6px;">${letters[answerIdx]}: ${task.options[answerIdx]}</em></div>`;
      stage.appendChild(box);
    }else if(key==='audience'){
      const isWrong=Math.random()<0.30;
      const pcts=[0,0,0,0];
      if(isWrong){
        const wi=[0,1,2,3].filter(i=>i!==correctIdx);
        const winner=wi[Math.floor(Math.random()*wi.length)];
        pcts[winner]=Math.floor(Math.random()*15)+45;
        pcts[correctIdx]=Math.floor(Math.random()*15)+10;
        const rest=[0,1,2,3].filter(i=>i!==winner&&i!==correctIdx);
        const r=100-pcts[winner]-pcts[correctIdx];
        pcts[rest[0]]=Math.floor(r*0.55);
        pcts[rest[1]]=r-pcts[rest[0]];
      }else{
        pcts[correctIdx]=Math.floor(Math.random()*25)+50;
        const wi=[0,1,2,3].filter(i=>i!==correctIdx);
        const r=100-pcts[correctIdx];
        pcts[wi[0]]=Math.floor(r*0.45);
        pcts[wi[1]]=Math.floor(r*0.30);
        pcts[wi[2]]=r-pcts[wi[0]]-pcts[wi[1]];
      }
      const barColors=['#d4922e','#e53935','#43a047','#f9a825'];
      const barsHTML=pcts.map((p,i)=>`<div class="wwm-audience-col" style="cursor:pointer" data-idx="${i}"><div class="wwm-audience-pct">${p}%</div><div class="wwm-audience-bar" style="height:${Math.max(p,4)}%;background:${barColors[i]};border-radius:4px 4px 0 0;"></div><div class="wwm-audience-label">${letters[i]}</div></div>`).join('');
      const box=document.createElement('div');box.className='wwm-audience-box';
      box.innerHTML=`<div class="wwm-audience-title">📊 Publikumsjoker</div><div class="wwm-audience-bars" style="align-items:flex-end;height:110px;">${barsHTML}</div>`;
      stage.appendChild(box);
      box.querySelectorAll('[data-idx]').forEach(col=>{
        col.addEventListener('click',()=>{
          const idx=parseInt(col.dataset.idx);
          if(btns[idx]&&!btns[idx].disabled)btns[idx].click();
        });
      });
    }
  }

  function renderQuestion(){
    if(current>=total){showFinal();return;}
    startTimer();
    wrap.innerHTML='';
    const t=tasks[current];
    const opts=t.options;
    const correctIdx=t.correct;
    currentBtns=[];
    const fw=document.createElement('div');fw.className='quiz-question-enter';
    const streakEl=document.createElement('div');streakEl.className='quiz-streak';
    if(streak>=3)streakEl.textContent=`🔥 ${streak}er-Serie!`;
    fw.appendChild(streakEl);
    // Jokers: Publikum | Telefonjoker | 50:50
    const lifelines=document.createElement('div');lifelines.className='wwm-lifelines';
    [{key:'audience',label:'👥 Publikum'},{key:'phone',label:'📞 Joker'},{key:'fifty',label:'50:50'}].forEach(j=>{
      const used=jokerUsed[j.key];
      const chip=document.createElement('button');chip.className='chip'+(used?' chip-used':'');
      chip.textContent=j.label;chip.disabled=used;
      chip.addEventListener('click',()=>{
        if(jokerUsed[j.key])return;
        jokerUsed[j.key]=true;chip.classList.add('chip-used');chip.disabled=true;
        applyJoker(j.key,t,correctIdx,currentBtns,stage);
      });
      lifelines.appendChild(chip);
    });
    fw.appendChild(lifelines);
    const layout=document.createElement('div');layout.className='wwm-layout';
    const stage=document.createElement('div');stage.className='wwm-stage';
    const prompt=document.createElement('div');prompt.className='prompt';prompt.innerHTML=t.prompt;
    stage.appendChild(prompt);
    const optWrap=document.createElement('div');optWrap.className='wwm-joker-options';
    const letters=['A','B','C','D'];
    let answered=false;
    opts.forEach((optText,i)=>{
      const btn=document.createElement('button');btn.className='wwm-option-btn';btn.type='button';
      btn.innerHTML=`<span class="wwm-opt-letter">${letters[i]}</span>${optText}`;
      btn.addEventListener('click',()=>{
        if(answered)return;
        answered=true;
        currentBtns.forEach(b=>b.disabled=true);
        // Color buttons
        currentBtns.forEach((b,bi)=>{
          const letter=b.querySelector('.wwm-opt-letter');
          if(bi===correctIdx){b.style.cssText+=';background:linear-gradient(90deg,#1b5e20,#2e7d32);border-color:#4caf50;';if(letter)letter.style.cssText='background:rgba(76,175,80,.3);border-color:#4caf50;color:#b9f6ca;';}
          else if(bi===i&&i!==correctIdx){b.style.cssText+=';background:linear-gradient(90deg,#7f0000,#b71c1c);border-color:#ef5350;';if(letter)letter.style.cssText='background:rgba(239,83,80,.3);border-color:#ef5350;color:#ffcdd2;';}
        });
        const isCorrect=i===correctIdx;
        if(isCorrect){
          fb.textContent='✓ Richtig!';fb.className='feedback ok';
          correct++;streak++;earnedLevel++;
          if(wwmMilestones.includes(earnedLevel-1))securedFloor=earnedLevel-1;
          if(t.explanation){eb.innerHTML=t.explanation;eb.style.display='block';}
          const nb=document.createElement('button');nb.className='btn green';nb.dataset.next='1';nb.textContent='Weiter →';
          nb.addEventListener('click',()=>{updateProgress();current++;renderQuestion();});
          ctrl.appendChild(nb);setTimeout(()=>nb.focus(),50);
        }else{
          fb.innerHTML=`✗ Falsch! Richtige Antwort: <b>${letters[correctIdx]}: ${opts[correctIdx]}</b>`;fb.className='feedback bad';
          wrongTasks.push({...t,_questionNumber:current+1,_userInput:`${letters[i]}: ${opts[i]}`});
          wrongCount++;streak=0;
          const floor=wwmMilestones.filter(m=>m<=earnedLevel).pop();earnedLevel=floor!==undefined?floor:0;
          if(t.explanation){eb.innerHTML=t.explanation.replace('✅','💡');eb.style.display='block';}
          if(t.tip){tb.innerHTML=`💡 <b>Tipp:</b> ${t.tip}`;tb.style.display='block';}
          const nb=document.createElement('button');nb.className='btn gray';nb.dataset.next='1';nb.textContent='Ergebnis ansehen →';
          nb.addEventListener('click',()=>{updateProgress();showFinal();});
          ctrl.appendChild(nb);setTimeout(()=>nb.focus(),50);
        }
      });
      optWrap.appendChild(btn);
      currentBtns.push(btn);
    });
    stage.appendChild(optWrap);
    const fb=document.createElement('div');fb.className='feedback';stage.appendChild(fb);
    const tb=document.createElement('div');tb.className='quiz-tip-box';tb.style.display='none';stage.appendChild(tb);
    const eb=document.createElement('div');eb.className='quiz-explanation-box';eb.style.display='none';stage.appendChild(eb);
    const ctrl=document.createElement('div');ctrl.className='controls';ctrl.style.cssText='margin-top:22px;padding-top:18px;border-top:1px solid rgba(255,204,0,.15);';stage.appendChild(ctrl);
    layout.appendChild(stage);layout.appendChild(buildLadder(current,earnedLevel));
    fw.appendChild(layout);wrap.appendChild(fw);
  }

  function showFinal(){
    stopTimer();wrap.innerHTML='';
    const pct=Math.round((correct/total)*100);const ts=formatTime(elapsedSeconds);
    const prize=earnedLevel>0?wwmAmounts[earnedLevel-1]+' €':'0 €';
    let emoji='',headline='',msg='';
    if(pct===100){emoji='🏆';headline='EINE MILLION! 🎉';msg='PERFEKT! Alle 15 Fragen richtig – das simple present hat keine Chance gegen dich!';}
    else if(pct>=90){emoji='🤩';headline='Fast perfekt – Respekt!';msg='Wow, kaum ein Fehler! Das simple present und du seid ein eingespieltes Team.';}
    else if(pct>=80){emoji='🌟';headline='Richtig stark, weiter so!';msg='Starke Leistung! do, does und die s-Regel sitzen schon sehr gut.';}
    else if(pct>=70){emoji='😎';headline='Solide – du weißt, was du tust!';msg='Mehr als zwei Drittel richtig – das ist kein Glück, das ist Können!';}
    else if(pct>=60){emoji='🙌';headline='Auf dem richtigen Weg!';msg='Über die Hälfte richtig – noch etwas üben und du nagelst es!';}
    else if(pct>=50){emoji='💡';headline='Halbzeit – Luft nach oben!';msg='Die Hälfte sitzt schon! Schau nochmal in die Regeln zu does und der s-Regel.';}
    else if(pct>=30){emoji='🐣';headline='Der Anfang ist gemacht!';msg='Noch ist nicht alles verloren – du weißt jetzt, wo du ansetzen musst.';}
    else{emoji='😅';headline='Ups – aber kein Problem!';msg='Schau nochmal in die Regeln zu do/does und der s-Regel, dann klappt\'s garantiert besser.';}
    let errorHTML='';
    if(wrongTasks.length>0){
      errorHTML=`<div style="margin-top:22px;text-align:left;"><div style="font-size:16px;font-weight:900;color:#ffcc00;margin-bottom:10px;text-align:center;">📋 Deine Fehler – schau sie dir nochmal an:</div><div style="display:flex;flex-direction:column;gap:8px;">${wrongTasks.map(wt=>`<div style="background:rgba(255,255,255,.07);border:1px solid rgba(255,110,110,.45);border-radius:10px;padding:10px 14px;"><div style="font-size:12px;color:#ffb3b3;font-weight:700;margin-bottom:3px;">Frage ${wt._questionNumber}</div><div style="font-size:14px;color:#e8d0aa;margin-bottom:4px;">${wt.prompt}</div><div style="font-size:14px;color:#ff6b6b;font-style:italic;margin-bottom:4px;">✗ ${wt._userInput||'–'}</div><div style="font-size:14px;color:#7fffb3;font-weight:700;">✓ ${['A','B','C','D'][wt.correct]}: ${wt.options[wt.correct]}</div>${wt.explanation?`<div style="font-size:13px;color:#c7d2fe;margin-top:5px;">${wt.explanation}</div>`:''}</div>`).join('')}</div></div>`;
    }
    resultBox.innerHTML=`<div style="position:relative;overflow:hidden;"><div style="height:8px;background:repeating-linear-gradient(90deg,#ffcc00 0 14%,#d4922e 14% 28%,#e53935 28% 42%,#43a047 42% 56%,#ffcc00 56% 70%,#ab47bc 70% 84%,#d4922e 84% 100%);"></div><div style="padding:28px 20px 24px;text-align:center;"><div style="font-size:72px;line-height:1;margin-bottom:10px;filter:drop-shadow(0 4px 12px rgba(255,204,0,.6));">${emoji}</div><div style="font-size:clamp(26px,6vw,38px);font-weight:900;color:#ffcc00;letter-spacing:.5px;margin-bottom:6px;">${headline}</div><div style="display:inline-block;background:rgba(255,204,0,.15);border:2px solid #ffcc00;border-radius:16px;padding:14px 32px;margin:12px 0 18px;"><div style="font-size:clamp(36px,8vw,52px);font-weight:900;color:#fff;line-height:1;">${correct} <span style="font-size:.55em;color:#ffcc00;">/ ${total}</span></div><div style="font-size:16px;font-weight:700;color:#ffcc00;letter-spacing:1px;margin-top:2px;">${pct} % RICHTIG</div><div style="font-size:13px;color:rgba(255,204,0,.8);margin-top:6px;">⏱ Zeit: ${ts}</div><div style="font-size:18px;font-weight:900;color:#ffcc00;letter-spacing:.5px;margin-top:8px;">🏅 Gewonnen: ${prize}</div></div><div style="font-size:clamp(14px,3vw,17px);color:#fff;max-width:500px;margin:0 auto;line-height:1.7;background:rgba(255,255,255,.08);border-radius:14px;padding:14px 18px;border:1px solid rgba(255,255,255,.2);">${msg}</div>${errorHTML}</div><div style="height:8px;background:repeating-linear-gradient(90deg,#43a047 0 14%,#ffcc00 14% 28%,#ab47bc 28% 42%,#e53935 42% 56%,#d4922e 56% 70%,#ffcc00 70% 84%,#43a047 84% 100%);"></div></div>`;
    resultBox.style.display='block';setTimeout(()=>resultBox.scrollIntoView({behavior:'smooth',block:'nearest'}),80);
  }

  document.getElementById('quiz-reset').addEventListener('click',()=>{
    tasks=pickByDifficulty(quizPool,15);current=0;correct=0;wrongCount=0;wrongTasks=[];streak=0;earnedLevel=0;securedFloor=0;
    jokerUsed.fifty=false;jokerUsed.phone=false;jokerUsed.audience=false;
    updateProgress();resetTimer();
    progressRoot.querySelector('.progress-fill').style.width='0%';
    document.querySelector('#quiz-progress .progress-text').textContent=`Fortschritt: 0/${total} richtig (0%)`;
    resultBox.style.display='none';resultBox.innerHTML='';
    renderQuestion();
  });
  updateProgress();
  let quizRendered=false;
  const qa=document.getElementById('wwm-quiz');
  if(qa)qa.addEventListener('toggle',()=>{
    if(!qa.open){stopTimer();}
    else{if(!quizRendered){quizRendered=true;renderQuestion();}else if(current<total&&timerStart!==null){startTimer();}}
  });
})();}catch(e){console.error('Quiz init:',e);}

