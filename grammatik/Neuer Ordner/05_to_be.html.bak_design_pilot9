(function initResetAll(){
  const btn=document.getElementById('reset-all-btn');
  if(!btn)return;
  btn.addEventListener('click',()=>{
    if(!confirm('Wirklich den GESAMTEN Fortschritt zurücksetzen?\n\nAlle gelösten Aufgaben, geöffneten Akkordeons und Quiz-Stände gehen verloren.'))return;
    try{
      const keys=[];
      for(let i=0;i<localStorage.length;i++){
        const k=localStorage.key(i);
        if(k&&k.indexOf('tobe_')===0)keys.push(k);
      }
      keys.forEach(k=>localStorage.removeItem(k));
    }catch(e){console.warn('Reset:',e);}
    location.reload();
  });
})();

