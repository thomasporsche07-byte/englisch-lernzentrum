var KI_URL='https://gemini-direct.thomasporsche07.workers.dev/';
// ↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑
var kiHistory=[];
var kiSystemPrompt='Du bist ein Englisch-Tutor für deutsche Realschüler der Klasse 7.\n\nDEINE AUFGABE:\n- Du hilfst ausschließlich beim Thema "If-Sätze Typ 1" (Bedingungssätze Typ 1, Conditional Sentences Type 1).\n- Du erklärst Grammatikregeln auf Deutsch, einfach und klar.\n- Du kannst Fehler in Schülersätzen erkennen und erklären, was falsch ist – aber du gibst NICHT die fertige Lösung.\n- Du stellst Gegenfragen, um den Schüler zum Nachdenken zu bringen.\n\nREGELN:\n1. Antworte IMMER auf Deutsch (außer für englische Beispielsätze).\n2. Antworte KURZ: maximal 4 Sätze.\n3. Wenn ein Schüler eine fertige Lösung will: Verweigere freundlich und gib einen Hinweis.\n4. Wenn ein Schüler über etwas anderes als If-Sätze Typ 1 fragt: Lenke freundlich zurück.\n5. Sei ermutigend und geduldig.\n\nTHEMEN: Aufbau (if + Simple Present, Hauptsatz + will + Grundform), Verwendung (reale Bedingung in der Zukunft), Verneinung (don\'t/doesn\'t im if-Satz, won\'t im Hauptsatz), Reihenfolge (if vorne ODER hinten – bei vorne mit Komma, bei hinten ohne), häufiger Fehler (KEIN will im if-Satz!), Fragen (Will + Subj. + Grundform + if-Teil; W-Fragen mit will), Short Answers (Yes, … will. / No, … won\'t.).';

function kiClear(){
  kiHistory=[];
  var c=document.getElementById('ki-messages');
  if(c)c.innerHTML='';
  var errEl=document.getElementById('ki-err');
  if(errEl)errEl.style.display='none';
  var clearBtn=document.getElementById('ki-clear-btn');
  if(clearBtn)clearBtn.disabled=true;
  var inputEl=document.getElementById('ki-input');
  if(inputEl)inputEl.focus();
}

function kiXHR(payload){
  payload.generationConfig=Object.assign({maxOutputTokens:400},payload.generationConfig||{});
  return fetch(KI_URL,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(payload)
  }).then(function(r){
    if(!r.ok)return r.json().then(function(e){throw new Error((e.error&&e.error.message)||'HTTP '+r.status);}).catch(function(){throw new Error('HTTP '+r.status);});
    return r.json();
  }).then(function(data){
    var text=(data.candidates&&data.candidates[0]&&data.candidates[0].content&&data.candidates[0].content.parts&&data.candidates[0].content.parts[0]&&data.candidates[0].content.parts[0].text)||'';
    return text.trim();
  });
}

function kiAppendMsg(role,text){
  var c=document.getElementById('ki-messages');
  var d=document.createElement('div');d.className='ki-msg '+role;
  var av=document.createElement('div');av.className='ki-avatar';av.textContent=role==='user'?'Du':'🤖';
  var bu=document.createElement('div');bu.className='ki-bubble';
  bu.innerHTML=text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>');
  d.appendChild(av);d.appendChild(bu);c.appendChild(d);
  d.scrollIntoView({behavior:'smooth',block:'nearest'});
  return d;
}

function kiAppendTyping(){
  var c=document.getElementById('ki-messages');
  var d=document.createElement('div');d.className='ki-msg ai';d.id='ki-typing';
  d.innerHTML='<div class="ki-avatar">🤖</div><div class="ki-bubble"><div class="ki-typing"><span></span><span></span><span></span></div></div>';
  c.appendChild(d);d.scrollIntoView({behavior:'smooth',block:'nearest'});return d;
}

async function kiSend(quickText){
  var inputEl=document.getElementById('ki-input');
  var sendBtn=document.getElementById('ki-send-btn');
  var clearBtn=document.getElementById('ki-clear-btn');
  var errEl=document.getElementById('ki-err');
  var text=quickText||(inputEl?inputEl.value.trim():'');
  if(!text)return;
  if(inputEl)inputEl.value='';
  errEl.style.display='none';
  sendBtn.disabled=true;
  kiAppendMsg('user',text);
  var typing=kiAppendTyping();
  try{
    var contents=[];
    contents.push({role:'user',parts:[{text:kiSystemPrompt}]});
    contents.push({role:'model',parts:[{text:'Verstanden! Ich helfe dir bei If-Sätzen Typ 1.'}]});
    for(var i=0;i<kiHistory.length;i++){contents.push(kiHistory[i]);}
    contents.push({role:'user',parts:[{text:text}]});
    var reply=await kiXHR({contents:contents,generationConfig:{temperature:0.7,maxOutputTokens:300,thinkingConfig:{thinkingBudget:0}}});
    kiHistory.push({role:'user',parts:[{text:text}]});
    kiHistory.push({role:'model',parts:[{text:reply}]});
    if(kiHistory.length>20)kiHistory=kiHistory.slice(kiHistory.length-20);
    if(typing&&typing.parentNode)typing.parentNode.removeChild(typing);
    kiAppendMsg('ai',reply);
    if(clearBtn)clearBtn.disabled=false;
  }catch(e){
    if(typing&&typing.parentNode)typing.parentNode.removeChild(typing);
    errEl.textContent='⚠️ Fehler: '+e.message;
    errEl.style.display='block';
  }
  sendBtn.disabled=false;
  if(inputEl)inputEl.focus();
}


