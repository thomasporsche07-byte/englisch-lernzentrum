<script>
// ===== LOCALSTORAGE =====
const LS_KEY='zap_tenses_v1';
try{['zap_tenses_v0','simplepast_progress_v1'].forEach(k=>{if(localStorage.getItem(k))localStorage.removeItem(k);});}catch(e){}
const _STORE = {};
function saveProgress(key, val){ try{_STORE[key]=val;}catch(e){} return true; }
function loadProgress(key, def=null){ return _STORE[key]!==undefined?_STORE[key]:def; }

// ===== PROGRESS BAR =====
function initProgressBar(root,total){
  let _total=total||15;
  const fill=root?root.querySelector('.progress-fill'):null;
  const textEl=root?root.parentElement.querySelector('.progress-text'):null;
  const summaryEl=root?root.closest('details'):null;
  const titleEl=summaryEl?summaryEl.querySelector('summary'):null;
  return{
    setTotal(t){_total=t;},
    update(correct,done){
      const pct=_total>0?Math.round(correct/_total*100):0;
      if(fill)fill.style.width=pct+'%';
      if(textEl)textEl.textContent='Fortschritt: '+correct+'/'+_total+' richtig ('+pct+'%)';
      if(titleEl){
        const base=titleEl.dataset.titleBase||(titleEl.dataset.titleBase=titleEl.textContent.replace(' \u2713','').trim());
        if(correct===_total&&_total>0){titleEl.textContent=base+' \u2713';}
        else{titleEl.textContent=base;}
      }
    },
    resetAnimated(){
      if(fill){fill.style.transition='none';fill.style.width='0%';setTimeout(()=>fill.style.transition='',50);}
      if(textEl)textEl.textContent='Fortschritt: 0/'+_total+' richtig (0%)';
      if(titleEl&&titleEl.dataset.titleBase)titleEl.textContent=titleEl.dataset.titleBase;
    }
  };
}

// ===== UTILITIES =====
function shuffle(a){const b=[...a];for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];}return b;}
function pickRandom(arr,n,persistKey){
  const saved=loadProgress('pick_'+persistKey,null);
  if(saved&&Array.isArray(saved)&&saved.length===n){
    const items=saved.map(i=>arr[i]).filter(Boolean);
    if(items.length===n)return items;
  }
  const indices=shuffle([...Array(arr.length).keys()]).slice(0,Math.min(n,arr.length));
  saveProgress('pick_'+persistKey,indices);
  return indices.map(i=>arr[i]);
}
function taskHash(t){
  try{return JSON.stringify(t).split('').reduce((a,c)=>(((a<<5)-a)+c.charCodeAt(0))|0,0).toString(36);}catch(e){return Math.random().toString(36);}
}
function formatTime(s){const m=Math.floor(s/60);return m+':'+(String(s%60).padStart(2,'0'));}

// ===== NORMALIZE ANSWER =====
function normalizeAnswer(s){
  if(!s)return '';
  return s.trim().toLowerCase()
    .replace(/\u2019/g,"'").replace(/\u2018/g,"'").replace(/\u201c/g,'"').replace(/\u201d/g,'"')
    .replace(/hadn\u2019t/g,"hadn't").replace(/hadn't/g,"hadn't")
    .replace(/\s+/g,' ').replace(/[.!?]+$/,'').trim();
}

// ===== DIFF HINT =====
function diffHint(userInput,correctAnswer){
  const uN=normalizeAnswer(userInput),cN=normalizeAnswer(correctAnswer);
  if(!uN||!cN||uN===cN)return null;
  const uW=uN.split(/\s+/).filter(Boolean),cW=cN.split(/\s+/).filter(Boolean);
  let i=0;const max=Math.max(uW.length,cW.length);
  while(i<max&&uW[i]===cW[i])i++;
  if(i>=max)return null;
  const uWord=uW[i]||'',cWord=cW[i]||'';
  if(!uWord&&cWord){
    if(/^(did|didn't|was|were|wasn't|weren't)$/.test(cWord))return '\u{1f4a1} Es fehlt die Form <b>'+cWord+'</b>.';
    return '\u{1f4a1} An Stelle '+(i+1)+' fehlt noch ein Wort.';
  }
  if(uWord&&!cWord)return '\u{1f4a1} Das Wort <b>'+uWord+'</b> am Ende geh\u00f6rt nicht dazu.';
  const pairs={"didn't":'did not','did not':"didn't","wasn't":'was not','was not':"wasn't","weren't":'were not','were not':"weren't",'does':'did','do':'did',"don't":"didn't","doesn't":"didn't"};
  if(pairs[uWord]===cWord)return '\u{1f4a1} Hier brauchst du <b>'+cWord+'</b>, nicht <i>'+uWord+'</i>.';
  if(uWord.length>=3&&cWord.length>=3&&uWord[0]===cWord[0]&&Math.abs(uWord.length-cWord.length)<=2)
    return '\u{1f4a1} Das Wort <b>'+uWord+'</b> stimmt so nicht \u2013 richtig: <b>'+cWord+'</b>.';
  return '\u{1f4a1} Ab dem Wort <b>'+(uWord||'\u2026')+'</b> stimmt etwas nicht.';
}

function buildPartialHint(answer){
  if(!answer)return '';
  const words=(''+answer).trim().replace(/[.!?]+$/,'').split(/\s+/).filter(Boolean);
  if(words.length<3)return words[0]||'';
  return words.slice(0,Math.max(2,Math.ceil(words.length*0.4))).join(' ');
}

// ===== ANALYZE ERROR (Simple Past specific) =====
function analyzeError(userInput,correctAnswers){
  const u=userInput.toLowerCase().trim();
  const ansList=Array.isArray(correctAnswers)?correctAnswers:[correctAnswers];
  const c=(ansList[0]||'').toLowerCase().trim();
  // will + V2/V-ed (klassischer Fehler)
  if(/\bwill\s+(went|ate|wrote|saw|bought|took|made|gave|came|ran|got|read|knew|drank|swam|brought|began|played|watched|worked|helped|cooked|visited|cleaned|opened|closed|started|stopped|lived|moved|studied|tried|cried)\b/.test(u))
    return '\u{1f4a1} Nach <b>will</b> kommt die <b>Grundform</b>, nicht die Vergangenheitsform! (z.\u00a0B. will go statt will went)';
  // won't + V2/V-ed
  if(/\bwon't\s+(went|ate|wrote|saw|bought|took|made|gave|came|ran|got|knew|drank|swam|brought|began|played|watched|worked|helped|visited|cleaned|opened|closed|started|stopped|lived|moved|studied)\b/.test(u))
    return '\u{1f4a1} Nach <b>won\'t</b> kommt die <b>Grundform</b>, nicht V2/-ed!';
  // didn't + V2 (klassischer Fehler "didn't went")
  if(/\bdidn't\s+(went|ate|wrote|did|saw|bought|took|made|left|broke|gave|spoke|found|lost|told|came|ran|sent|met|got|won|read|knew|heard|thought|drank|swam|brought|began|played|watched|worked|helped|cooked|visited|cleaned|opened|closed|started|stopped|lived|moved|studied|tried|cried)\b/.test(u))
    return '\u{1f4a1} Nach <b>didn\'t</b> kommt die <b>Grundform</b>, nicht V2/-ed! (z.\u00a0B. didn\'t go statt didn\'t went)';
  // doesn't / don't + V-s (Simple Present)
  if(/\b(doesn't|don't)\s+(plays|watches|works|likes|goes|sees|eats|does|has|gives|takes|makes|reads|knows|wants|needs|lives|moves)\b/.test(u))
    return '\u{1f4a1} Nach <b>don\'t/doesn\'t</b> kommt die <b>Grundform</b> (ohne -s)!';
  // did + V2 in Frage
  if(/^did\s+\w+\s+(went|ate|wrote|did|saw|bought|took|made|left|broke|gave|spoke|found|lost|told|came|ran|sent|met|got|won|read|knew|heard|thought|played|watched|worked|helped|visited)\b/.test(u))
    return '\u{1f4a1} Nach <b>Did + Subj.</b> kommt die <b>Grundform</b>, nicht V2/-ed!';
  // do/does + V-s
  if(/^(do|does)\s+\w+\s+(plays|watches|works|likes|goes|sees|eats|has|gives|takes|makes)\b/.test(u))
    return '\u{1f4a1} Nach <b>Do/Does + Subj.</b> kommt die <b>Grundform</b> (ohne -s)!';
  // 3rd person -s vergessen (he/she/it + Grundform statt + s)
  if(/\b(he|she|it|tom|anna|sue)\s+(play|watch|work|like|go|see|eat|do|have|give|take|make|read|know|want|need|live|move|study|try)\b/.test(u)&&!/\bwill\b/.test(u)&&!/\bdoesn't\b/.test(u)&&!/\bdon't\b/.test(u)&&!/\bdid\b/.test(u))
    if(/\b(plays|watches|works|likes|goes|sees|eats|does|has|gives|takes|makes|reads|knows|wants|needs|lives|moves|studies|tries)\b/.test(c))
      return '\u{1f4a1} Im Simple Present bekommt <b>he / she / it</b> ein <b>-s</b> am Verb!';
  // doesn't / don't statt didn't
  if(/\b(doesn't|don't)\b/.test(u)&&/\bdidn't\b/.test(c))
    return '\u{1f4a1} Vergangenheit: nicht <i>don\'t/doesn\'t</i>, sondern <b>didn\'t</b>.';
  if(/\bdoes\b/.test(u)&&/\bdid\b/.test(c)&&!/\bwill\b/.test(c))
    return '\u{1f4a1} Vergangenheit: nicht <i>does</i>, sondern <b>did</b>.';
  // will statt going-to oder umgekehrt \u2013 einfache Hinweise
  if(/\bwill\b/.test(c)&&/\b(am|is|are)\s+going\s+to\b/.test(u))
    return '\u{1f4a1} Hier passt eher das <b>will-future</b> (will + Grundform).';
  // was/were verwechselt
  if(/\bwas\b/.test(u)&&/\bwere\b/.test(c)&&!/\bwere\b/.test(u))
    return '\u{1f4a1} <b>were</b> bei you/we/they.';
  if(/\bwere\b/.test(u)&&/\bwas\b/.test(c)&&!/\bwas\b/.test(u))
    return '\u{1f4a1} <b>was</b> bei I/he/she/it.';
  if(/\bdidn't\b/.test(c)&&!/\bdidn't\b/.test(u)&&!/\bdid not\b/.test(u)&&!/\bwon't\b/.test(u)&&!/\bwill not\b/.test(u))
    return '\u{1f4a1} Verneinung im Simple Past: <b>didn\'t</b> + Grundform.';
  if(/\bwon't\b/.test(c)&&!/\bwon't\b/.test(u)&&!/\bwill not\b/.test(u))
    return '\u{1f4a1} Verneinung im Will Future: <b>won\'t</b> (= will not) + Grundform.';
  if(/\bdidn't\b/.test(c)&&/\bdid not\b/.test(u))return null;
  if(/\bdid not\b/.test(c)&&/\bdidn't\b/.test(u))return null;
  if(/\bwon't\b/.test(c)&&/\bwill not\b/.test(u))return null;
  if(/\bwill not\b/.test(c)&&/\bwon't\b/.test(u))return null;
  if(/\bdoesn't\b/.test(c)&&/\bdoes not\b/.test(u))return null;
  if(/\bdoes not\b/.test(c)&&/\bdoesn't\b/.test(u))return null;
  if(/\bdon't\b/.test(c)&&/\bdo not\b/.test(u))return null;
  if(/\bdo not\b/.test(c)&&/\bdon't\b/.test(u))return null;
  let best=ansList[0],bestDiff=Infinity;
  for(const a of ansList){
    const an=normalizeAnswer(a),un=normalizeAnswer(userInput);
    const aw=an.split(/\s+/),uw=un.split(/\s+/);
    let d=Math.abs(aw.length-uw.length);
    const m=Math.min(aw.length,uw.length);
    for(let i=0;i<m;i++)if(aw[i]!==uw[i])d++;
    if(d<bestDiff){bestDiff=d;best=a;}
  }
  return diffHint(userInput,best);
}

// ===== CUSTOM CONFIRM =====
function customConfirm(msg,onOk){
  const modal=document.getElementById('confirm-modal');
  const msgEl=document.getElementById('confirm-msg');
