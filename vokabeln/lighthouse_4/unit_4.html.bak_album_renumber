function renderScrWordTasks(ct,items,onS){
  ct.innerHTML='';let correct=0,done=0;const total=items.length;
  items.forEach((item,i)=>{
    const answer=item.answer;const chars=[...answer];
    const spacePos=new Set();chars.forEach((c,j)=>{if(c===' ')spacePos.add(j);});
    const letters=chars.filter(c=>c!==' ');
    const sh=shuffle([...letters]);if(sh.join('')===letters.join('')&&letters.length>1){const tmp=sh[0];sh[0]=sh[sh.length-1];sh[sh.length-1]=tmp;}
    let built=[];
