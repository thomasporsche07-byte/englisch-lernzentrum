// ── TOKEN-REIHENFOLGE (Schreibübung N2, Diktat N2) ──
function renderTokenOrderTasks(ct,items,onS,opts){
opts=opts||{};ct.innerHTML='';var correct=0,done=0,total=items.length;
items.forEach(function(item,i){
  var answer=item.answer;var isMulti=answer.indexOf(' ')!==-1;
  var tokens=isMulti?answer.split(' '):answer.split('');
  var scrambled=tokens.slice();var tries=0;
  while(tries<30&&tokens.length>1&&scrambled.join('\x01')===tokens.join('\x01')){
    for(var s=scrambled.length-1;s>0;s--){var r=Math.floor(Math.random()*(s+1));var tmp=scrambled[s];scrambled[s]=scrambled[r];scrambled[r]=tmp;}tries++;}
  var card=document.createElement('div');card.className='scr-card';
  var topHtml=(opts.showAudio&&item.playHtml)?item.playHtml
    :'<div class="scr-de" style="font-size:18px;font-weight:800;text-align:center;margin-bottom:8px">'+item.de+'</div>';
  var hintHtml=item.hint?'<div class="scr-hint" style="font-size:13px;color:#475569;text-align:center;margin-bottom:6px;font-style:italic">'+highlightKeys(item.hint,item.key)+'</div>':'';
  var ph=isMulti?'Wörter in die richtige Reihenfolge klicken …':'Buchstaben in die richtige Reihenfolge klicken …';
