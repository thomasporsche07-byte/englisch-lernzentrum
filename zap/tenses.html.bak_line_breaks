}

// ===== SHUFFLE PROMPT SLASH LIST =====
function shufflePromptSlashList(html){
  if(!html||typeof html!=='string')return html;
  return html.replace(/<i>([^<]+?)<\/i>/g,(m,inner)=>{
    if(!inner.includes(' / ')||/___|[()]/.test(inner))return m;
    const content=inner.replace(/[.!?]+\s*$/,'').trim();
    const parts=content.split(' / ').map(p=>p.trim()).filter(Boolean);
    if(parts.length<2)return m;
    const original=parts.join(' / ');
    let shuffled,attempts=0;
    do{shuffled=parts.slice();for(let i=shuffled.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[shuffled[i],shuffled[j]]=[shuffled[j],shuffled[i]];}attempts++;}
    while(shuffled.join(' / ')===original&&attempts<20);
    return '<i>'+shuffled.join(' / ')+'</i>';
  });
}

// ===== CELEBRATE =====
function checkCelebration(container,progressCtrl){
  const inputs=container.querySelectorAll('.task input');
  if(!inputs.length)return;
  if(!Array.from(inputs).every(i=>i._correct))return;
  if(container.querySelector('.celebrate-banner'))return;
  const banner=document.createElement('div');banner.className='celebrate-banner';
  banner.innerHTML='\U0001f389 Perfekt! Alle Aufgaben richtig \u2013 super gemacht!';
  container.prepend(banner);
  setTimeout(()=>banner.scrollIntoView({behavior:'smooth',block:'nearest'}),80);
}

// ===== RENDER TASKS =====
function renderTasks(container,tasks,sectionKey,options={}){
  const{enableSolution=false,onStatusChange=null,currentLevel=1}=options;
  const progressKey=sectionKey+'_L'+currentLevel;
  const answersKey=sectionKey+'_L'+currentLevel+'_ans';
  const solvedTasks=loadProgress(progressKey,[]);
  const savedAnswers=loadProgress(answersKey,{});
  container.innerHTML='';
  tasks.forEach((t,idx)=>{
    const tHash=taskHash(t);
    const isSolved=solvedTasks.includes(tHash);
    const savedAns=savedAnswers[tHash]||'';
    const wrap=document.createElement('div');wrap.className='task';
    if(isSolved)wrap.classList.add('task--solved');
    const nb=document.createElement('div');nb.style.cssText='font-size:12px;font-weight:700;color:#9ca3af;margin-bottom:4px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;';
    nb.textContent='Aufgabe '+(idx+1)+' / '+tasks.length;
    const badge=document.createElement('span');badge.className='task-type-badge';
    if(t.type==='mc'){badge.classList.add('badge-mc');badge.textContent='Multiple Choice';}
    else if(Array.isArray(t.words)){badge.classList.add('badge-ordne');badge.textContent='W\u00f6rter ordnen';}
    else{badge.classList.add('badge-frei');badge.textContent='Freitext';}
    nb.appendChild(badge);wrap.appendChild(nb);
    const solvedLabel=document.createElement('div');solvedLabel.className='task-solved-label';
    if(isSolved&&savedAns){solvedLabel.innerHTML='\u2713 Bereits gel\u00f6st: <i>'+savedAns+'</i>';}
    else if(isSolved){solvedLabel.textContent='\u2713 Bereits gel\u00f6st';}
    wrap.appendChild(solvedLabel);

    // ===== MC =====
    if(t.type==='mc'){
      const prompt=document.createElement('p');prompt.className='prompt';prompt.innerHTML=t.prompt;wrap.appendChild(prompt);
      const mcBox=document.createElement('div');mcBox.className='mc-options';
      const letters=['A','B','C','D'];
      const input=document.createElement('input');input.type='hidden';input.id=sectionKey+'-input-'+idx;
      if(isSolved){input._correct=true;input._done=true;}
      wrap.appendChild(input);
      const feedback=document.createElement('div');feedback.className='feedback';
      let answered=isSolved;
      const optBtns=[];
      const optIndices=[...Array(t.options.length).keys()];
      for(let i=optIndices.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[optIndices[i],optIndices[j]]=[optIndices[j],optIndices[i]];}
      const shuffledOpts=optIndices.map(i=>t.options[i]);
      const correctIdx=optIndices.indexOf(t.correct);
      shuffledOpts.forEach((opt,oi)=>{
        const btn=document.createElement('button');btn.className='mc-opt';btn.type='button';
        if(isSolved){btn.classList.add('mc-disabled');if(oi===correctIdx)btn.classList.add('mc-correct');}
        btn.innerHTML='<span class="mc-letter">'+letters[oi]+'</span><span>'+opt+'</span>';
        btn.addEventListener('click',()=>{
          if(answered)return;answered=true;
          optBtns.forEach(b=>b.classList.add('mc-disabled'));
          if(oi===correctIdx){
            btn.classList.add('mc-correct');feedback.textContent='\u2713 Richtig!';feedback.className='feedback ok';
            input._correct=true;input._done=true;input.value=opt;
            if(!isSolved){const updated=[...solvedTasks,tHash];saveProgress(progressKey,updated);savedAnswers[tHash]=opt;saveProgress(answersKey,savedAnswers);wrap.classList.add('task--solved');solvedLabel.innerHTML='\u2713 Bereits gel\u00f6st: <i>'+opt+'</i>';}
          }else{
            btn.classList.add('mc-wrong');optBtns[correctIdx].classList.add('mc-correct');
            feedback.textContent='\u2717 Leider falsch.';feedback.className='feedback bad';
            input._correct=false;input._done=true;input.value=opt;
            if(t.explanation){const expl=document.createElement('div');expl.className='solution';expl.style.display='block';expl.innerHTML=t.explanation;wrap.appendChild(expl);}
          }
          if(typeof onStatusChange==='function')onStatusChange();
        });
        optBtns.push(btn);mcBox.appendChild(btn);
      });
      wrap.appendChild(mcBox);wrap.appendChild(feedback);
      input._check=()=>{if(!answered){feedback.textContent='Bitte w\u00e4hle eine Antwort.';feedback.className='feedback warn';return false;}return input._correct;};
      input._reset=()=>{answered=false;input._correct=false;input._done=false;input.value='';feedback.textContent='';feedback.className='feedback';optBtns.forEach(b=>{b.classList.remove('mc-correct','mc-wrong','mc-selected','mc-disabled');});solvedLabel.textContent='';wrap.classList.remove('task--solved');wrap.querySelectorAll('.solution').forEach(e=>e.remove());if(typeof onStatusChange==='function')onStatusChange();};
      container.appendChild(wrap);return;
    }

    // ===== WORD ORDER (TAP-TO-ORDER) =====
    if(Array.isArray(t.words)){
      const answers=Array.isArray(t.answer)?t.answer:[t.answer];
      const punct=answers[0]&&answers[0].slice(-1).match(/[.?!]/)?answers[0].slice(-1):'.';
      const allCorrectNorms=answers.map(a=>a.replace(/[.?!]$/,'').trim().toLowerCase());
      function isCorrectOrder(arr){return allCorrectNorms.includes(arr.join(' ').toLowerCase());}
      let mixed=shuffle([...t.words]);let tries=0;
      while(isCorrectOrder(mixed)&&tries<20){mixed=shuffle([...t.words]);tries++;}
      if(isCorrectOrder(mixed)&&mixed.length>=2){
        let swapped=false;
        for(let i=0;i<mixed.length-1&&!swapped;i++){const test=[...mixed];[test[i],test[i+1]]=[test[i+1],test[i]];if(!isCorrectOrder(test)){mixed=test;swapped=true;}}
        if(!swapped){mixed=[mixed[mixed.length-1],...mixed.slice(0,mixed.length-1)];}
      }
      const prompt=document.createElement('p');prompt.className='prompt';prompt.textContent=(t.label||'Ordne')+': Tippe die W\u00f6rter in der richtigen Reihenfolge an.';wrap.appendChild(prompt);
      const input=document.createElement('input');input.type='hidden';input.id=sectionKey+'-input-'+idx;
      if(isSolved){input._correct=true;input._done=true;}
      wrap.appendChild(input);
      const target=document.createElement('div');target.className='wt-target';
      const source=document.createElement('div');source.className='wt-source';
      const feedback=document.createElement('div');feedback.className='feedback';
      let done=isSolved,answered=isSolved;
      const notify=()=>{if(typeof onStatusChange==='function')onStatusChange();};
      function getCurrentAnswer(){return Array.from(target.querySelectorAll('.word-tile')).map(t=>t.textContent);}
      function checkAnswer(){
        const cur=getCurrentAnswer();
        return isCorrectOrder(cur);
      }
      if(isSolved){
        const correctWords=answers[0].replace(/[.?!]$/,'').trim().split(' ');
        correctWords.forEach(w=>{const tile=document.createElement('span');tile.className='word-tile';tile.textContent=w;target.appendChild(tile);});
        const pt=document.createElement('span');pt.className='wt-punct';pt.textContent=punct;target.appendChild(pt);
        feedback.textContent='\u2713 Richtig!';feedback.className='feedback ok';
      }else{
        mixed.forEach(w=>{
          const tile=document.createElement('span');tile.className='word-tile';tile.textContent=w;
          tile.addEventListener('click',()=>{
            if(done)return;
            target.appendChild(tile);
            if(getCurrentAnswer().length===t.words.length){
              if(checkAnswer()){
                done=true;answered=true;input._correct=true;input._done=true;
                const pt=document.createElement('span');pt.className='wt-punct';pt.textContent=punct;target.appendChild(pt);
                feedback.textContent='\u2713 Richtig!';feedback.className='feedback ok';
                const ansText=getCurrentAnswer().join(' ');
