let acSelectedIdx = -1;
let acVisible = false;

function acCurrentWord() {
  const ta = document.getElementById('student-text');
  const val = ta.value.substring(0, ta.selectionStart);
  const lines = val.split('\n');
  return lines[lines.length - 1];
}

function acInput() {
  const type = document.getElementById('sel-type').value;
  const phrases = AC_PHRASES[type] || AC_PHRASES.free;
  const currentLine = acCurrentWord().trimStart();
  const box = document.getElementById('ac-box');

  if (currentLine.length < 1) { acHide(); return; }

  const filtered = phrases.filter(p =>
    p.t.toLowerCase().startsWith(currentLine.toLowerCase()) && p.t.toLowerCase() !== currentLine.toLowerCase()
  );

  if (!filtered.length) { acHide(); return; }

  acSelectedIdx = -1;
  box.innerHTML = '<div class="ac-header">💡 Vorschläge / Suggestions</div>' +
    filtered.slice(0, 5).map((p, i) =>
      `<div class="ac-item" data-idx="${i}" data-phrase="${p.t.replace(/"/g,'&quot;').replace(/'/g,'&#39;')}"><span class="ac-item-icon">${p.i}</span>${esc(p.t)}</div>`
    ).join('');
  box.querySelectorAll('.ac-item').forEach(el => {
    el.addEventListener('mousedown', e => { e.preventDefault(); acSelect(el.dataset.phrase); });
  });
  box.classList.add('visible');
  acVisible = true;
}

function acSelect(text) {
  const ta = document.getElementById('student-text');
  const pos = ta.selectionStart;
  const before = ta.value.substring(0, pos);
  const after = ta.value.substring(pos);
  const lines = before.split('\n');
  const currentLine = lines[lines.length - 1];
  const lineStart = before.lastIndexOf('\n') + 1;
  ta.value = ta.value.substring(0, lineStart) + text + ' ' + after.trimStart();
  const newPos = lineStart + text.length + 1;
  ta.setSelectionRange(newPos, newPos);
  ta.focus();
  acHide();
  updateWordCount();
}

function acKeydown(e) {
  if (!acVisible) return;
  const items = document.querySelectorAll('#ac-box .ac-item');
  if (e.key === 'ArrowDown') { e.preventDefault(); acSelectedIdx = Math.min(acSelectedIdx+1, items.length-1); acHighlight(items); }
  else if (e.key === 'ArrowUp') { e.preventDefault(); acSelectedIdx = Math.max(acSelectedIdx-1, -1); acHighlight(items); }
  else if (e.key === 'Tab' || e.key === 'Enter') {
    if (acSelectedIdx >= 0 && items[acSelectedIdx]) {
      e.preventDefault();
      acSelect(items[acSelectedIdx].dataset.phrase);
    } else { acHide(); }
  } else if (e.key === 'Escape') { acHide(); }
}

function acHighlight(items) {
  items.forEach((el,i) => el.style.background = i===acSelectedIdx ? '#eff6ff' : '');
}
function acHide() { document.getElementById('ac-box').classList.remove('visible'); acVisible=false; acSelectedIdx=-1; }

