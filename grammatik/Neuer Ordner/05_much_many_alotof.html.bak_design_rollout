function renderTask(task,idx,secKey){
  const shuf=HRShared.shuffle;
  let html='<div class="task" id="task-'+secKey+'-'+idx+'">';
  if(task.type==='mc'){
    html+='<span class="task-type-badge badge-mc">Multiple Choice</span>';
    html+='<div class="prompt">'+task.prompt+'</div>';
    html+='<div class="mc-options">';
    task.options.forEach((opt,i)=>{
      const isCorrect=i===task.correct;
      html+='<div class="mc-opt" data-opt="'+i+'" data-correct="'+isCorrect+'"><span class="mc-letter">'+String.fromCharCode(65+i)+'</span><span>'+opt+'</span></div>';
    });
    html+='</div>';
  }else{
    html+='<span class="task-type-badge badge-frei">Freitext</span>';
    html+='<div class="prompt">'+task.prompt+'</div>';
    html+='<input type="text" class="task-input" placeholder="Antwort eingeben..." />';
    if(task.explanation){html+='<div class="solution">'+task.explanation+'</div>';}
  }
  html+='<div class="controls" style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;">';
  html+='<button class="btn blue task-check">Prüfen</button>';
  html+='<button class="btn ghost task-show">Lösung zeigen</button>';
  html+='</div>';
  html+='<div class="feedback"></div>';
  html+='</div>';
  return html;
}

function setupSection(secKey,lvlSwitch,tasksDiv,pools,checkAllBtn,resetBtn){
  let currentLevel=1;
  let taskStates=mmaLoad(secKey+'_states',{})||{};

  function renderTasks(){
    tasksDiv.innerHTML='';
    if(window.HRShared&&HRShared.clearBanners)HRShared.clearBanners(tasksDiv);
    const pool=pools[currentLevel]||[];
    const PICK=15;
    const shuffled=pool.slice();
    for(let i=shuffled.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[shuffled[i],shuffled[j]]=[shuffled[j],shuffled[i]];}
    const picked=shuffled.slice(0,Math.min(PICK,shuffled.length));
    picked.forEach((task,idx)=>{
      const taskId=currentLevel+'-'+idx;
      tasksDiv.insertAdjacentHTML('beforeend',renderTask(task,idx,secKey));
      const taskEl=tasksDiv.querySelector('#task-'+secKey+'-'+idx);
      if(taskStates[taskId]==='solved')taskEl.classList.add('task--solved');
      const checkBtn=taskEl.querySelector('.task-check');
      const showBtn=taskEl.querySelector('.task-show');
      const feedback=taskEl.querySelector('.feedback');
      const input=taskEl.querySelector('.task-input');

      if(task.type==='mc'){
        const opts=taskEl.querySelectorAll('.mc-opt');
        opts.forEach(o=>o.addEventListener('click',()=>{
          if(taskEl.classList.contains('task--solved'))return;
          opts.forEach(x=>x.classList.remove('mc-selected','mc-correct','mc-wrong'));
          o.classList.add('mc-selected');
        }));
        if(checkBtn)checkBtn.addEventListener('click',()=>{
          if(taskEl.classList.contains('task--solved'))return;
          const sel=taskEl.querySelector('.mc-opt.mc-selected');
          if(!sel){feedback.textContent='Bitte wähle eine Antwort.';feedback.className='feedback warn';return;}
          const correct=sel.dataset.correct==='true';
          opts.forEach(x=>x.classList.add('mc-disabled'));
          if(correct){
            sel.classList.add('mc-correct');
            feedback.textContent='✓ Richtig!';feedback.className='feedback ok';
            taskEl.classList.add('task--solved');
            taskStates[taskId]='solved';mmaSave(secKey+'_states',taskStates);
          }else{
            sel.classList.add('mc-wrong');
            const corr=Array.from(opts).find(x=>x.dataset.correct==='true');
            if(corr)corr.classList.add('mc-correct');
            feedback.innerHTML='✗ Falsch! Richtig: <b>'+(corr?corr.textContent:'')+'</b>';
            feedback.className='feedback bad';
            taskEl.classList.add('task--wrong');
          }
          updateProgress();
          setTimeout(()=>HRShared.checkCelebration(tasksDiv,'🎉 Perfekt! Du hast alles gelöst!'),300);
        });
      }else{
        if(checkBtn)checkBtn.addEventListener('click',()=>{
          if(taskEl.classList.contains('task--solved'))return;
          const val=(input.value||'').trim().toLowerCase();
          const correctList=task.answer.map(a=>a.toLowerCase().trim());
          const isCorrect=correctList.includes(val);
          if(isCorrect){
            feedback.textContent='✓ Richtig!';feedback.className='feedback ok';
            input.disabled=true;
            taskEl.classList.add('task--solved');
            taskStates[taskId]='solved';mmaSave(secKey+'_states',taskStates);
          }else{
            feedback.innerHTML='✗ Falsch! Lösung: <b>'+task.answer.join(' / ')+'</b>';
            feedback.className='feedback bad';
            taskEl.classList.add('task--wrong');
          }
          updateProgress();
          setTimeout(()=>HRShared.checkCelebration(tasksDiv,'🎉 Perfekt! Du hast alles gelöst!'),300);
        });
        if(showBtn)showBtn.addEventListener('click',()=>{
          const sol=taskEl.querySelector('.solution');
          if(sol)sol.style.display='block';
        });
      }
    });
  }

  function updateProgress(){
    const all=tasksDiv.querySelectorAll('.task');
    const solved=tasksDiv.querySelectorAll('.task.task--solved').length;
    const pct=all.length>0?Math.round(solved/all.length*100):0;
    const wrap=lvlSwitch?lvlSwitch.parentNode:tasksDiv.parentNode;
    const prog=wrap.querySelector('.progress-fill');
    const txt=wrap.querySelector('.progress-text');
    if(prog)prog.style.width=pct+'%';
    if(txt)txt.textContent='Fortschritt: '+solved+'/'+all.length+' richtig ('+pct+'%)';
  }

  if(lvlSwitch){
    lvlSwitch.querySelectorAll('.level-btn').forEach(btn=>{
      btn.addEventListener('click',()=>{
        lvlSwitch.querySelectorAll('.level-btn').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
        currentLevel=+btn.dataset.level;
        renderTasks();updateProgress();
      });
    });
  }
  if(checkAllBtn)checkAllBtn.addEventListener('click',()=>{
    tasksDiv.querySelectorAll('.task-check').forEach(btn=>btn.click());
    const all=tasksDiv.querySelectorAll('.task').length;
    const solved=tasksDiv.querySelectorAll('.task.task--solved').length;
    const wrongItems=[];
    tasksDiv.querySelectorAll('.task.task--wrong').forEach(t=>{
      const p=t.querySelector('.prompt');
      wrongItems.push({prompt:p?p.textContent:''});
    });
    HRShared.showResultBanner(tasksDiv,solved,all,{wrongItems:wrongItems});
  });
  if(resetBtn)resetBtn.addEventListener('click',()=>{
    HRShared.customConfirm('Diese Sektion zurücksetzen?',()=>{
      taskStates={};mmaSave(secKey+'_states',{});
      renderTasks();updateProgress();
    });
  });
  renderTasks();updateProgress();
}

