      }
      wrap.appendChild(source);wrap.appendChild(target);wrap.appendChild(feedback);
      input._check=()=>input._correct;
      input._reset=()=>{done=false;answered=false;input._correct=false;input._done=false;feedback.textContent='';feedback.className='feedback';target.innerHTML='';source.innerHTML='';mixed=shuffle([...t.words]);let tr=0;while(isCorrectOrder(mixed)&&tr<20){mixed=shuffle([...t.words]);tr++;}mixed.forEach(w=>{const tile=document.createElement('span');tile.className='word-tile';tile.textContent=w;tile.addEventListener('click',()=>{if(done)return;target.appendChild(tile);if(getCurrentAnswer().length===t.words.length){if(checkAnswer()){done=true;answered=true;input._correct=true;input._done=true;const pt=document.createElement('span');pt.className='wt-punct';pt.textContent=punct;target.appendChild(pt);feedback.textContent='\u2713 Richtig!';feedback.className='feedback ok';const ansText=getCurrentAnswer().join(' ');if(!solvedTasks.includes(tHash)){solvedTasks.push(tHash);saveProgress(progressKey,solvedTasks);savedAnswers[tHash]=ansText;saveProgress(answersKey,savedAnswers);wrap.classList.add('task--solved');solvedLabel.innerHTML='\u2713 Bereits gel\u00f6st: <i>'+ansText+'</i>';}}else{feedback.textContent='\u2717 Leider falsch \u2013 versuche es nochmal!';feedback.className='feedback bad';setTimeout(()=>{Array.from(target.querySelectorAll('.word-tile')).forEach(tile=>source.appendChild(tile));feedback.textContent='';feedback.className='feedback';},900);}notify();}});source.appendChild(tile);});solvedLabel.textContent='';wrap.classList.remove('task--solved');notify();};
      container.appendChild(wrap);
      if(typeof TTS!=='undefined'&&TTS.enabled)setTimeout(()=>TTS.injectAll(),60);
      return;
    }

    // ===== FREITEXT =====
    const answers=Array.isArray(t.answer)?t.answer:[t.answer];
    const prompt=document.createElement('p');prompt.className='prompt';
    prompt.innerHTML=shufflePromptSlashList(t.prompt||'');wrap.appendChild(prompt);
    const inp=document.createElement('input');inp.type='text';inp.placeholder='Deine Antwort \u2026';
    if(isSolved){inp.value=savedAns;inp.disabled=true;}
    wrap.appendChild(inp);
    const feedback=document.createElement('div');feedback.className='feedback';wrap.appendChild(feedback);
    const hintBtn=document.createElement('button');hintBtn.className='btn ghost';hintBtn.textContent='\u{1f4a1} Tipp';hintBtn.style.display='none';
    const hintBox=document.createElement('div');hintBox.className='hint-box';
