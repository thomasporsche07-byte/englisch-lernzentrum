(function(){const stored=localStorage.getItem('darkMode');const sysDark=window.matchMedia('(prefers-color-scheme: dark)').matches;const useDark=stored==='1'||(stored===null && sysDark);if(useDark)document.body.classList.add('dark-mode');const btn=document.getElementById('dark-toggle');if(btn){btn.textContent=useDark?'☀️ Hell':'🌙 Dark Mode';btn.onclick=()=>{const on=document.body.classList.toggle('dark-mode');btn.textContent=on?'☀️ Hell':'🌙 Dark Mode';try{localStorage.setItem('darkMode',on?'1':'0');}catch(e){}};}})();

/* ===== TTS (Web Speech API) ===== */
const TTS={enabled:false,toggle(){this.enabled=!this.enabled;const b=document.getElementById('tts-toggle');if(b)b.textContent=this.enabled?'🔇 TTS aus':'🔊 Vorlesen';},speak(text,lang,rate){if(!this.enabled || !window.speechSynthesis)return;window.speechSynthesis.cancel();const u=new SpeechSynthesisUtterance(text);u.lang=lang||'en-US';u.rate=rate||0.95;window.speechSynthesis.speak(u);},stop(){if(window.speechSynthesis)window.speechSynthesis.cancel();}};
(function(){const b=document.getElementById('tts-toggle');if(b)b.onclick=()=>TTS.toggle();})();

/* ===== Reset-All Button ===== */
function resetAllProgress(prefix){if(!confirm('Gesamten Fortschritt dieser Seite zurücksetzen?'))return;const keys=[];for(let i=0;i<localStorage.length;i++){const k=localStorage.key(i);if(k && k.startsWith('pb_'+prefix))keys.push(k);}keys.forEach(k=>localStorage.removeItem(k));location.reload();}


