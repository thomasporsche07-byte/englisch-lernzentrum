// Dark Mode: System-Präferenz als Default, manueller Toggle überschreibt
(function(){
  const b=document.getElementById('dark-toggle');
  let stored=null;
  try{stored=localStorage.getItem('darkMode');}catch(e){}
  const sysQuery = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;
  const sysDark = sysQuery && sysQuery.matches;
  function apply(on){
    document.body.classList.toggle('dark-mode',on);
    b.textContent = on ? '☀️ Hell' : '🌙 Dark Mode';
  }
  // initial: localStorage gewinnt; sonst System
  apply(stored==='1' || (stored===null && sysDark));
  b.addEventListener('click',()=>{
    const on=!document.body.classList.contains('dark-mode');
    apply(on);
    try{localStorage.setItem('darkMode',on?'1':'0');}catch(e){}
  });
  // Live-Reaktion auf System-Wechsel, solange User noch nichts manuell gesetzt hat
  if(sysQuery && sysQuery.addEventListener){
    sysQuery.addEventListener('change', ev=>{
      let cur=null; try{cur=localStorage.getItem('darkMode');}catch(e){}
      if(cur===null) apply(ev.matches);
    });
  }
})();
// Tastatur-Shortcuts: 1/2/3 für MC-Auswahl, ↓/↑ zum Springen zwischen Aufgaben, Enter wird in Inputs lokal behandelt
(function(){
  function isTyping(el){
    if(!el) return false;
    const tag=(el.tagName||'').toUpperCase();
    return tag==='INPUT' || tag==='TEXTAREA' || el.isContentEditable;
  }
  function openTasks(){
    return Array.from(document.querySelectorAll('details.accordion[open] .task'));
  }
  function topVisibleTaskWithMC(){
    const vh = window.innerHeight;
    let best=null, bestTop=Infinity;
    openTasks().forEach(t=>{
      const opts = t.querySelectorAll('.mc-opt:not([disabled])');
      if(opts.length===0) return;
      const r = t.getBoundingClientRect();
      if(r.bottom<60 || r.top>vh-60) return;
      const top = Math.abs(r.top);
      if(top<bestTop){bestTop=top;best=t;}
    });
    return best;
  }
  document.addEventListener('keydown', function(e){
    if(e.ctrlKey||e.metaKey||e.altKey) return;
    const typing = isTyping(document.activeElement);
    if(!typing && /^[1-6]$/.test(e.key)){
      const idx = parseInt(e.key,10)-1;
      const t = topVisibleTaskWithMC();
      if(t){
        const opts = t.querySelectorAll('.mc-opt:not([disabled])');
        if(opts[idx]){opts[idx].click(); e.preventDefault();}
      }
      return;
    }
    if(!typing && (e.key==='ArrowDown' || e.key==='ArrowUp')){
      const tasks = openTasks();
      if(tasks.length===0) return;
      const vh = window.innerHeight;
      let curIdx = tasks.findIndex(t=>{
        const r=t.getBoundingClientRect();
        return r.top >= -10 && r.top < vh*0.5;
      });
      if(curIdx<0){
        curIdx = tasks.findIndex(t=>t.getBoundingClientRect().top>=0);
        if(curIdx<0) curIdx = tasks.length-1;
      }
      const dir = e.key==='ArrowDown' ? 1 : -1;
      const next = tasks[Math.max(0, Math.min(tasks.length-1, curIdx+dir))];
      if(next && next!==tasks[curIdx]){
        next.scrollIntoView({behavior:'smooth', block:'start'});
        e.preventDefault();
      }
    }
  });
})();
