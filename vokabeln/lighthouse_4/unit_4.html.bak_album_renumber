// ── CROSSWORD ─────────────────────────────────────────────────────
function setupCrossword(){
  const acc = document.getElementById('acc-crossword');
  const board = document.getElementById('cw-board');
  const progEl = document.getElementById('cw-progress');
  const winEl = document.getElementById('cw-win');
  let cur='all', solved = new Set(), allWords = [], grid = null, cellMap = null, activeWord = null;

  buildTopicButtons('cw-topics');

  function eligibleWords(pool){
    return pool
      .map(v => ({en: v.en, de: v.de, raw: v}))
      .filter(w => /^[a-zA-Z]+$/.test(w.en) && w.en.length >= 3 && w.en.length <= 12)
      .map(w => ({...w, key: w.en.toLowerCase()}));
  }

  function buildLayout(words, MAX){
    if(words.length === 0) return null;
    // Sort by length descending for better packing
    words = words.slice().sort((a,b) => b.key.length - a.key.length);
    const G = new Map(); // "y,x" -> letter
    const placed = []; // {word, dir, y, x}

    function get(y,x){return G.get(y+','+x);}
    function setCell(y,x,ch){G.set(y+','+x,ch);}

    function canPlace(word, dir, y, x){
      const wlen = word.length;
      // before
      if(dir==='H' && get(y, x-1)) return false;
      if(dir==='V' && get(y-1, x)) return false;
      // after
      if(dir==='H' && get(y, x+wlen)) return false;
      if(dir==='V' && get(y+wlen, x)) return false;
      let intersections = 0;
      for(let i=0;i<wlen;i++){
        const yy = dir==='V' ? y+i : y;
        const xx = dir==='H' ? x+i : x;
        const ex = get(yy,xx);
        if(ex){
          if(ex !== word[i]) return false;
          intersections++;
        } else {
          // perpendicular neighbors must be empty
          if(dir==='H'){
            if(get(yy-1,xx) || get(yy+1,xx)) return false;
          } else {
            if(get(yy,xx-1) || get(yy,xx+1)) return false;
          }
        }
      }
      return intersections;
    }

    function place(word, dir, y, x, raw){
      for(let i=0;i<word.length;i++){
        const yy = dir==='V' ? y+i : y;
        const xx = dir==='H' ? x+i : x;
        setCell(yy,xx, word[i]);
      }
      placed.push({word, dir, y, x, raw});
    }

    // first word: horizontal at 0,0
    place(words[0].key, 'H', 0, 0, words[0]);

    // try to place each remaining word
    for(let i=1; i<words.length && placed.length<MAX; i++){
      const w = words[i].key;
      let bestPos = null, bestScore = 0;
      for(let li=0; li<w.length; li++){
        for(const [k, ch] of G){
          if(ch !== w[li]) continue;
          const [y,x] = k.split(',').map(Number);
          for(const dir of ['H','V']){
            const yy = dir==='V' ? y - li : y;
            const xx = dir==='H' ? x - li : x;
            const inter = canPlace(w, dir, yy, xx);
            if(inter && inter > bestScore){
              bestScore = inter;
              bestPos = {dir, y: yy, x: xx};
            }
          }
        }
      }
      if(bestPos){
        place(w, bestPos.dir, bestPos.y, bestPos.x, words[i]);
      }
    }
    return {G, placed};
  }

  function render(){
    winEl.classList.remove('show');winEl.innerHTML='';
    solved = new Set();
    activeWord = null;
    const pool = eligibleWords(getPool(cur));
    if(pool.length < 3){
      board.innerHTML='<div class="cw-empty">Nicht genug Wörter im aktuellen Topic (mindestens 3 nötig).</div>';
      progEl.textContent='📍 0 / 0 Wörter gelöst';
      return;
    }
    const picks = lt_pick(pool, Math.min(10, pool.length));
    const layout = buildLayout(picks, 10);
    if(!layout || layout.placed.length === 0){
      board.innerHTML='<div class="cw-empty">Konnte kein Gitter erstellen. Versuch es mit 🎲 Neu generieren.</div>';
      progEl.textContent='📍 0 / 0 Wörter gelöst';
      return;
    }
    grid = layout.G;
    const placed = layout.placed;

    // Bounds
    let minY=Infinity, maxY=-Infinity, minX=Infinity, maxX=-Infinity;
    for(const k of grid.keys()){
      const [y,x] = k.split(',').map(Number);
      if(y<minY)minY=y; if(y>maxY)maxY=y;
      if(x<minX)minX=x; if(x>maxX)maxX=x;
    }

    // Numbering: cells where horizontal or vertical word starts
    const sortedCells = [...grid.keys()].map(k=>{
      const [y,x] = k.split(',').map(Number); return {y,x,key:k};
    }).sort((a,b) => a.y-b.y || a.x-b.x);

    cellMap = new Map(); // "y,x" -> {num, expected}
    let nextNum = 1;
    sortedCells.forEach(({y,x,key})=>{
      const startH = !grid.has(y+','+(x-1)) && grid.has(y+','+(x+1));
      const startV = !grid.has((y-1)+','+x) && grid.has((y+1)+','+x);
      const e = {expected: grid.get(key)};
      if(startH || startV){ e.num = nextNum; nextNum++; }
      cellMap.set(key, e);
    });

    // Find words for hints
    const wordsAcross = [], wordsDown = [];
    sortedCells.forEach(({y,x})=>{
      const startH = !grid.has(y+','+(x-1)) && grid.has(y+','+(x+1));
      const startV = !grid.has((y-1)+','+x) && grid.has((y+1)+','+x);
      const num = cellMap.get(y+','+x).num;
      if(startH){
        let w='', xx=x;
        while(grid.has(y+','+xx)){ w += grid.get(y+','+xx); xx++; }
        const v = VOCAB.find(vc => vc.en.toLowerCase() === w);
        wordsAcross.push({num, word:w, y, x, len:w.length, dir:'H', de: v ? v.de : '?'});
      }
      if(startV){
        let w='', yy=y;
        while(grid.has(yy+','+x)){ w += grid.get(yy+','+x); yy++; }
        const v = VOCAB.find(vc => vc.en.toLowerCase() === w);
        wordsDown.push({num, word:w, y, x, len:w.length, dir:'V', de: v ? v.de : '?'});
      }
    });
    allWords = [...wordsAcross, ...wordsDown];

    // Build table
    board.innerHTML='';
    const wrap = document.createElement('div'); wrap.className='cw-wrap';
    const tbl = document.createElement('table'); tbl.className='cw-grid';
    for(let y=minY; y<=maxY; y++){
      const tr = document.createElement('tr');
      for(let x=minX; x<=maxX; x++){
        const td = document.createElement('td');
        const k = y+','+x;
        if(grid.has(k)){
          td.classList.add('cw-cell');
          td.dataset.key = k;
          const meta = cellMap.get(k);
          if(meta && meta.num){
            const n = document.createElement('span');
            n.className = 'cw-num';
            n.textContent = meta.num;
            td.appendChild(n);
          }
          const inp = document.createElement('input');
          inp.type='text'; inp.maxLength=1;
          inp.dataset.y = y; inp.dataset.x = x;
          inp.dataset.expected = meta.expected;
          inp.addEventListener('input', onInput);
          inp.addEventListener('keydown', onKey);
          inp.addEventListener('focus', onFocus);
          td.appendChild(inp);
        } else {
          td.classList.add('cw-block');
        }
        tr.appendChild(td);
      }
      tbl.appendChild(tr);
    }
    wrap.appendChild(tbl);
    board.appendChild(wrap);

    // Hints
    const hints = document.createElement('div'); hints.className='cw-hints';
    function makeCol(title, list){
      const col = document.createElement('div'); col.className='cw-hint-col';
      const h = document.createElement('h4'); h.textContent=title; col.appendChild(h);
      list.sort((a,b)=>a.num-b.num);
      list.forEach(w=>{
        const row = document.createElement('div'); row.className='cw-hint';
        row.dataset.dir = w.dir; row.dataset.y = w.y; row.dataset.x = w.x; row.dataset.len = w.len;
        row.dataset.word = w.word;
        row.innerHTML = '<span class="cw-hint-num">'+w.num+'.</span><span>'+w.de+' <span style="color:#94a3b8;font-size:11px">('+w.len+')</span></span>';
        row.addEventListener('click', ()=>highlightWord(w));
        col.appendChild(row);
      });
      return col;
    }
    hints.appendChild(makeCol('➡️ Waagerecht', wordsAcross));
    hints.appendChild(makeCol('⬇️ Senkrecht', wordsDown));
    board.appendChild(hints);

    progEl.textContent = '📍 0 / ' + allWords.length + ' Wörter gelöst';
  }

  function highlightWord(w){
    activeWord = w;
    document.querySelectorAll('.cw-grid td.highlight').forEach(t=>t.classList.remove('highlight'));
    document.querySelectorAll('.cw-hint.active').forEach(h=>h.classList.remove('active'));
    const hintEl = document.querySelector('.cw-hint[data-dir="'+w.dir+'"][data-y="'+w.y+'"][data-x="'+w.x+'"]');
    if(hintEl) hintEl.classList.add('active');
    let firstInput = null;
    for(let i=0; i<w.len; i++){
      const yy = w.dir==='V' ? w.y+i : w.y;
      const xx = w.dir==='H' ? w.x+i : w.x;
      const td = board.querySelector('td[data-key="'+yy+','+xx+'"]');
      if(td){
        td.classList.add('highlight');
        if(!firstInput){
          const inp = td.querySelector('input:not(.correct)');
          if(inp) firstInput = inp;
        }
      }
    }
    if(firstInput) firstInput.focus();
  }
  function nextEmptyInActiveWord(fromIdx){
    if(!activeWord) return null;
    for(let off=1; off<=activeWord.len; off++){
      const i = (fromIdx + off) % activeWord.len;
      const yy = activeWord.dir==='V' ? activeWord.y+i : activeWord.y;
      const xx = activeWord.dir==='H' ? activeWord.x+i : activeWord.x;
      const inp = board.querySelector('input[data-y="'+yy+'"][data-x="'+xx+'"]');
      if(inp && !inp.classList.contains('correct')) return inp;
    }
    return null;
  }
  function indexInActiveWord(y, x){
    if(!activeWord) return -1;
    for(let i=0; i<activeWord.len; i++){
      const yy = activeWord.dir==='V' ? activeWord.y+i : activeWord.y;
      const xx = activeWord.dir==='H' ? activeWord.x+i : activeWord.x;
      if(yy===y && xx===x) return i;
    }
    return -1;
  }

  function onFocus(e){
    const y = parseInt(e.target.dataset.y,10), x = parseInt(e.target.dataset.x,10);
    // wenn aktuelles activeWord diese Zelle enthält → nichts ändern (Cursor bleibt im Wort)
    if(activeWord){
      if(activeWord.dir==='H' && activeWord.y===y && x>=activeWord.x && x<activeWord.x+activeWord.len) return;
      if(activeWord.dir==='V' && activeWord.x===x && y>=activeWord.y && y<activeWord.y+activeWord.len) return;
    }
    // sonst: Wort wechseln
    const candidate = allWords.find(w=>{
      if(w.dir==='H') return w.y===y && x>=w.x && x<w.x+w.len;
      return w.x===x && y>=w.y && y<w.y+w.len;
    });
    if(candidate) highlightWord(candidate);
  }

  function onInput(e){
    const inp = e.target;
    const v = (inp.value||'').toLowerCase();
    if(!v){ inp.classList.remove('correct','wrong'); return; }
    if(v === inp.dataset.expected){
      inp.classList.add('correct'); inp.classList.remove('wrong');
      checkProgress();
      // 1) nächstes leeres Feld im AKTIVEN Wort
      if(activeWord){
        const y = parseInt(inp.dataset.y,10), x = parseInt(inp.dataset.x,10);
        const idx = indexInActiveWord(y, x);
        if(idx >= 0){
          const next = nextEmptyInActiveWord(idx);
          if(next){ next.focus(); return; }
        }
      }
      // 2) aktives Wort komplett gelöst → nächstes ungelöstes Wort öffnen
      const nextWord = allWords.find(w => !solved.has(w.word) && w !== activeWord);
      if(nextWord){ highlightWord(nextWord); return; }
      // 3) Fallback: irgendein leeres Feld
      const anyEmpty = board.querySelector('.cw-grid input:not(.correct)');
      if(anyEmpty) anyEmpty.focus();
    } else {
      inp.classList.add('wrong'); inp.classList.remove('correct');
    }
  }

  function onKey(e){
    if(e.key === 'Backspace' && !e.target.value){
      const cur = e.target;
      const allInputs = [...board.querySelectorAll('.cw-grid input')];
      const idx = allInputs.indexOf(cur);
      if(idx>0){ allInputs[idx-1].focus(); }
    }
  }

  function checkProgress(){
    let solvedCount = 0;
    allWords.forEach(w=>{
      let ok = true;
      for(let i=0; i<w.len; i++){
        const yy = w.dir==='V' ? w.y+i : w.y;
        const xx = w.dir==='H' ? w.x+i : w.x;
        const inp = board.querySelector('input[data-y="'+yy+'"][data-x="'+xx+'"]');
        if(!inp || !inp.classList.contains('correct')){ ok = false; break; }
      }
      if(ok){
        solvedCount++;
        if(!solved.has(w.word)){
          solved.add(w.word);
          lt_record(w.word, true);
          // strike-through hint
          const hint = document.querySelector('.cw-hint[data-dir="'+w.dir+'"][data-y="'+w.y+'"][data-x="'+w.x+'"]');
          if(hint) hint.classList.add('solved');
        }
      }
    });
    progEl.textContent = '📍 '+solvedCount+' / '+allWords.length+' Wörter gelöst';
    if(solvedCount === allWords.length && allWords.length > 0){
      winEl.innerHTML = '<div style="font-size:42px">🏆</div><div style="font-size:18px;margin-top:6px">Alle Wörter gelöst!</div>';
      winEl.classList.add('show');
      fireConfetti();
    }
  }

  function reveal(){
    if(!grid) return;
    board.querySelectorAll('.cw-grid input').forEach(inp=>{
      if(!inp.classList.contains('correct')){
        inp.value = inp.dataset.expected.toUpperCase();
        inp.classList.add('correct');
        inp.classList.remove('wrong');
      }
    });
    checkProgress();
  }

  document.getElementById('cw-topics').addEventListener('click', e=>{
    const b = e.target.closest('button[data-topic]'); if(!b) return;
    document.getElementById('cw-topics').querySelectorAll('button').forEach(x=>x.classList.remove('active'));
    b.classList.add('active'); cur = b.dataset.topic; render();
  });
  document.getElementById('cw-reroll').addEventListener('click', render);
  document.getElementById('cw-reveal').addEventListener('click', ()=>{
    if(confirm('Komplette Lösung zeigen?')) reveal();
  });
  acc.addEventListener('toggle', function(){ if(this.open && !board.innerHTML.trim()) render(); });
}

