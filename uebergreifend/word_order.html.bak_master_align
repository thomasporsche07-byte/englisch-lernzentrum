      wrap.appendChild(prompt);
      const mcBox=document.createElement("div");mcBox.className="mc-options";
      const letters=['A','B','C','D'];
      const input=document.createElement("input");input.type="hidden";input.id=`${sectionKey}-input-${idx}`;
      if(isSolved){input._correct=true;input._done=true;}
      wrap.appendChild(input);
      const feedback=document.createElement("div");feedback.className="feedback";
      let answered=isSolved;
      const optBtns=[];
      // Optionen mischen, damit die richtige Antwort nicht immer an der gleichen Stelle steht
      const optIndices=[...Array(t.options.length).keys()];
      for(let i=optIndices.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[optIndices[i],optIndices[j]]=[optIndices[j],optIndices[i]];}
      const shuffledOpts=optIndices.map(i=>t.options[i]);
      const correctIdx=optIndices.indexOf(t.correct);
      shuffledOpts.forEach((opt,oi)=>{
        const btn=document.createElement("button");btn.className="mc-opt";btn.type="button";
        if(isSolved){btn.classList.add('mc-disabled');if(oi===correctIdx)btn.classList.add('mc-correct');}
        btn.innerHTML=`<span class="mc-letter">${letters[oi]||oi+1}</span><span>${opt}</span>`;
        btn.addEventListener('click',()=>{
          if(answered)return;
          answered=true;
          optBtns.forEach(b=>b.classList.add('mc-disabled'));
          if(oi===correctIdx){
            btn.classList.add('mc-correct');
            feedback.textContent="✓ Richtig!";feedback.className="feedback ok";
            input._correct=true;input._done=true;input.value=opt;
            if(!isSolved){const updated=[...solvedTasks,tHash];saveProgress(progressKey,updated);savedAnswers[tHash]=opt;saveProgress(answersKey,savedAnswers);wrap.classList.add('task--solved');solvedLabel.innerHTML=`✓ Bereits gelöst: <i>${opt}</i>`;}
          }else{
            btn.classList.add('mc-wrong');
            optBtns[correctIdx].classList.add('mc-correct');
            feedback.textContent="✗ Leider falsch.";feedback.className="feedback bad";
            input._correct=false;input._done=true;input.value=opt;
            if(t.explanation){const expl=document.createElement('div');expl.className='solution';expl.style.display='block';expl.innerHTML=t.explanation;wrap.appendChild(expl);}
          }
          if(typeof onStatusChange==='function')onStatusChange();
        });
        optBtns.push(btn);
        mcBox.appendChild(btn);
      });
      wrap.appendChild(mcBox);
      wrap.appendChild(feedback);
      input._check=()=>{if(!answered){feedback.textContent="Bitte wähle eine Antwort.";feedback.className="feedback warn";return false;}return input._correct;};
      input._reset=()=>{answered=false;input._correct=false;input._done=false;input.value="";feedback.textContent="";feedback.className="feedback";optBtns.forEach(b=>{b.classList.remove('mc-correct','mc-wrong','mc-selected','mc-disabled');});solvedLabel.textContent='';wrap.classList.remove('task--solved');wrap.querySelectorAll('.solution').forEach(e=>e.remove());if(typeof onStatusChange==='function')onStatusChange();};
      container.appendChild(wrap);
      return;
    }

    // ========== Wörter ordnen (Tap-to-Order Tiles) ==========
    if(Array.isArray(t.words)){
      const answers=Array.isArray(t.answer)?t.answer:[t.answer];
      const correct=(answers[0]||'').replace(/[.?!]$/,'').trim();
      const punct=answers[0]&&answers[0].slice(-1).match(/[.?!]/)?answers[0].slice(-1):'.';
      const allCorrectNorms=answers.map(a=>a.replace(/[.?!]$/,'').trim().toLowerCase());
      function checkOrder(arr){return allCorrectNorms.includes(arr.join(' ').toLowerCase());}
      let mixed=shuffle([...t.words]);
      let tries=0;
      while(checkOrder(mixed)&&tries<20){mixed=shuffle([...t.words]);tries++;}
      // Fallback: garantiert eine andere Reihenfolge erzwingen
      if(checkOrder(mixed)&&mixed.length>=2){
        // Suche zwei benachbarte Positionen deren Tausch die Lösung bricht
        let swapped=false;
        for(let i=0;i<mixed.length-1&&!swapped;i++){
          const test=[...mixed];[test[i],test[i+1]]=[test[i+1],test[i]];
          if(!checkOrder(test)){mixed=test;swapped=true;}
        }
        // Letzter Ausweg: letztes Wort an den Anfang
        if(!swapped){mixed=[mixed[mixed.length-1],...mixed.slice(0,mixed.length-1)];}
      }

      const prompt=document.createElement("p");prompt.className="prompt";prompt.textContent=(t.label||'Ordne')+': Tippe die Wörter in der richtigen Reihenfolge an.';
      wrap.appendChild(prompt);

      const input=document.createElement("input");input.type="hidden";input.id=`${sectionKey}-input-${idx}`;
      if(isSolved){input._correct=true;input._done=true;}
      wrap.appendChild(input);

      const sourceLabel=document.createElement("div");sourceLabel.className="word-tiles-label";sourceLabel.textContent="Verfügbare Wörter:";
      const source=document.createElement("div");source.className="word-tiles wt-source";
      const targetLabel=document.createElement("div");targetLabel.className="word-tiles-label";targetLabel.style.marginTop="10px";targetLabel.textContent="Dein Satz:";
      const target=document.createElement("div");target.className="word-tiles wt-target";
      const feedback=document.createElement("div");feedback.className="feedback";
      const controls=document.createElement("div");controls.className="controls";
      const checkBtn=document.createElement("button");checkBtn.className="btn primary";checkBtn.textContent="Prüfen";
      const clearBtn=document.createElement("button");clearBtn.className="btn ghost";clearBtn.textContent="Zurücksetzen";
      const solBtn=document.createElement("button");solBtn.className="btn ghost";solBtn.textContent="Lösung";solBtn.style.display='none';
      const solBox=document.createElement("div");solBox.className="solution";
      controls.appendChild(checkBtn);controls.appendChild(clearBtn);
      if(enableSolution)controls.appendChild(solBtn);

      const placed=[];
      const srcTiles=[];
      const tgtTiles=[];
      let locked=false;
      let failCount=0;

      mixed.forEach((word,wi)=>{
        const tile=document.createElement("button");tile.className="word-tile";tile.type="button";tile.textContent=word;tile.dataset.idx=wi;
        tile.addEventListener('click',()=>{
          if(locked)return;
          tile.classList.add('wt-used');
          placed.push({word,srcIdx:wi});
          const pt=document.createElement("button");pt.className="word-tile wt-placed";pt.type="button";pt.textContent=word;
          pt.addEventListener('click',()=>{
            if(locked)return;
            const pi=placed.findIndex(p=>p.srcIdx===wi);
            if(pi>-1)placed.splice(pi,1);
            tile.classList.remove('wt-used');
            pt.remove();
            updateTgtTiles();
          });
          target.appendChild(pt);
          updateTgtTiles();
        });
        source.appendChild(tile);
        srcTiles.push(tile);
      });

      function updateTgtTiles(){
        tgtTiles.length=0;
        target.querySelectorAll('.word-tile').forEach(t=>tgtTiles.push(t));
      }

      const notify=()=>{if(typeof onStatusChange==='function')onStatusChange();};

      function checkTiles(){
        if(locked)return input._correct;
        if(placed.length===0){feedback.textContent="Bitte ordne die Wörter.";feedback.className="feedback warn";return false;}
        const userSentence=placed.map(p=>p.word).join(' ');
        const userNorm=normalizeAnswer(userSentence);
        const okSet=answers.map(normalizeAnswer);
        if(okSet.some(a=>a===userNorm)){
          feedback.textContent="✓ Richtig!";feedback.className="feedback ok";
          input._correct=true;input._done=true;locked=true;
          tgtTiles.forEach(t=>{t.classList.remove('wt-placed');t.classList.add('wt-correct');});
          // Satzzeichen anhängen
          const punctTile=document.createElement('span');
          punctTile.textContent=punct;
          punctTile.style.cssText='font-size:22px;font-weight:800;color:#14532d;align-self:center;line-height:1;padding-left:2px;';
          target.appendChild(punctTile);
          if(!isSolved){const updated=[...solvedTasks,tHash];saveProgress(progressKey,updated);savedAnswers[tHash]=userSentence+punct;saveProgress(answersKey,savedAnswers);wrap.classList.add('task--solved');solvedLabel.innerHTML=`✓ Bereits gelöst: <i>${userSentence}${punct}</i>`;}
          notify();return true;
        }else{
          failCount++;
          const hint=analyzeError(userSentence,answers);
          if(hint&&failCount<=2){feedback.innerHTML=`✗ Das passt noch nicht. ${hint}`;feedback.className="feedback bad";}
          else{feedback.textContent="✗ Das passt noch nicht. Versuche es erneut.";feedback.className="feedback bad";}
          tgtTiles.forEach(t=>{t.classList.add('wt-wrong');setTimeout(()=>t.classList.remove('wt-wrong'),500);});
          if(enableSolution&&failCount>=2)solBtn.style.display="inline-flex";
          input._correct=false;notify();return false;
        }
      }
      checkBtn.addEventListener('click',()=>checkTiles());
      clearBtn.addEventListener('click',()=>{
        if(locked)return;
        placed.length=0;target.innerHTML='';tgtTiles.length=0;
        srcTiles.forEach(t=>t.classList.remove('wt-used'));
        feedback.textContent='';feedback.className='feedback';
      });
      solBtn.addEventListener('click',()=>{
        input._done=true;notify();solBox.style.display='block';locked=true;
        solBox.innerHTML=`<b>Lösung:</b> ${answers[0]||''}`;
      });

      wrap.appendChild(sourceLabel);wrap.appendChild(source);
      wrap.appendChild(targetLabel);wrap.appendChild(target);
      wrap.appendChild(controls);wrap.appendChild(feedback);wrap.appendChild(solBox);
      container.appendChild(wrap);
      input._check=checkTiles;
      input._reset=()=>{locked=false;placed.length=0;target.innerHTML='';tgtTiles.length=0;srcTiles.forEach(t=>t.classList.remove('wt-used'));input._correct=false;input._done=false;failCount=0;feedback.textContent='';feedback.className='feedback';solBtn.style.display='none';solBox.style.display='none';solBox.textContent='';solvedLabel.textContent='';wrap.classList.remove('task--solved');notify();};
      return;
    }

    // ========== Freitext-Aufgabe ==========
    let promptHTML=t.prompt||"";
    const prompt=document.createElement("p");prompt.className="prompt";prompt.innerHTML=promptHTML;
    const input=document.createElement("input");input.type="text";input.id=`${sectionKey}-input-${idx}`;input.setAttribute("aria-label","Antwort eingeben");input.placeholder="Schreib den Satz hier …";
    
    if(isSolved){input._correct=true;input._done=true;}
    const controls=document.createElement("div");controls.className="controls";
    const checkBtn=document.createElement("button");checkBtn.className="btn primary";checkBtn.textContent="Prüfen";
    const solBtn=document.createElement("button");solBtn.className="btn ghost";solBtn.textContent="Lösung anzeigen";solBtn.style.display='none';
    const feedback=document.createElement("div");feedback.className="feedback";
    const solBox=document.createElement("div");solBox.className="solution";
    controls.appendChild(checkBtn);
    if(enableSolution)controls.appendChild(solBtn);
    wrap.appendChild(prompt);wrap.appendChild(input);wrap.appendChild(controls);wrap.appendChild(feedback);wrap.appendChild(solBox);
    container.appendChild(wrap);
    const answers=Array.isArray(t.answer)?t.answer:[t.answer];
    const notify=()=>{if(typeof onStatusChange==='function')onStatusChange();};
    let failCount=0;
    function checkOne(batchMode){
      const user=normalizeAnswer(input.value);
      const okSet=answers.map(normalizeAnswer);
      if(!user){feedback.textContent="Bitte gib eine Lösung ein.";feedback.className="feedback warn";input._correct=false;notify();return false;}
      if(okSet.some(a=>a===user)){
        feedback.textContent="✓ Richtig!";feedback.className="feedback ok";
        input._correct=true;input._done=true;failCount=0;
        if(!isSolved){
          const updated=[...solvedTasks,tHash];
          saveProgress(progressKey,updated);
          savedAnswers[tHash]=input.value.trim();
          saveProgress(answersKey,savedAnswers);
          wrap.classList.add('task--solved');
          solvedLabel.innerHTML=`✓ Bereits gelöst: <i>${input.value.trim()}</i>`;
        }
        notify();
        if(!batchMode){const all=Array.from(container.querySelectorAll("input[type='text']"));const next=all[all.indexOf(input)+1];if(next)setTimeout(()=>{next.focus();next.scrollIntoView({behavior:'smooth',block:'nearest'});},150);}
        return true;
      }
      failCount++;
      // Fehleranalyse
      const hint=analyzeError(input.value,answers);
      if(hint&&failCount<=2){feedback.innerHTML=`✗ Das passt noch nicht. ${hint}`;feedback.className="feedback bad";}
      else{feedback.textContent="✗ Das passt noch nicht. Versuche es erneut.";feedback.className="feedback bad";}
      if(enableSolution&&failCount>=2)solBtn.style.display="inline-flex";
      input._correct=false;notify();return false;
    }
    checkBtn.addEventListener("click",()=>checkOne(false));
    input.addEventListener("keydown",(e)=>{if(e.key==="Enter"){e.preventDefault();checkOne(false);}});
    solBtn.addEventListener("click",()=>{
      input._done=true;notify();solBox.style.display="block";
      let html=`<b>Lösung:</b> ${answers[0]||''}`;
      if(t.explanation){html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">${t.explanation}</div>`;}
      else{
        const ans=(answers[0]||'').toLowerCase();
        if(/(does not|doesn't)/.test(ans))html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>Verneinung he/she/it:</b> Subjekt + <b>does not / doesn't</b> + Verb (Grundform – kein -s!)</div>`;
        else if(/(do not|don't)/.test(ans))html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>Verneinung:</b> Subjekt + <b>don't</b> + Verb (Grundform)</div>`;
        else if(/^does /.test(ans))html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>Frage he/she/it:</b> <b>Does</b> + Subjekt + Verb (Grundform)?</div>`;
        else if(/^do /.test(ans))html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>Frage:</b> <b>Do</b> + Subjekt + Verb (Grundform)?</div>`;
        else if(/^(where|when|what|who|how|why)/.test(ans))html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>W-Frage:</b> W-Wort + <b>do/does</b> + Subjekt + Verb (Grundform)?</div>`;
        else html+=`<div style="margin-top:6px;font-size:13px;color:#7a5c3a;">💡 <b>Grundregel:</b> he/she/it → Verb + <b>s/es</b>; alle anderen → Verb (Grundform)</div>`;
      }
      solBox.innerHTML=html;
      // TTS-Button für Lösung
      if(typeof TTS!=='undefined'&&TTS.enabled){const ans=answers[0]||'';const sb=TTS.createBtn(ans,'en-GB','font-size:14px;margin-left:6px;');const bEl=solBox.querySelector('b');if(bEl)bEl.insertAdjacentElement('afterend',sb);}
    });
    input._check=checkOne;
    input._reset=()=>{input.value="";input._correct=false;input._done=false;failCount=0;notify();feedback.textContent="";feedback.className="feedback";solBtn.style.display='none';solBox.style.display="none";solBox.textContent="";solvedLabel.textContent='';wrap.classList.remove('task--solved');};
  });
  // TTS-Buttons injizieren falls aktiviert
  if(typeof TTS!=='undefined'&&TTS.enabled)setTimeout(()=>TTS.injectAll(),50);
}
function setupSection(sectionKey,levelButtons,container,pools,checkAllBtn,resetBtn,enableSolution){
  const progressRoot=document.querySelector(`#${sectionKey}-progress .progress`);
  const progressCtrl=initProgressBar(progressRoot,15);
  let currentLevel=1;const levelCache={};
  function updateProgress(){
    const inputs=container.querySelectorAll(".task input");let correct=0,done=0;
    inputs.forEach(inp=>{if(inp._correct)correct++;if(inp._done)done++;});
    progressCtrl.update(correct,done);
    const total=inputs.length;
    const activeBtn=levelButtons.querySelector(`button[data-level="${currentLevel}"]`);
    if(activeBtn&&total>0){const base=activeBtn.dataset.label||activeBtn.textContent.replace(' ✓','');activeBtn.dataset.label=base;activeBtn.textContent=correct===total?base+' ✓':base;}
    if(correct===total&&total>0)checkCelebration(container,progressCtrl);
  }
  const renderLevel=(lvl)=>{
    currentLevel=lvl;
    levelButtons.querySelectorAll('button').forEach(b=>{const isActive=+b.dataset.level===lvl;b.classList.toggle('active',isActive);b.setAttribute('aria-pressed',isActive?'true':'false');if(!b.dataset.label)b.dataset.label=b.textContent.replace(' ✓','');});
    container.querySelectorAll('.result-banner').forEach(b=>b.remove());container.querySelectorAll('.error-list').forEach(b=>b.remove());
    if(!levelCache[lvl]){const pickKey=`${sectionKey}_L${lvl}`;const div=document.createElement('div');renderTasks(div,pickRandom(pools[lvl],15,pickKey),sectionKey,{enableSolution,onStatusChange:updateProgress,currentLevel:lvl});levelCache[lvl]=div;}
    Object.values(levelCache).forEach(div=>{if(div.parentNode===container)container.removeChild(div);});
    container.appendChild(levelCache[lvl]);
    progressCtrl.setTotal(levelCache[lvl].querySelectorAll(".task input").length);
    updateProgress();
    // "Alle prüfen" nur bei Levels mit Freitext-Aufgaben einblenden
    const hasFreitext=levelCache[lvl].querySelector('input[type="text"]')!==null;
    checkAllBtn.style.display=hasFreitext?'':'none';
  };
  levelButtons.addEventListener('click',(e)=>{const b=e.target.closest('button[data-level]');if(!b)return;renderLevel(+b.dataset.level);});
  checkAllBtn.addEventListener('click',()=>{
    const inputs=container.querySelectorAll(".task input");let ok=0,total=0;const wrongItems=[];
    inputs.forEach(inp=>{if(typeof inp._check==='function'){total++;if(inp._check(true))ok++;}});
    updateProgress();
    if(total>0){
      container.querySelectorAll('.result-banner').forEach(b=>b.remove());container.querySelectorAll('.error-list').forEach(b=>b.remove());
      inputs.forEach(inp=>{const wrap=inp.closest('.task');if(!wrap)return;if(inp._correct){wrap.classList.remove('task--wrong');}else if(inp.value&&inp.value.trim()){wrap.classList.add('task--wrong');const pEl=wrap.querySelector('.prompt');const nEl=wrap.querySelector('div[style*="color:#b8905a"]');wrongItems.push({num:nEl?nEl.textContent:'',prompt:pEl?pEl.textContent:'',userVal:inp.value.trim()});}});
      const pct=Math.round(ok/total*100);const banner=document.createElement('div');banner.className='result-banner';
      const col=pct===100?'#3d7a2e':pct>=60?'#b85c20':'#b83a22';const em=pct===100?'🏆':pct>=60?'👍':'💪';
      banner.style.cssText=`margin:10px 0 6px;padding:12px 16px;border-radius:12px;border:2px solid ${col};background:${col}18;font-size:15px;font-weight:700;color:${col};display:flex;align-items:center;gap:10px;`;
      banner.innerHTML=`<span style="font-size:22px">${em}</span><span>Ergebnis: <b>${ok} / ${total}</b> richtig (${pct}%)</span>`;
      container.prepend(banner);
      if(wrongItems.length>0){const el=document.createElement('div');el.className='error-list';el.style.cssText='margin:0 0 12px;padding:10px 14px;border-radius:10px;border:1px solid #fca5a5;background:#fff5f5;font-size:13px;';el.innerHTML=`<div style="font-weight:800;color:#b91c1c;margin-bottom:6px;">✗ Noch nicht richtig (${wrongItems.length}):</div>`+wrongItems.map(w=>`<div style="padding:3px 0;border-top:1px solid #fee2e2;color:#374151;"><span style="color:#9ca3af;font-size:11px;">${w.num}</span> <span>${w.prompt}</span></div>`).join('');container.insertBefore(el,banner.nextSibling);}
      setTimeout(()=>banner.scrollIntoView({behavior:'smooth',block:'nearest'}),80);
    }
  });
  resetBtn.addEventListener('click',()=>{customConfirm('Fortschritt zurücksetzen?',()=>{container.querySelectorAll('.result-banner,.celebrate-banner').forEach(b=>b.remove());container.querySelectorAll('.error-list').forEach(b=>b.remove());container.querySelectorAll('.task--wrong').forEach(t=>t.classList.remove('task--wrong'));container.querySelectorAll(".task input").forEach(inp=>{if(typeof inp._reset==='function')inp._reset();});[1,2,3].forEach(function(l){saveProgress(sectionKey+'_L'+l,[]);saveProgress(sectionKey+'_L'+l+'_ans',{});});updateProgress();});});
  const rerollBtn=document.getElementById(`${sectionKey}-reroll`);
  if(rerollBtn)rerollBtn.addEventListener('click',()=>{progressCtrl.resetAnimated();const old=levelCache[currentLevel];if(old&&old.parentNode===container)container.removeChild(old);delete levelCache[currentLevel];const pKey=`${sectionKey}_L${currentLevel}`;saveProgress('pick_'+pKey,null);saveProgress(pKey,[]);renderLevel(currentLevel);});
  renderLevel(1);
}

