function shuffle(arr){for(let i=arr.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[arr[i],arr[j]]=[arr[j],arr[i]];}return arr;}
function pickRandom(pool,n,storageKey){
  // Wenn storageKey vorhanden: gespeicherte Auswahl laden
  if(storageKey){
    const saved=loadProgress('pick_'+storageKey);
    if(saved&&Array.isArray(saved)&&saved.length===Math.min(n,pool.length)&&saved.every(i=>i>=0&&i<pool.length)){
      return saved.map(i=>pool[i]);
    }
  }
  const indices=Array.from({length:pool.length},(_,i)=>i);
  for(let i=indices.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[indices[i],indices[j]]=[indices[j],indices[i]];}
  const picked=indices.slice(0,Math.min(n,pool.length));
  if(storageKey)saveProgress('pick_'+storageKey,picked);
  return picked.map(i=>pool[i]);
}
function initProgressBar(progressRoot,total){
  const fill=progressRoot.querySelector('.progress-fill');
  const text=progressRoot.parentElement.querySelector('.progress-text');
  function update(correct,done){
    done=done!==undefined?done:correct;
    const fp=total?Math.round((done/total)*100):0;
    const rp=total?Math.round((correct/total)*100):0;
    fill.style.width=fp+'%';
    if(done===correct){text.textContent=`Fortschritt: ${correct}/${total} richtig (${rp}%)`;}
    else{text.textContent=`Fortschritt: ${correct}/${total} richtig · ${done} bearbeitet`;}
    progressRoot.setAttribute('aria-valuenow',String(fp));
    if(done===0){fill.style.background='';}
    else if(correct===total){fill.style.background='linear-gradient(90deg,#2e7d32,#43a047)';}
    else if(rp>=60){fill.style.background='';}
    else{fill.style.background='linear-gradient(90deg,#e65100,#ff8f00)';}
  }
  function setTotal(n){total=n;update(0,0);}
  function resetAnimated(){
    fill.style.transition='width .5s cubic-bezier(.4,0,.2,1)';
    fill.style.width='0%';
    fill.style.background='';
    text.textContent=`Fortschritt: 0/${total} richtig (0%)`;
    progressRoot.setAttribute('aria-valuenow','0');
    setTimeout(()=>{fill.style.transition='width .3s ease';},520);
  }
  update(0,0);
  return{update,setTotal,resetAnimated};
}
