function analyzeError(userInput, correctAnswers){
  const u=userInput.toLowerCase().trim();
  const c=(Array.isArray(correctAnswers)?correctAnswers[0]:correctAnswers).toLowerCase().trim();
  const hints=[];
  // don't vs doesn't
  if(/\b(he|she|it)\b/.test(c)&&/\bdon'?t\b/.test(u)&&/\bdoes(n'?t| not)\b/.test(c)){
    hints.push("Bei <b>he/she/it</b> brauchst du <b>doesn't</b>, nicht <i>don't</i>.");
  }
  if(/\b(i|you|we|they)\b/.test(c)&&/\bdoes(n'?t| not)\b/.test(u)&&/\bdo(n'?t| not)\b/.test(c)){
    hints.push("Bei <b>I/you/we/they</b> brauchst du <b>don't</b>, nicht <i>doesn't</i>.");
  }
  // Verb mit -s nach doesn't/don't
  if(/\b(doesn'?t|does not|don'?t|do not)\b/.test(u)){
    const afterAux=u.replace(/.*\b(doesn'?t|does not|don'?t|do not)\s+/,'');
    const firstWord=afterAux.split(/\s+/)[0]||'';
    if(/^(plays|watches|goes|does|studies|reads|gets|walks|takes|works|cooks|drives|writes|finishes|brushes|teaches|sends|draws|runs|helps|meets|cleans|listens|lives|speaks|eats|drinks|rides|visits|misses|forgets|buys|starts|arrives|sits|comes|sings)$/i.test(firstWord)){
      hints.push("Nach <b>don't/doesn't</b> kommt das Verb immer in der <b>Grundform</b> – ohne <i>-s</i>!");
    }
  }
  // Do/Does in Frage falsch
  if(/^do\b/.test(c)&&/^does\b/.test(u)){hints.push("Hier brauchst du <b>Do</b>, nicht <i>Does</i> (kein he/she/it-Subjekt).");}
  if(/^does\b/.test(c)&&/^do\b/.test(u)&&!/^do not/.test(u)){hints.push("Bei <b>he/she/it</b> beginnt die Frage mit <b>Does</b>, nicht <i>Do</i>.");}
  // Verb mit -s in Frage
  if(/^(do|does)\b/.test(u)){
    const parts=u.split(/\s+/);
    if(parts.length>=3){
      const verb=parts[2]||'';
      if(/(plays|watches|goes|does|studies|reads|gets|walks|takes|works|cooks|drives|finishes|brushes)$/i.test(verb)&&!/^does$/.test(verb)){
        hints.push("In einer Frage mit <b>Do/Does</b> steht das Verb immer in der <b>Grundform</b> – kein <i>-s</i>!");
      }
    }
  }
  // he/she/it ohne -s im Aussagesatz (kein don't/doesn't, kein Do/Does)
  if(!/\b(do(n'?t|es(n'?t)?| not)?)\b/.test(c)&&/\b(he|she|it)\b/.test(c)){
    const cVerb=c.replace(/^.*?\b(he|she|it)\s+/i,'').split(/\s+/)[0]||'';
    const uVerb=u.replace(/^.*?\b(he|she|it)\s+/i,'').split(/\s+/)[0]||'';
    if(cVerb!==uVerb&&cVerb.length>uVerb.length&&cVerb.startsWith(uVerb.substring(0,uVerb.length-1))){
      hints.push("Bei <b>he/she/it</b> bekommt das Verb ein <b>-s</b> oder <b>-es</b>!");
    }
  }
  return hints.length>0?'💡 '+hints[0]:null;
}

