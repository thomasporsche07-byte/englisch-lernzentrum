async function dictLookup() {
  const word = document.getElementById('dict-input').value.trim();
  if (!word) return;
  const btn = document.getElementById('dict-btn');
  const loading = document.getElementById('dict-loading');
  const result = document.getElementById('dict-result');
  const errEl = document.getElementById('dict-error');

  btn.disabled = true;
  loading.className = 'dict-loading visible';
  result.classList.remove('visible');
  errEl.className = 'dict-error';

  const cls = document.getElementById('sel-class').value;
  const ageHint = cls === '56' ? '10–12 Jahre, sehr einfache Sprache' : cls === '78' ? '12–15 Jahre, mittleres Niveau' : '14–17 Jahre';

  const prompt = `Ein Schüler (${ageHint}) schreibt einen englischen Text und sucht das englische Wort für: "${word}".
Antworte NUR mit einem JSON-Objekt, kein Text davor oder danach:
{
  "english": "<englisches Wort oder kurze Phrase>",
  "phonetic": "<einfache Aussprache-Hilfe, z.B. [sɪk'saɪtmənt]  – optional, weglassen wenn unnötig>",
  "german_alt": "<bis zu 2 weitere deutsche Bedeutungen, kommasepariert – nur wenn relevant, sonst leer>",
  "example": "<ein kurzer Beispielsatz auf Englisch, das gesuchte Wort in ** einschließen, z.B. 'She felt **excitement** before the game.'>",
  "example_de": "<deutsche Übersetzung des Beispielsatzes>"
}`;

  try {
    const res = await fetch(PROXY_URL, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        contents: [{role: 'user', parts: [{text: prompt}]}],
        generationConfig: {temperature: 0.1, maxOutputTokens: 300, responseMimeType: 'application/json', thinkingConfig: {thinkingBudget: 0}}
      })
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    const raw = (data?.candidates?.[0]?.content?.parts || []).map(p => p.text || '').join('').trim();
    const j = JSON.parse(raw.slice(raw.indexOf('{'), raw.lastIndexOf('}') + 1));

    document.getElementById('dict-word').textContent = j.english || '—';
    document.getElementById('dict-phonetic').textContent = j.phonetic || '';
    const altText = j.german_alt ? ` (auch: ${j.german_alt})` : '';
    document.getElementById('dict-translation').textContent = `🇩🇪 ${word}${altText}  →  🇬🇧 ${j.english}`;

    // Beispielsatz: **word** → fett + blau hervorheben
    const exampleHtml = (j.example || '').replace(/\*\*(.+?)\*\*/g, '<span>$1</span>');
    const exDe = j.example_de ? `<br><span style="opacity:.7;font-style:italic">${esc(j.example_de)}</span>` : '';
    document.getElementById('dict-example').innerHTML = `💬 ${exampleHtml}${exDe}`;

    result.classList.add('visible');
  } catch(e) {
    errEl.className = 'dict-error visible';
    errEl.textContent = '⚠ Konnte nicht übersetzt werden – bitte nochmal versuchen.';
  } finally {
    btn.disabled = false;
    loading.className = 'dict-loading';
  }
}

