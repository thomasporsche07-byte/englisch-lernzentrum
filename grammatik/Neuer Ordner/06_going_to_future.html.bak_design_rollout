function setupSimpleSection(sectionKey,container,pool,checkAllBtn,resetBtn){
  const progressRoot=document.querySelector('#'+sectionKey+'-progress .progress');
  const progressCtrl=initProgressBar(progressRoot,15);
  let cache=null;
  function updateProgress(){
    const inputs=container.querySelectorAll('.task input');let correct=0,done=0;
    inputs.forEach(inp=>{if(inp._correct)correct++;if(inp._done)done++;});
    progressCtrl.update(correct,done);
    if(correct===inputs.length&&inputs.length>0)checkCelebration(container,progressCtrl);
  }
  function render(){
    container.querySelectorAll('.result-banner,.error-list').forEach(b=>b.remove());
    const pickKey=sectionKey+'_L1';
    const div=document.createElement('div');
    renderTasks(div,pickRandom(pool,15,pickKey),sectionKey,{enableSolution:true,onStatusChange:updateProgress,currentLevel:1});
    cache=div;if(container.firstChild)container.innerHTML='';
    container.prepend(div);progressCtrl.setTotal(div.querySelectorAll('.task input').length);
    updateProgress();
    const hasFreitext=div.querySelector('input[type="text"]')!==null;
    checkAllBtn.style.display=hasFreitext?'':'none';
  }
  checkAllBtn.addEventListener('click',()=>{
    const inputs=container.querySelectorAll('.task input');let ok=0,total=0;const wrongItems=[];
    inputs.forEach(inp=>{if(typeof inp._check==='function'){total++;if(inp._check(true))ok++;}});
    updateProgress();
    if(total>0){
      container.querySelectorAll('.result-banner,.error-list').forEach(b=>b.remove());
      inputs.forEach(inp=>{const wrap=inp.closest('.task');if(!wrap)return;if(inp._correct){wrap.classList.remove('task--wrong');}else if(inp.value&&inp.value.trim()){wrap.classList.add('task--wrong');}});
      const pct=Math.round(ok/total*100);const banner=document.createElement('div');banner.className='result-banner';
      const col=pct===100?'#3d7a2e':pct>=60?'#b85c20':'#b83a22';const em=pct===100?'\U0001f3c6':pct>=60?'\U0001f44d':'\U0001f4aa';
      banner.style.cssText='margin:10px 0 6px;padding:12px 16px;border-radius:12px;border:2px solid '+col+';background:'+col+'18;font-size:15px;font-weight:700;color:'+col+';display:flex;align-items:center;gap:10px;';
      banner.innerHTML='<span style="font-size:22px">'+em+'</span><span>Ergebnis: <b>'+ok+' / '+total+'</b> richtig ('+pct+'%)</span>';
      container.prepend(banner);
      setTimeout(()=>banner.scrollIntoView({behavior:'smooth',block:'nearest'}),80);
    }
  });
  resetBtn.addEventListener('click',()=>{customConfirm('Fortschritt zur\u00fccksetzen?',()=>{container.querySelectorAll('.result-banner,.error-list').forEach(b=>b.remove());container.querySelectorAll('.task--wrong').forEach(t=>t.classList.remove('task--wrong'));container.querySelectorAll('.task input').forEach(inp=>{if(typeof inp._reset==='function')inp._reset();});saveProgress(sectionKey+'_L1',[]);saveProgress(sectionKey+'_L1_ans',{});saveProgress('pick_'+sectionKey+'_L1',null);updateProgress();});});
  const rerollBtn=document.getElementById(sectionKey+'-reroll');
  if(rerollBtn)rerollBtn.addEventListener('click',()=>{progressCtrl.resetAnimated();if(cache&&cache.parentNode===container)container.removeChild(cache);cache=null;const pKey=sectionKey+'_L1';saveProgress('pick_'+pKey,null);saveProgress(pKey,[]);saveProgress(pKey+'_ans',{});render();});
  render();
}

