// HELPER-FUNKTIONEN
function saveProgress(key,val){try{localStorage.setItem(key,JSON.stringify(val));}catch(e){}}
function loadProgress(key,def){try{const v=localStorage.getItem(key);return v?JSON.parse(v):def;}catch(e){return def;}}
function shuffle(arr){for(let i=arr.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[arr[i],arr[j]]=[arr[j],arr[i]];}return arr;}

function initProgressBar(el,total){
  const fill=el.querySelector('.progress-fill');
  const text=el.parentNode.querySelector('.progress-text');
  return{
    update(correct,total){
      const pct=total>0?Math.round(correct/total*100):0;
      if(fill)fill.style.width=pct+'%';
      if(text)text.textContent=`Fortschritt: ${correct}/${total} richtig (${pct}%)`;
    },
    setTotal(n){},
  };
}

function renderTask(task,idx,secKey){
  let html='<div class="task" id="task-'+secKey+'-'+idx+'">';
  if(task.type==='mc'){
    html+='<span class="task-type-badge badge-mc">Multiple Choice</span>';
    html+='<div class="prompt">'+task.prompt+'</div>';
    html+='<div class="mc-options">';
    task.options.forEach((opt,i)=>{
      const isCorrect=i===task.correct;
      html+='<div class="mc-opt" data-opt="'+i+'" data-correct="'+isCorrect+'" data-answer="'+task.answer+'"><span class="mc-letter">'+String.fromCharCode(65+i)+'</span><span>'+opt+'</span></div>';
    });
    html+='</div>';
  }else if(task.words){
    html+='<span class="task-type-badge badge-ordne">Wörter Ordnen</span>';
    html+='<div class="prompt">'+task.prompt+'</div>';
    html+='<div class="word-tiles-wrap">';
    html+='<div class="word-tiles-label">'+task.label+'</div>';
    html+='<div class="word-tiles wt-source" id="src-'+secKey+'-'+idx+'">';
    const shuffled=shuffle([...task.words]);
    shuffled.forEach(w=>{html+='<span class="word-tile" data-word="'+w+'">'+w+'</span>';});
    html+='</div>';
    html+='<div class="word-tiles wt-target" id="target-'+secKey+'-'+idx+'"></div>';
    html+='</div>';
  }else{
    html+='<span class="task-type-badge badge-frei">Freitext</span>';
    html+='<div class="prompt">'+task.prompt+'</div>';
    html+='<input type="text" class="task-input" placeholder="Antwort eingeben..." data-answer="'+JSON.stringify(task.answer).replace(/"/g,'&quot;')+'" />';
    if(task.explanation){html+='<div class="solution">'+task.explanation+'</div>';}
  }
  html+='<div class="controls" style="display:none;">';
  html+='<button class="btn blue task-check">Prüfen</button>';
  html+='<button class="btn ghost task-show">Lösung zeigen</button>';
  html+='</div>';
  html+='<div class="feedback"></div>';
  html+='</div>';
  return html;
}

function checkCelebration(container){
  const allTasks=container.querySelectorAll('.task');
  const solved=Array.from(allTasks).filter(t=>t.classList.contains('task--solved')).length;
  if(solved===allTasks.length){
    const banner=document.createElement('div');
    banner.className='celebrate-banner';
    banner.innerHTML='🎉 Perfekt! Du hast alles gelöst!';
    container.insertBefore(banner,container.firstChild);
    setTimeout(()=>banner.remove(),4000);
  }
}

function setupSection(secKey,lvlSwitch,tasksDiv,pools,checkAllBtn,resetBtn,isMultiLevel){
  let currentLevel=1;
  let taskStates={};
  const savedStates=loadProgress(secKey+'_states',{});
  Object.assign(taskStates,savedStates);

  function renderTasks(){
    tasksDiv.innerHTML='';
    const pool=pools[currentLevel]||[];
    const PICK=15;
    const shuffled=pool.slice();
    for(let i=shuffled.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[shuffled[i],shuffled[j]]=[shuffled[j],shuffled[i]];}
    const picked=shuffled.slice(0,Math.min(PICK,shuffled.length));
    picked.forEach((task,idx)=>{
      const taskId=currentLevel+'-'+idx;
      tasksDiv.innerHTML+=renderTask(task,idx,secKey);
      const taskEl=tasksDiv.querySelector('#task-'+secKey+'-'+idx);
      if(taskStates[taskId]==='solved')taskEl.classList.add('task--solved');

      const checkBtn=taskEl.querySelector('.task-check');
      const showBtn=taskEl.querySelector('.task-show');
      const feedback=taskEl.querySelector('.feedback');
      const input=taskEl.querySelector('.task-input');

      if(task.type==='mc'){
        const opts=taskEl.querySelectorAll('.mc-opt');
        opts.forEach(o=>{
          o.addEventListener('click',()=>{
            if(taskEl.classList.contains('task--solved'))return;
            opts.forEach(x=>x.classList.remove('mc-selected','mc-correct','mc-wrong'));
            o.classList.add('mc-selected');
            checkBtn.style.display='flex';
          });
        });
        checkBtn?.addEventListener('click',()=>{
          const sel=taskEl.querySelector('.mc-opt.mc-selected');
          if(!sel)return;
          const correct=sel.dataset.correct==='true';
          opts.forEach(x=>x.disabled=true);
          if(correct){
            sel.classList.add('mc-correct');
            feedback.textContent='✓ Richtig!';
            feedback.className='feedback ok';
            taskEl.classList.add('task--solved');
            taskStates[taskId]='solved';
            saveProgress(secKey+'_states',taskStates);
          }else{
            sel.classList.add('mc-wrong');
            const corrOpt=Array.from(opts).find(x=>x.dataset.correct==='true');
            if(corrOpt)corrOpt.classList.add('mc-correct');
            feedback.innerHTML='✗ Falsch! Richtig: <b>'+corrOpt?.textContent+'</b>';
            feedback.className='feedback bad';
          }
          updateProgress();
          setTimeout(()=>checkCelebration(tasksDiv),300);
        });
      }else if(task.words){
        const src=taskEl.querySelector('#src-'+secKey+'-'+idx);
        const target=taskEl.querySelector('#target-'+secKey+'-'+idx);
        src.querySelectorAll('.word-tile').forEach(tile=>{
          tile.addEventListener('click',()=>{
            if(tile.classList.contains('wt-used')||tile.classList.contains('wt-correct'))return;
            tile.classList.toggle('wt-placed');
            if(tile.classList.contains('wt-placed')){
              target.appendChild(tile.cloneNode(true));
              tile.classList.add('wt-used');
              const cloned=target.querySelector('.word-tile:last-child');
              cloned.classList.remove('wt-placed','wt-used');
              cloned.addEventListener('click',()=>{
                src.appendChild(cloned);
                tile.classList.remove('wt-used','wt-placed');
                cloned.remove();
              });
            }
          });
        });
        checkBtn?.addEventListener('click',()=>{
          if(taskEl.classList.contains('task--solved'))return;
          const ordered=Array.from(target.querySelectorAll('.word-tile')).map(t=>t.textContent.trim());
          const isCorrect=ordered.join(',')===task.answer.join(',');
          if(isCorrect){
            feedback.textContent='✓ Richtig!';
            feedback.className='feedback ok';
            taskEl.classList.add('task--solved');
            taskStates[taskId]='solved';
            saveProgress(secKey+'_states',taskStates);
            Array.from(target.querySelectorAll('.word-tile')).forEach(t=>{t.classList.add('wt-correct');t.disabled=true;});
          }else{
            feedback.innerHTML='✗ Falsch! Richtig: <b>'+task.answer.join(' ')+'</b>';
            feedback.className='feedback bad';
          }
          updateProgress();
          setTimeout(()=>checkCelebration(tasksDiv),300);
        });
      }else{
        checkBtn?.addEventListener('click',()=>{
          if(taskEl.classList.contains('task--solved'))return;
          const val=input.value.trim().toLowerCase();
          const correct=task.answer.map(a=>a.toLowerCase());
          const isCorrect=correct.includes(val);
          if(isCorrect){
            feedback.textContent='✓ Richtig!';
            feedback.className='feedback ok';
            input.disabled=true;
            taskEl.classList.add('task--solved');
            taskStates[taskId]='solved';
            saveProgress(secKey+'_states',taskStates);
          }else{
            feedback.innerHTML='✗ Falsch! Lösung: <b>'+task.answer.join(' / ')+'</b>';
            feedback.className='feedback bad';
          }
          updateProgress();
          setTimeout(()=>checkCelebration(tasksDiv),300);
        });
        showBtn?.addEventListener('click',()=>{
          taskEl.querySelector('.solution').style.display='block';
        });
      }
    });
  }

  function updateProgress(){
    const all=tasksDiv.querySelectorAll('.task');
    const solved=tasksDiv.querySelectorAll('.task.task--solved').length;
    const pct=all.length>0?Math.round(solved/all.length*100):0;
    const prog=lvlSwitch.parentNode.parentNode.querySelector('.progress-fill');
    const txt=lvlSwitch.parentNode.parentNode.querySelector('.progress-text');
    if(prog)prog.style.width=pct+'%';
    if(txt)txt.textContent=`Fortschritt: ${solved}/${all.length} richtig (${pct}%)`;
  }

  if(isMultiLevel&&lvlSwitch){
    lvlSwitch.querySelectorAll('.level-btn').forEach(btn=>{
      btn.addEventListener('click',()=>{
        lvlSwitch.querySelectorAll('.level-btn').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
        currentLevel=+btn.dataset.level;
        renderTasks();
        updateProgress();
      });
    });
  }

  checkAllBtn?.addEventListener('click',()=>{
    tasksDiv.querySelectorAll('.task-check').forEach(btn=>btn.click());
    const prog=lvlSwitch.parentNode.parentNode.querySelector('.progress');
    const txt=lvlSwitch.parentNode.parentNode.querySelector('.progress-text');
    const all=tasksDiv.querySelectorAll('.task');
    const solved=tasksDiv.querySelectorAll('.task.task--solved').length;
    const pct=all.length>0?Math.round(solved/all.length*100):0;
    const bannerClass=pct===100?'result-green':pct>=70?'result-orange':'result-red';
    const banner=document.createElement('div');
    banner.className='result-banner '+bannerClass;
    banner.innerHTML=(pct===100?'✅ Alle gelöst!':pct>=70?'🟡 Guter Fortschritt':'🔴 Noch üben')+' – '+solved+'/'+all.length+' richtig ('+pct+'%)';
    const errorList=document.createElement('div');
    errorList.className='error-list';
    tasksDiv.querySelectorAll('.task.task--wrong').forEach(t=>{
      errorList.innerHTML+='<li>Fehler: '+t.querySelector('.prompt')?.textContent.substring(0,60)+'...</li>';
    });
    tasksDiv.insertBefore(banner,tasksDiv.firstChild);
    if(errorList.querySelectorAll('li').length)tasksDiv.insertBefore(errorList,banner.nextSibling);
  });

  resetBtn?.addEventListener('click',()=>{
    taskStates={};
    saveProgress(secKey+'_states',{});
    renderTasks();
    updateProgress();
    tasksDiv.querySelectorAll('.result-banner,.result-banner,.celebrate-banner,.error-list').forEach(el=>el.remove());
  });

  renderTasks();
}

