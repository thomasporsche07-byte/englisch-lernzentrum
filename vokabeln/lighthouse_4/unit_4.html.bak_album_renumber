function normalizeAnswer(t){if(!t)return"";let s=(""+t).toLowerCase();s=s.replace(/[\u0027\u00B4\u2018\u2019\u2032\u0060`´]/g,"'");s=s.replace(/[.,!?:;"]+/g," ").replace(/\s+/g," ").trim();s=s.normalize("NFD").replace(/[\u0300-\u036f]/g,"");return s;}
function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function pickRandom(p,n){return shuffle([...p]).slice(0,Math.min(n,p.length));}
function highlightKeys(text,keyStr){if(!keyStr)return text;let h=text;keyStr.split('|').forEach(k=>{const r=new RegExp('('+k.trim().replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','i');h=h.replace(r,'<span class="hint-key">$1</span>');});return h;}
function initProgressBar(root,total,storageKey){const fill=root.querySelector('.progress-fill');const text=root.parentElement.querySelector('.progress-text');const PB_PREFIX='pb_'+PAGE_TITLE.replace(/[^a-zA-Z0-9]/g,'_')+'_';function save(c,t){if(!storageKey)return;try{localStorage.setItem(PB_PREFIX+storageKey,JSON.stringify({c,t}));}catch(e){}}function load(){if(!storageKey)return null;try{return JSON.parse(localStorage.getItem(PB_PREFIX+storageKey));}catch(e){return null;}}function render(c,d,t){const fp=t?Math.round((d/t)*100):0;const rp=t?Math.round((c/t)*100):0;fill.style.width=fp+'%';text.textContent=d===c?'Fortschritt: '+c+'/'+t+' richtig ('+rp+'%)':'Fortschritt: '+c+'/'+t+' richtig · '+d+' bearbeitet';if(d===0)fill.style.background='';else if(c===t)fill.style.background='linear-gradient(90deg,#2e7d32,#43a047)';else if(rp<60)fill.style.background='linear-gradient(90deg,#e65100,#ff8f00)';else fill.style.background='';}function update(c,d){d=d!==undefined?d:c;render(c,d,total);if(d===total&&total>0)save(c,total);}function setTotal(n){total=n;update(0,0);}const saved=load();if(saved&&saved.t>0){total=saved.t;render(saved.c,saved.t,saved.t);}else{update(0,0);}return{update,setTotal};}

function getPool(topic){return topic==='all'?[...VOCAB]:VOCAB.filter(v=>v.t===topic);}
function toGap(v){return{sentence:v.s,hint:v.h,key:v.k,answer:v.ans||v.en,de:v.de,__key:v.en};}
function toMatch(v){return{english:v.mEn||v.en,german:v.de,__key:v.en};}
const allAnswers=[...new Set(VOCAB.map(v=>{const a=v.ans||v.en;return Array.isArray(a)?a[0]:a;}))];
const allBaseAnswers=[...new Set(VOCAB.map(v=>v.en))];

function buildTopicButtons(id){const c=document.getElementById(id);if(!c)return;c.innerHTML='<button data-topic="all" class="active">Alle</button>';TOPICS.forEach(t=>{const b=document.createElement('button');b.dataset.topic=t.id;b.textContent=t.label;c.appendChild(b);});}
function updatePoolHint(id,shown,poolSize){const el=document.getElementById(id);if(!el)return;if(shown<poolSize){el.textContent=`🎲 ${shown} von ${poolSize} Vokabeln zufällig ausgewählt – „Neu würfeln" für andere`;}else{el.textContent='';}}

// ── TTS ──
function speak(text,lang){const u=new SpeechSynthesisUtterance(text.replace(/<[^>]*>/g,''));u.lang=lang||'de-DE';u.rate=0.9;speechSynthesis.cancel();speechSynthesis.speak(u);return u;}
function makeTtsBtn(text,lang,mini){const b=document.createElement('button');b.className='tts-btn'+(mini?' tts-mini':'');b.title='Vorlesen';b.textContent='🔊';b.addEventListener('click',e=>{e.stopPropagation();b.classList.add('speaking');const u=speak(text,lang);u.onend=()=>b.classList.remove('speaking');});return b;}


