    const txtBox=document.createElement('div');txtBox.className='read-text';txtBox.innerHTML=t.text;
    wrap.appendChild(txtBox);
    let totalCorrect=0,totalItems=0;
    // T/F/NG
    const tfHead=document.createElement('h4');tfHead.style.cssText='color:var(--info);margin:14px 0 8px';tfHead.innerHTML='✓✗ True / False / Not given';wrap.appendChild(tfHead);
    const tfList=document.createElement('div');tfList.className='tf-list';
    t.aufgaben.tf.forEach((it,ii)=>{
      const row=document.createElement('div');row.className='tf-row';
      row.innerHTML='<div class="tf-stmt">'+(ii+1)+'. '+it.s+'</div>';
      const btns=document.createElement('div');btns.className='tf-btns';
      ['True','False','Not given'].forEach((label)=>{
        const b=document.createElement('button');b.className='mc-opt tf-btn';b.textContent=label;
        b.onclick=()=>{
          if(row.dataset.done)return;
          row.dataset.done='1';
          const want=it.a;
          const ok=(label.toLowerCase().replace(' ','')===want.toLowerCase().replace(' ',''));
          b.classList.add(ok?'correct':'wrong');
          if(!ok){btns.querySelectorAll('.tf-btn').forEach(x=>{if(x.textContent.toLowerCase().replace(' ','')===want.toLowerCase().replace(' ',''))x.classList.add('correct');});}
          const fb=document.createElement('div');fb.className='feedback '+(ok?'ok':'bad');fb.style.fontSize='13px';fb.innerHTML=(ok?'✅ ':'❌ Korrekt: '+want+'. ')+(it.why||'');
          row.appendChild(fb);
          if(ok)totalCorrect++;
          totalItems++;updScore();
        };
        btns.appendChild(b);
      });
      row.appendChild(btns);
      tfList.appendChild(row);
    });
    wrap.appendChild(tfList);
    // MC
    const mcHead=document.createElement('h4');mcHead.style.cssText='color:var(--accent-strong);margin:14px 0 8px';mcHead.innerHTML='🅰 Multiple Choice';wrap.appendChild(mcHead);
    t.aufgaben.mc.forEach((q,qi)=>{
      const card=document.createElement('div');card.className='task';card.style.margin='8px 0';card.style.padding='10px 14px';
      card.innerHTML='<div class="task-prompt" style="font-size:14px"><span class="task-num">'+(qi+1)+'</span>'+q.prompt+'</div>';
      const opts=document.createElement('div');opts.className='mc-options';
      q.options.forEach((o,oi)=>{
        const b=document.createElement('button');b.className='mc-opt';b.textContent=o;
        b.onclick=()=>{
          if(card.dataset.done)return;
          card.dataset.done='1';
          const ok=(oi===q.correct);
          b.classList.add(ok?'correct':'wrong');
          if(!ok)opts.children[q.correct].classList.add('correct');
          if(ok)totalCorrect++;
          totalItems++;updScore();
        };
        opts.appendChild(b);
      });
      card.appendChild(opts);
      wrap.appendChild(card);
    });
    // Open
    const opHead=document.createElement('h4');opHead.style.cssText='color:var(--success);margin:14px 0 8px';opHead.innerHTML='✏️ Offene Fragen';wrap.appendChild(opHead);
    t.aufgaben.open.forEach((q,qi)=>{
      const card=document.createElement('div');card.className='task';card.style.margin='8px 0';card.style.padding='10px 14px';
      card.innerHTML='<div class="task-prompt" style="font-size:14px"><span class="task-num">'+(qi+1)+'</span>'+q.prompt+'</div>';
      const w2=document.createElement('div');w2.className='ft-wrap';
      const inp=document.createElement('input');inp.type='text';inp.className='ft-input';inp.placeholder='Stichwort/Phrase…';
      const cb=document.createElement('button');cb.className='btn';cb.textContent='Prüfen';
      const sb=document.createElement('button');sb.className='btn gray';sb.textContent='Lösung';
      w2.appendChild(inp);w2.appendChild(cb);w2.appendChild(sb);
      card.appendChild(w2);
      const fb=document.createElement('div');fb.className='feedback';card.appendChild(fb);
      cb.onclick=()=>{
        if(card.dataset.done)return;
        const ok=isCorrect(inp.value,q.answer);
        if(ok){card.dataset.done='1';fb.classList.add('ok');fb.innerHTML='✅ Richtig!';inp.disabled=true;totalCorrect++;totalItems++;updScore();}
        else{fb.classList.remove('ok');fb.classList.add('bad');fb.innerHTML='❌ '+(q.hint||'Versuche es nochmal.');}
      };
      sb.onclick=()=>{const a=Array.isArray(q.answer)?q.answer[0]:q.answer;inp.value=a;fb.classList.add('ok');fb.innerHTML='💡 Lösung: <b>'+a+'</b>';card.dataset.done='1';inp.disabled=true;totalItems++;updScore();};
      inp.addEventListener('keydown',e=>{if(e.key==='Enter')cb.click();});
      wrap.appendChild(card);
    });
    // Score per text
    const scoreBox=document.createElement('div');scoreBox.style.cssText='margin-top:14px;padding:12px 16px;background:var(--accent-soft);border-radius:10px;text-align:center;font-weight:700';
    scoreBox.id='lv-score-'+t.id;scoreBox.innerHTML='Bearbeite die Aufgaben — dann erscheint hier die Note.';
    wrap.appendChild(scoreBox);
    function updScore(){
      const total=t.aufgaben.tf.length+t.aufgaben.mc.length+t.aufgaben.open.length;
      const pct=Math.round(totalCorrect/total*100);
      let note='';
      if(pct>=85)note='🏆 sehr gut (1)';
      else if(pct>=70)note='👍 gut (2)';
      else if(pct>=55)note='👌 befriedigend (3)';
      else if(pct>=40)note='📚 ausreichend (4)';
      else note='📖 mangelhaft (5)';
      scoreBox.innerHTML=note+' · '+totalCorrect+' von '+total+' Punkten ('+pct+'%)';
    }
    list.appendChild(wrap);
  });
}

