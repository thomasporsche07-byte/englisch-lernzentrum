  const maxY=480;
  aliens.forEach(a=>{
    if(a.done)return;
    a.speed+=0.004; // gradual acceleration
    a.y+=a.speed;
    a.el.style.top=a.y+'px';
    if(a.y>=maxY) failAlien(a);
  });
  // Check if lowest alien changed – refresh choices if so
  const lowest=getLowestAlien();
  if(lowest&&lowest!==currentTarget) showChoicesForLowest();
}

