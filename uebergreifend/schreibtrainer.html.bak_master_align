function buildInlineView(errors, rawText) {
  const container=document.getElementById('error-inline');
  if(!errors.length){container.innerHTML='';return;}
  let html=rawText;
  const used=new Set();
  errors.forEach((e,i)=>{
    if(!e.original)return;
    const orig=e.original.trim();
    if(used.has(orig))return;
    used.add(orig);
    const type=e.type||'grammar';
    const escaped=orig.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
    const explanation = (e.explanation||'').replace(/'/g,'&#39;').replace(/"/g,'&quot;');
    const marker=`<span style="position:relative;display:inline"><span class="inline-error-num ${type}" onclick="showTooltip(this,'${explanation}')" title="${explanation}">${i+1}</span><span class="inline-strike">${esc(orig)}</span><span class="inline-fix">→ ${esc(e.correction)}</span></span>`;
    html=html.replace(new RegExp(escaped),marker);
  });
  html=html.replace(/\n/g,'<br>');
  const legend=errors.map((e,i)=>{const type=e.type||'grammar';return `<div class="inline-legend-item ${type}"><div class="inline-legend-num ${type}">${i+1}</div><div class="inline-legend-text"><div class="inline-legend-change"><span class="leg-orig">${esc(e.original)}</span><span class="leg-arr">→</span><span class="leg-fix">${esc(e.correction)}</span></div><div class="inline-legend-explain">${esc(e.explanation)}</div></div></div>`;}).join('');
  container.innerHTML=`<div class="inline-text">${html}</div><div class="inline-legend">${legend}</div>`;
}

function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

