  };

  const starsMap = v => Array.from({length:5},(_,i)=>`<span style='opacity:${i<v?1:.2}'>★</span>`).join('');
  const keys = cls === '56'
    ? ['inhalt','orthographie','ausdruck','grammatik']
    : ['inhalt','orthographie','ausdruck','grammatik','textgestaltung'];

  // Gradient palette: blue → teal → green → amber → rose
  const palette = [
    {bg:'#eff6ff',border:'#93c5fd'},
    {bg:'#f0fdfa',border:'#5eead4'},
    {bg:'#f0fdf4',border:'#86efac'},
    {bg:'#fffbeb',border:'#fcd34d'},
    {bg:'#fff1f2',border:'#fda4af'},
  ];

  grid.innerHTML = keys.map((k, idx) => {
    const v = scores[k] || 3;
    const meta = labels[k];
    const sc = 's' + v;
    const barW = (v / 5 * 100).toFixed(0);
    const pal = palette[idx % palette.length];
    return `<div class="subscore-item ${sc}" style="background:${pal.bg};border-color:${pal.border}">
      <div class="subscore-label">${meta.icon} ${meta.label}</div>
      <div class="subscore-bar-wrap"><div class="subscore-bar ${sc}" style="width:${barW}%"></div></div>
      <div class="subscore-stars">${starsMap(v)}</div>
      <div class="subscore-note">${meta.note}</div>
    </div>`;
  }).join('');

  card.style.display = 'block';
}

