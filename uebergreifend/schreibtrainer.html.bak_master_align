/* ── Score-Banner Animation ── */
@keyframes scoreSlideIn{from{opacity:0;transform:translateY(-18px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.score-banner.animate{animation:scoreSlideIn .45s cubic-bezier(.22,1,.36,1) forwards}

/* ── Konfetti ── */
.confetti-wrap{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;overflow:hidden}
@keyframes confettiFall{0%{transform:translateY(-20px) rotate(0deg);opacity:1}100%{transform:translateY(100vh) rotate(720deg);opacity:0}}
.confetti-piece{position:absolute;width:10px;height:10px;border-radius:2px;animation:confettiFall linear forwards}

/* ── Tipp-Animation ── */
@keyframes textPulse{0%,100%{box-shadow:0 0 0 3px rgba(21,101,192,.15)}50%{box-shadow:0 0 0 6px rgba(21,101,192,.25)}}
textarea#student-text.loading{animation:textPulse 1.2s ease-in-out infinite}

/* ── Streak-Banner ── */
.streak-banner{background:linear-gradient(135deg,#fff7ed,#ffedd5);border:2px solid #fed7aa;border-radius:14px;padding:12px 18px;margin-bottom:14px;display:flex;align-items:center;gap:12px;font-size:15px;font-weight:800;color:#c2410c}
body.dark-mode .streak-banner{background:#1c0a00;border-color:#c2410c;color:#fdba74}

/* ── Autocomplete ── */
.autocomplete-wrap{position:relative}
.autocomplete-suggestions{position:absolute;bottom:calc(100% + 6px);left:58px;right:0;background:#fff;border:2px solid #bfdbfe;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:50;display:none;overflow:hidden}
.autocomplete-suggestions.visible{display:block}
.ac-item{padding:9px 14px;font-size:14px;font-weight:700;color:var(--ink);cursor:pointer;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;gap:8px;transition:.1s background}
.ac-item:last-child{border-bottom:none}
.ac-item:hover{background:#eff6ff;color:var(--blue)}
.ac-item-icon{font-size:14px;flex-shrink:0;opacity:.6}
.ac-header{padding:6px 14px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);background:#f8fafc;border-bottom:1px solid #e5e7eb}
body.dark-mode .autocomplete-suggestions{background:#1e2a3a;border-color:#334155}
body.dark-mode .ac-item{color:#e2e8f0;border-color:#334155}
body.dark-mode .ac-item:hover{background:#162032;color:#60a5fa}
body.dark-mode .ac-header{background:#0f172a;color:#94a3b8;border-color:#334155}

/* ── Inline Tooltip ── */
.inline-error-num{cursor:pointer;transition:.15s all}
.inline-error-num:hover{transform:scale(1.2)}
.inline-tooltip{display:none;position:absolute;background:#1e293b;color:#f8fafc;font-size:12px;font-weight:700;border-radius:8px;padding:7px 11px;max-width:240px;z-index:100;box-shadow:0 4px 16px rgba(0,0,0,.3);line-height:1.5;white-space:normal;pointer-events:none}
.inline-tooltip.show{display:block}
.inline-tooltip::after{content:"";position:absolute;bottom:-5px;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:#1e293b;border-bottom:none}

/* ── Mini-Wörterbuch ── */
.dict-widget{margin-top:0;margin-bottom:6px;border:2px solid #bfdbfe;border-radius:16px;overflow:hidden;background:#eff6ff;transition:.2s border-color}
.dict-widget:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(21,101,192,.1)}
.dict-header{display:flex;align-items:center;gap:8px;padding:9px 14px;cursor:pointer;user-select:none;background:#dbeafe}
.dict-header-icon{font-size:18px}
.dict-header-title{font-size:13px;font-weight:900;color:#1e40af;flex:1}
.dict-header-toggle{font-size:12px;color:#3b82f6;font-weight:800;transition:.2s transform}
.dict-header-toggle.open{transform:rotate(180deg)}
.dict-body{padding:10px 14px 12px;display:none}
.dict-body.open{display:block}
.dict-input-row{display:flex;gap:8px;align-items:center}
.dict-input{flex:1;padding:8px 13px;border:2px solid #bfdbfe;border-radius:10px;font-family:'Baloo 2',sans-serif;font-size:14px;font-weight:700;color:var(--ink);background:#fff;outline:none;transition:.2s}
.dict-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(21,101,192,.1)}
.dict-input::placeholder{color:#94a3b8;font-weight:600}
.dict-btn{border:none;border-radius:10px;padding:8px 14px;background:var(--blue);color:#fff;font-family:'Baloo 2',sans-serif;font-size:13px;font-weight:800;cursor:pointer;white-space:nowrap;transition:.15s all}
.dict-btn:hover{filter:brightness(1.1);transform:translateY(-1px)}
.dict-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
.dict-result{margin-top:10px;padding:10px 13px;border-radius:10px;background:#fff;border:2px solid #bfdbfe;display:none;animation:dictFadeIn .2s ease}
.dict-result.visible{display:block}
@keyframes dictFadeIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.dict-result-word{font-size:17px;font-weight:900;color:var(--blue);margin-bottom:2px}
.dict-result-phonetic{font-size:12px;color:var(--muted);font-weight:600;margin-bottom:6px;font-style:italic}
.dict-result-translation{font-size:14px;font-weight:800;color:var(--ink);margin-bottom:6px}
.dict-result-example{font-size:13px;color:#374151;font-weight:600;line-height:1.6;background:#eff6ff;border-radius:8px;padding:7px 10px;border-left:3px solid #93c5fd}
.dict-result-example span{color:var(--blue);font-weight:800}
.dict-loading{display:none;font-size:13px;color:var(--muted);font-weight:700;padding:6px 0;display:none;align-items:center;gap:6px}
.dict-loading.visible{display:flex}
.dict-spinner{width:14px;height:14px;border:2px solid #bfdbfe;border-top-color:var(--blue);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.dict-error{font-size:13px;color:var(--red);font-weight:700;padding:4px 0;display:none}
.dict-error.visible{display:block}
body.dark-mode .dict-widget{background:#0d2040;border-color:#334155}
body.dark-mode .dict-header{background:#162032}
body.dark-mode .dict-header-title{color:#60a5fa}
body.dark-mode .dict-input{background:#0f172a;color:#e2e8f0;border-color:#334155}
body.dark-mode .dict-result{background:#1e2a3a;border-color:#334155}
body.dark-mode .dict-result-translation{color:#e2e8f0}
body.dark-mode .dict-result-example{background:#0d2040;border-color:#3b82f6;color:#94a3b8}

/* ── Schreibtipps ── */
.writing-tips{margin:0 0 22px;border:2px solid #a5d6a7;border-radius:14px;overflow:hidden;background:#f0fdf4;transition:.3s all}
.writing-tips-header{display:flex;align-items:center;gap:8px;padding:9px 14px;cursor:pointer;user-select:none;background:#dcfce7}
.writing-tips-title{font-size:13px;font-weight:900;color:#166534;flex:1}
.writing-tips-toggle{font-size:12px;color:#16a34a;font-weight:800;transition:.2s transform;flex-shrink:0}
.writing-tips-toggle.open{transform:rotate(180deg)}
.writing-tips-body{padding:12px 14px 0;max-height:58px;overflow:hidden;position:relative;transition:max-height .35s cubic-bezier(.4,0,.2,1)}
.writing-tips-body::after{content:"";position:absolute;bottom:0;left:0;right:0;height:36px;background:linear-gradient(transparent,#f0fdf4);pointer-events:none;transition:opacity .3s}
.writing-tips-body.open{max-height:600px;padding-bottom:14px}
.writing-tips-body.open::after{opacity:0}
.tips-checklist{list-style:none;display:flex;flex-direction:column;gap:6px;margin:0;padding:0}
.tips-checklist li{display:flex;align-items:flex-start;gap:8px;font-size:13px;font-weight:700;color:#166534;line-height:1.5}
.tips-checklist li::before{content:"☐";font-size:16px;line-height:1.2;flex-shrink:0;color:#22c55e}
.tips-checklist li.tip-note{color:#854d0e;font-weight:600}
.tips-checklist li.tip-note::before{content:"💡";font-size:14px}
.tips-structure{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
.tips-structure-item{background:#fff;border:2px solid #a5d6a7;border-radius:10px;padding:6px 12px;font-size:12px;font-weight:800;color:#166534;display:flex;align-items:center;gap:5px}
.tips-structure-arrow{color:#94a3b8;font-size:14px}
body.dark-mode .writing-tips{background:#052e16;border-color:#166534}
body.dark-mode .writing-tips-header{background:#0a2e16}
body.dark-mode .writing-tips-body::after{background:linear-gradient(transparent,#052e16)}
body.dark-mode .writing-tips-title{color:#86efac}
body.dark-mode .tips-checklist li{color:#86efac}
body.dark-mode .tips-structure-item{background:#1e2a3a;border-color:#166534;color:#86efac}

/* ── Überarbeitungs-Modus (Diff) ── */
.diff-card{background:#fff;border-radius:20px;box-shadow:0 4px 20px rgba(0,0,0,.07);padding:22px 24px;margin-bottom:18px;border:2px solid #c4b5fd;display:none}
.diff-card.visible{display:block}
.diff-card-title{font-size:16px;font-weight:900;margin-bottom:16px;display:flex;align-items:center;gap:8px;color:var(--purple)}
.diff-cols{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:600px){.diff-cols{grid-template-columns:1fr}}
.diff-col-label{font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.diff-col-label.original{color:#b91c1c}
.diff-col-label.corrected{color:var(--green)}
.diff-box{border-radius:12px;padding:12px 14px;font-size:14px;font-weight:600;line-height:1.9;min-height:100px;white-space:pre-wrap;font-family:'Baloo 2',sans-serif}
.diff-box.original{background:#fef2f2;border:2px solid #fca5a5;color:#374151}
.diff-box.corrected{background:#f0fdf4;border:2px solid #a5d6a7;color:#374151}
.diff-del{background:#fecaca;color:#b91c1c;text-decoration:line-through;border-radius:3px;padding:0 2px;font-weight:800}
.diff-ins{background:#bbf7d0;color:#15803d;border-radius:3px;padding:0 2px;font-weight:800}
.diff-legend{display:flex;gap:14px;margin-top:10px;flex-wrap:wrap}
.diff-legend-item{display:flex;align-items:center;gap:5px;font-size:12px;font-weight:700;color:var(--muted)}
.diff-legend-swatch{width:14px;height:14px;border-radius:3px;flex-shrink:0}
body.dark-mode .diff-card{background:#1e2a3a;border-color:#7c3aed}
body.dark-mode .diff-box.original{background:#2d1010;border-color:#b91c1c;color:#e2e8f0}
body.dark-mode .diff-box.corrected{background:#052e16;border-color:#166534;color:#e2e8f0}

/* ── Teilbewertungen ── */
.subscores-card{background:#fff;border-radius:20px;box-shadow:0 4px 20px rgba(0,0,0,.07);padding:20px 24px;margin-bottom:14px;border:2px solid #e9d5ff}
.subscores-title{font-size:15px;font-weight:900;color:#7c3aed;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.subscores-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;align-items:stretch}
.subscore-item{border-radius:14px;padding:14px 10px;border:2px solid;text-align:center;display:flex;flex-direction:column;align-items:center;gap:6px}
.subscore-item.s5{border-color:#4ade80}.subscore-item.s4{border-color:#22c55e}.subscore-item.s3{border-color:#fbbf24}.subscore-item.s2{border-color:#fb923c}.subscore-item.s1{border-color:#f87171}
.subscore-label{font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:.3px;color:#475569;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
.subscore-bar-wrap{height:6px;background:rgba(0,0,0,.08);border-radius:999px;overflow:hidden;width:80%}
.subscore-bar{height:100%;border-radius:999px;transition:width .6s cubic-bezier(.22,1,.36,1)}
.subscore-bar.s5{background:#22c55e}.subscore-bar.s4{background:#4ade80}
.subscore-bar.s3{background:#fbbf24}.subscore-bar.s2{background:#fb923c}.subscore-bar.s1{background:#f87171}
.subscore-stars{font-size:17px;letter-spacing:1px;color:#f59e0b;line-height:1}
.subscore-note{font-size:11px;color:#475569;font-weight:700;white-space:nowrap}
body.dark-mode .subscores-card{background:#1e2a3a;border-color:#4c1d95}
body.dark-mode .subscores-title{color:#c4b5fd}
body.dark-mode .subscore-label{color:#94a3b8}
body.dark-mode .subscore-note{color:#94a3b8}
body.dark-mode .subscore-bar-wrap{background:#334155}

/* ── Autosave-Indikator ── */
.autosave-indicator{font-size:11px;font-weight:700;color:#94a3b8;display:flex;align-items:center;gap:5px;opacity:0;transition:opacity .4s}
.autosave-indicator.visible{opacity:1}
.autosave-dot{width:7px;height:7px;border-radius:50%;background:#94a3b8;flex-shrink:0}
.autosave-indicator.saved .autosave-dot{background:#22c55e}
.autosave-indicator.saved{color:#15803d}

</style>
