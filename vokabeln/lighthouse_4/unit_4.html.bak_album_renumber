// ── MEMORY ────────────────────────────────────────────────────────
// 12-Farben Hue-verteilte Palette für Memory-Paare (analog MATCH_COLORS, +2 Farben für 12 Paare)
const MEMORY_COLORS=['#C62828','#E65100','#827717','#558B2F','#1B5E20','#00838F','#0277BD','#1A237E','#6A1B9A','#AD1457','#5D4037','#455A64'];
function setupMemory(){
  const grid = document.getElementById('mem-grid');
  const triesEl = document.getElementById('mem-tries');
  const foundEl = document.getElementById('mem-found');
  const timeEl  = document.getElementById('mem-time');
  const winEl   = document.getElementById('mem-win');
  const PAIRS   = 12;
  let cur='all', cards=[], opened=[], matched=0, tries=0, t0=null, timer=null;
  buildTopicButtons('mem-topics');
  function fmt(s){const m=Math.floor(s/60), r=s%60;return m+':'+(r<10?'0':'')+r;}
  function startTimer(){
    if(timer) return;
    t0 = Date.now();
    timer = setInterval(()=>{const s=Math.floor((Date.now()-t0)/1000);timeEl.textContent='⏱ '+fmt(s);},1000);
  }
  function stopTimer(){if(timer){clearInterval(timer);timer=null;}}
  function render(){
    stopTimer();
    grid.innerHTML='';winEl.classList.remove('show');winEl.innerHTML='';
    matched=0;tries=0;opened=[];
    triesEl.textContent='🎯 Versuche: 0';foundEl.textContent='✅ Paare: 0/'+PAIRS;timeEl.textContent='⏱ 0:00';
    const pool = getPool(cur);
    const picks = lt_pick(pool, Math.min(PAIRS, pool.length));
    cards = [];
    picks.forEach(v=>{
      cards.push({k:v.en,face:(v.mEn||v.en),side:'en',pairKey:v.en});
      cards.push({k:v.en,face:v.de,             side:'de',pairKey:v.en});
    });
    shuffle(cards);
    cards.forEach((c,idx)=>{
      const card=document.createElement('div');card.className='mem-card';card.dataset.idx=idx;
      card.innerHTML='<div class="mem-card-inner"><div class="mem-face mem-back">?</div><div class="mem-face mem-front'+(c.side==='de'?' is-de':'')+'">'+c.face+'</div></div>';
      card.addEventListener('click', ()=>onClick(card,idx));
      grid.appendChild(card);
    });
  }
  function onClick(card, idx){
    if(card.classList.contains('matched') || card.classList.contains('flipped')) return;
    if(opened.length>=2) return;
    if(!t0) startTimer();
    card.classList.add('flipped');
    opened.push({card, idx, data:cards[idx]});
    if(opened.length===2){
      tries++;triesEl.textContent='🎯 Versuche: '+tries;
      const [a,b] = opened;
      if(a.data.pairKey === b.data.pairKey && a.data.side !== b.data.side){
        // Match: gleiche Farbe für beide Karten vergeben
        const col = MEMORY_COLORS[matched % MEMORY_COLORS.length];
        a.card.style.setProperty('--match-col', col);
        b.card.style.setProperty('--match-col', col);
        setTimeout(()=>{
          a.card.classList.add('matched');b.card.classList.add('matched');
          opened=[];matched++;foundEl.textContent='✅ Paare: '+matched+'/'+PAIRS;
          lt_record(a.data.pairKey, true);
          if(matched===PAIRS) finish();
        }, 350);
      } else {
        // Kein Match
        lt_record(a.data.pairKey, false);
        setTimeout(()=>{
          a.card.classList.remove('flipped');b.card.classList.remove('flipped');
          opened=[];
        }, 900);
      }
    }
  }
  function finish(){
    stopTimer();
    const sec = Math.floor((Date.now()-t0)/1000);
    winEl.innerHTML='<div style="font-size:36px;margin-bottom:6px">🎉</div><div style="font-size:18px;font-weight:900;color:#7c2410">Geschafft!</div><div style="margin-top:6px">'+tries+' Versuche · '+fmt(sec)+'</div>';
    winEl.classList.add('show');
    fireConfetti();
  }
  document.getElementById('mem-topics').addEventListener('click',e=>{
    const b=e.target.closest('button[data-topic]');if(!b)return;
    document.getElementById('mem-topics').querySelectorAll('button').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');cur=b.dataset.topic;render();
  });
  document.getElementById('mem-reroll').addEventListener('click',()=>render());
  // Erst beim ersten Öffnen rendern
  document.getElementById('acc-memory').addEventListener('toggle',function(){
    if(this.open && grid.children.length===0) render();
  });
}



