<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Unit 4 Vokabeln – Lighthouse 4</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 40'><clipPath id='c'><path d='M0 0h60v40H0z'/></clipPath><rect width='60' height='40' fill='%23012169'/><g clip-path='url(%23c)'><path d='M0 0l60 40M60 0L0 40' stroke='white' stroke-width='8'/><path d='M0 0l60 40M60 0L0 40' stroke='%23C8102E' stroke-width='4'/><path d='M30 0v40M0 20h60' stroke='white' stroke-width='10'/><path d='M30 0v40M0 20h60' stroke='%23C8102E' stroke-width='6'/></g></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --hr-blue:#b85c20;--hr-red:#C62828;--hr-green:#2e7d32;--hr-gray:#455A64;--ok:#2e7d32;--warn:#ef6c00;--bad:#b71c1c;
  /* === Master-Token-System (Slate-Gold, aus 06_will_future.html) === */
  --bg:#f8fafc;--bg-card:#ffffff;--bg-card-hover:#f1f5f9;--bg-input:#ffffff;
  --border:#e5e7eb;--border-strong:#d1d5db;
  --text:#1f2937;--text-dim:#4b5563;
  --accent:#d4a017;--accent-soft:rgba(212,160,23,0.10);--accent-strong:#a07408;--accent-tint:#e2e8f0;
  --success:#16a34a;--success-soft:rgba(22,163,74,0.08);--success-tint:#bbf7d0;
  --error:#dc2626;--error-soft:rgba(220,38,38,0.08);--error-tint:#fecaca;
  --info:#2563eb;--info-soft:rgba(37,99,235,0.08);--info-tint:#bfdbfe;
}
body.dark-mode{
  --bg:#0f1117;--bg-card:#1a1d28;--bg-card-hover:#232634;--bg-input:#14161e;
  --border:#2a2e3d;--border-strong:#3a3f52;
  --text:#e8e9ed;--text-dim:#9ba0b3;
  --accent:#f4c430;--accent-soft:rgba(244,196,48,0.12);--accent-strong:#facc15;
  --success:#4ade80;--success-soft:rgba(74,222,128,0.10);
  --error:#f87171;--error-soft:rgba(248,113,113,0.10);
  --info:#60a5fa;--info-soft:rgba(96,165,250,0.10);
}
html,body{margin:0;padding:0;font-family:'Baloo 2',system-ui,-apple-system,sans-serif;background:#fef9f2;color:#2c1a0e;line-height:1.55;font-size:18px}
body{min-height:100vh}
html:has(body.dark-mode){background:#111827}
.container{max-width:1100px;margin:0 auto;padding:16px 20px 96px}
header{text-align:center;padding:20px 10px 10px;position:relative}
header img{height:70px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.15))}
header h1{margin:10px 0 0;font-size:clamp(26px,5vw,38px);color:var(--hr-blue);letter-spacing:.2px}
header p.sub{margin:6px 0 0;color:#475569}
.dark-toggle{position:fixed;top:14px;right:16px;z-index:100;border:none;border-radius:999px;padding:8px 14px;font-weight:700;font-size:14px;cursor:pointer;background:#b85c20;color:#fff;box-shadow:0 2px 10px rgba(0,0,0,.2);transition:.2s background,.2s transform}
.dark-toggle:hover{transform:translateY(-1px);background:#8a4210}
body.dark-mode .dark-toggle{background:#334155;color:#f0e6d8}
@media(max-width:600px){.dark-toggle{position:static;display:block;margin:0 auto 8px;box-shadow:0 1px 6px rgba(0,0,0,.15)}}
details.accordion{background:#fff;border-radius:16px;border:1px solid #e5e7eb;box-shadow:0 6px 20px rgba(0,0,0,.06);margin:16px 0;overflow:hidden}
details.accordion summary{list-style:none;cursor:pointer;padding:14px 18px;outline:none;display:flex;align-items:center;gap:10px;font-weight:700;font-size:16px;color:#0f172a;border-left:5px solid transparent;transition:background .2s}
details.accordion summary::-webkit-details-marker{display:none}
details.opener summary{list-style:none;cursor:pointer}
details.opener summary::-webkit-details-marker{display:none}
details.accordion[open] summary{border-bottom:1px solid #e5e7eb}
details.accordion summary:hover{filter:brightness(.97)}
#acc-uebungen summary{border-left-color:#2e7d32;background:linear-gradient(90deg,rgba(46,125,50,.10),rgba(46,125,50,.02))}
#acc-matching summary{border-left-color:#C62828;background:linear-gradient(90deg,rgba(198,40,40,.10),rgba(198,40,40,.02))}
#acc-scramble summary{border-left-color:#e65100;background:linear-gradient(90deg,rgba(230,81,0,.10),rgba(230,81,0,.02))}
#acc-spell summary{border-left-color:#00838f;background:linear-gradient(90deg,rgba(0,131,143,.10),rgba(0,131,143,.02))}
#acc-dictation summary{border-left-color:#ad1457;background:linear-gradient(90deg,rgba(173,20,87,.10),rgba(173,20,87,.02))}
#acc-race summary{border-left-color:#b85c20;background:linear-gradient(90deg,rgba(184,92,32,.10),rgba(184,92,32,.02))}
#acc-invaders summary{border-left-color:#00695c;background:linear-gradient(90deg,rgba(0,105,92,.10),rgba(0,105,92,.02))}
.content{padding:18px 20px}
.note{background:linear-gradient(135deg,#fef5e4,#fefae8);border:1px solid #f5d9a8;border-left:4px solid #b85c20;padding:11px 14px;border-radius:10px;margin:6px 0 16px;color:#5a2e0e;font-size:14px;line-height:1.6}
.btn{border:none;border-radius:999px;padding:9px 18px;font-weight:700;cursor:pointer;background:#e2e8f0;color:#334155;font-size:14px;transition:.15s all}
.btn:hover{transform:translateY(-1px);filter:brightness(1.06)}
.btn.primary{background:linear-gradient(135deg,#C62828,#e53935);color:#fff;box-shadow:0 2px 6px rgba(198,40,40,.3)}
.btn.green{background:linear-gradient(135deg,#2e7d32,#43a047);color:#fff;box-shadow:0 2px 6px rgba(46,125,50,.3)}
.btn.gray{background:linear-gradient(135deg,#455A64,#607d8b);color:#fff}
.btn.ghost{background:#f1f5f9;color:#475569;border:1px solid #e2e8f0}
.btn.purple{background:linear-gradient(135deg,#6a35b0,#8e4ec6);color:#fff;box-shadow:0 2px 6px rgba(106,53,176,.3)}
.task{border:1px solid #e5e7eb;border-top:3px solid #2e7d32;background:#f0fdf4;border-radius:14px;padding:16px 18px;margin:12px 0;line-height:1.6;box-shadow:0 2px 8px rgba(0,0,0,.05)}
.task:hover{box-shadow:0 4px 16px rgba(0,0,0,.09)}
.task .prompt{margin:0 0 8px;font-weight:600;color:#0f172a;font-size:15.5px}
.task input[type="text"]{width:100%;padding:11px 16px;border:2px solid #e2e8f0;border-radius:999px;font-size:16px;outline:none;transition:.2s all;box-sizing:border-box;background:#f8fafc;color:#0f172a}
.task input[type="text"]:focus{border-color:#b85c20;background:#fff;box-shadow:0 0 0 4px rgba(184,92,32,.12)}
.task input[type="text"]:disabled{background:#f1f5f9;color:#64748b}
.task .controls{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
.feedback{margin-top:8px;font-size:14px;font-weight:700;padding:4px 0}
.ok{color:var(--ok)}.warn{color:var(--warn)}.bad{color:var(--bad)}
.section-actions{display:flex;gap:8px;margin:14px 0 10px;flex-wrap:wrap}
.progress-wrap{display:flex;align-items:center;gap:12px;margin:12px 0 10px}
.progress{position:relative;width:260px;height:16px;background:#e2e8f0;border-radius:999px;overflow:hidden;box-shadow:inset 0 1px 3px rgba(0,0,0,.1)}
.progress-fill{position:absolute;left:0;top:0;bottom:0;width:0%;background:#b85c20;transition:width .3s ease;border-radius:999px}
.progress.green .progress-fill{background:linear-gradient(90deg,#2e7d32,#43a047)}
.progress.red .progress-fill{background:linear-gradient(90deg,#C62828,#ef5350)}
.progress.purple .progress-fill{background:linear-gradient(90deg,#6a35b0,#8e4ec6)}
.progress.pink .progress-fill{background:linear-gradient(90deg,#ad1457,#d81b60)}
.dict-card{border:1px solid #e5e7eb;border-top:3px solid #ad1457;background:#fdf2f8;border-radius:14px;padding:16px 18px;margin:12px 0;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.05)}
.dict-card.done.was-correct{border-top-color:#2e7d32;background:#f0fdf4}
.dict-card.done.was-wrong{border-top-color:#C62828;background:#fef2f2}
.dict-play-btn{border:none;border-radius:50%;width:56px;height:56px;font-size:28px;cursor:pointer;background:linear-gradient(135deg,#ad1457,#d81b60);color:#fff;box-shadow:0 4px 12px rgba(173,20,87,.4);transition:.2s;margin:8px 0}
.dict-play-btn:hover{transform:scale(1.1)}
.dict-play-btn:disabled{opacity:.5;cursor:default;transform:none}
body.dark-mode .dict-card{background:#1e2a3a;border-color:#334155}
body.dark-mode .dict-card.done.was-correct{background:rgba(22,101,52,.15)}
body.dark-mode .dict-card.done.was-wrong{background:rgba(127,29,29,.15)}
.progress-text{font-size:13.5px;color:#475569;font-weight:600}
.pool-hint{font-size:12px;color:#94a3b8;margin:2px 0 0;font-weight:600}
.match-grid{display:flex;gap:12px;margin:12px 0;background:#fef5e4;border:1px solid #f5d9a8;border-radius:14px;padding:14px}
.match-col{display:flex;flex-direction:column;gap:7px;flex:1}
.match-col-header{font-size:11px;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:.6px;margin-bottom:2px}
.match-btn{padding:9px 12px;border-radius:10px;border:2px solid #f5d9a8;background:#fef5e4;color:#7a3010;font-weight:700;cursor:pointer;text-align:left;font-size:13px;transition:.2s all;min-height:42px;line-height:1.3;width:100%}
.match-btn:hover:not(.matched):not(.selected){background:#fde8c0;border-color:#d4922e;transform:translateY(-1px)}
.match-btn.selected{background:linear-gradient(135deg,#b85c20,#d4762a);color:#fff;border-color:transparent}
.match-btn.matched{color:#fff;border-color:transparent;cursor:default;opacity:.85}
.match-btn.wrong{background:linear-gradient(135deg,#C62828,#e53935);color:#fff;border-color:transparent;animation:shake .3s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}
.match-done{margin-top:12px;padding:10px 14px;border-radius:10px;font-size:15px;font-weight:700;display:none}
.match-done.ok{background:#f0fdf4;border:2px solid #86efac;color:#166534}
.match-summary{margin-top:14px}
.match-summary-row{display:flex;align-items:stretch;gap:0;margin:6px 0;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08);font-size:13px;font-weight:700}
.match-summary-en{padding:10px 14px;flex:1;color:#fff;text-align:right;transform:translateX(-100%);opacity:0;transition:transform .5s ease,opacity .5s ease}
.match-summary-arrow{padding:0 4px;display:flex;align-items:center;color:#fff;font-size:11px;transform:scale(0);opacity:0;transition:transform .4s ease .2s,opacity .4s ease .2s}
.match-summary-de{padding:10px 14px;flex:1;color:#fff;transform:translateX(100%);opacity:0;transition:transform .5s ease,opacity .5s ease}
.match-summary-row.fly-in .match-summary-en{transform:translateX(0);opacity:1}
.match-summary-row.fly-in .match-summary-arrow{transform:scale(1);opacity:1}
.match-summary-row.fly-in .match-summary-de{transform:translateX(0);opacity:1}
.topic-switch{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 16px}
.topic-switch button{border:2px solid #f5d9a8;border-radius:999px;padding:7px 16px;font-weight:700;cursor:pointer;background:#fef5e4;color:#7a3010;transition:.2s all;font-size:13px;outline:none}
.topic-switch button:hover{background:#fde8c0;transform:translateY(-1px)}
.topic-switch button.active{background:linear-gradient(135deg,#b85c20,#d4762a);color:#fff;border-color:transparent;box-shadow:0 3px 10px rgba(184,92,32,.35);transform:translateY(-1px)}
.hint-key{background:#fef08a;border:1.5px solid #ca8a04;border-radius:5px;padding:1px 6px;font-weight:900;color:#713f12;font-style:normal}
.gap-hint{font-size:13px;color:#475569;margin-bottom:8px;font-weight:600;line-height:1.5;padding-bottom:8px;border-bottom:1px solid #f1f5f9;display:flex;align-items:flex-start;gap:8px}
.gap-hint-text{flex:1}
.tts-btn{flex-shrink:0;width:32px;height:32px;border:none;border-radius:50%;background:#e2e8f0;cursor:pointer;font-size:16px;display:inline-flex;align-items:center;justify-content:center;transition:.15s;padding:0}
.tts-btn:hover{background:#b85c20;transform:scale(1.1)}
.tts-btn.speaking{background:#b85c20;animation:pulse .8s ease infinite}
.tts-mini{width:26px;height:26px;font-size:13px}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
body.dark-mode .tts-btn{background:#334155}
body.dark-mode .tts-btn:hover,body.dark-mode .tts-btn.speaking{background:#d4722a}
.match-btn:focus{outline:3px solid #b85c20;outline-offset:2px}
.race-streak{text-align:center;font-size:14px;font-weight:800;color:#e65100;min-height:20px;margin:2px 0}
body.dark-mode .race-streak{color:#ff8f00}
.race-level{display:flex;gap:8px;justify-content:center;margin:10px 0 14px}
.race-level button{border:2px solid #e2e8f0;border-radius:12px;padding:10px 16px;font-weight:700;font-size:14px;cursor:pointer;background:#fff;transition:.15s;flex:1;max-width:140px;text-align:center}
.race-level button:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.race-level .lvl-easy{border-color:#86efac;color:#166534;background:#f0fdf4}
.race-level .lvl-easy:hover,.race-level .lvl-easy.active{background:#2e7d32;color:#fff;border-color:#2e7d32}
.race-level .lvl-medium{border-color:#fde68a;color:#92400e;background:#fefce8}
.race-level .lvl-medium:hover,.race-level .lvl-medium.active{background:#e65100;color:#fff;border-color:#e65100}
.race-level .lvl-hard{border-color:#fca5a5;color:#991b1b;background:#fef2f2}
.race-level .lvl-hard:hover,.race-level .lvl-hard.active{background:#C62828;color:#fff;border-color:#C62828}
body.dark-mode .race-level button{background:#162032;border-color:#334155}
body.dark-mode .race-level .lvl-easy{color:#86efac;border-color:#166534}
body.dark-mode .race-level .lvl-medium{color:#fde68a;border-color:#92400e}
body.dark-mode .race-level .lvl-hard{color:#fca5a5;border-color:#991b1b}
.race-wrong-list{margin-top:14px;text-align:center;font-size:13px}
.race-wrong-list table{border-collapse:collapse;margin:6px auto 0;text-align:left}
.race-wrong-list th,.race-wrong-list td{padding:6px 10px;border-bottom:1px solid #e2e8f0;text-align:left}
.race-wrong-list th{font-size:11px;text-transform:uppercase;color:#64748b;letter-spacing:.5px}
body.dark-mode .race-wrong-list th,body.dark-mode .race-wrong-list td{border-color:#334155}
/* Space Invaders */
.si-arena{position:relative;width:100%;height:520px;background:linear-gradient(180deg,#0a0a2e 0%,#1a1a4e 60%,#0d0d3a 100%);border-radius:14px;overflow:hidden;border:2px solid #2a2a6e;box-shadow:inset 0 0 40px rgba(100,100,255,.08);user-select:none}
.si-arena .star{position:absolute;width:2px;height:2px;background:#fff;border-radius:50%;opacity:.5;animation:twinkle 2s ease-in-out infinite alternate}
@keyframes twinkle{0%{opacity:.3}100%{opacity:.9}}
.si-alien{position:absolute;display:flex;flex-direction:column;align-items:center;transition:top .5s linear;z-index:2;cursor:default;transform:translateX(-50%)}
.si-alien-sprite{font-size:30px;line-height:1;filter:drop-shadow(0 0 6px rgba(255,220,0,.5));animation:alienBob 1.2s ease-in-out infinite alternate}
@keyframes alienBob{0%{transform:translateY(0)}100%{transform:translateY(-4px)}}
.si-alien-word{margin-top:2px;font-size:11px;font-weight:800;color:#ffdd00;background:rgba(0,0,0,.85);border:1.5px solid rgba(255,221,0,.5);border-radius:6px;padding:2px 8px;text-shadow:0 0 4px rgba(255,221,0,.4);max-width:180px;text-align:center;line-height:1.3}
.si-alien.hit .si-alien-sprite{animation:explode .4s ease forwards}
.si-alien.hit .si-alien-word{opacity:0}
.si-alien.si-active .si-alien-word{border-color:rgba(255,60,60,.8);box-shadow:0 0 12px rgba(255,60,60,.5);color:#fff;background:rgba(180,0,0,.7)}
.si-alien.si-active .si-alien-sprite{filter:drop-shadow(0 0 10px rgba(255,60,60,.7))}
.si-alien.si-punished{animation:shake .3s ease}
.si-alien.si-punished .si-alien-word{border-color:#ff4444;color:#ff8888}
@keyframes explode{0%{transform:scale(1);opacity:1}50%{transform:scale(1.8);opacity:.6}100%{transform:scale(0);opacity:0}}
.si-alien.missed .si-alien-sprite{color:#ff4444;animation:none}
.si-alien.missed .si-alien-word{background:rgba(200,0,0,.5);border-color:#ff4444;color:#ffaaaa}
.si-ship{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);font-size:36px;z-index:3;filter:drop-shadow(0 0 12px rgba(0,75,157,.8));transition:left .2s}
.si-laser-svg{position:absolute;top:0;left:0;width:100%;height:100%;z-index:2;pointer-events:none}
.si-laser-svg line{stroke:#0068c8;stroke-width:3;stroke-linecap:round;filter:drop-shadow(0 0 6px rgba(0,104,200,.8))}
.si-laser-svg .glow{stroke:#60a5fa;stroke-width:6;stroke-linecap:round;opacity:.5}

.si-choices{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin:14px 0 6px;min-height:50px}
.si-choice{padding:9px 16px;border:2px solid #004B9D;border-radius:10px;background:linear-gradient(135deg,#001a3d,#003070);color:#a8d4ff;font-weight:700;font-size:14px;cursor:pointer;transition:.15s all;text-align:center;display:flex;align-items:center;justify-content:center;grid-column:span 2}
.si-choice:nth-child(4){grid-column:2/span 2}
.si-choice:nth-child(5){grid-column:4/span 2}
.si-choice:hover:not(.used){background:linear-gradient(135deg,#004B9D,#0068c8);border-color:#60a5fa;color:#fff;transform:translateY(-2px);box-shadow:0 4px 10px rgba(0,75,157,.4)}
@media(hover:none){.si-choice:hover:not(.used){background:linear-gradient(135deg,#001a3d,#003070);border-color:#004B9D;color:#a8d4ff;transform:none;box-shadow:none}}
.si-choice.correct{background:linear-gradient(135deg,#004B9D,#0068c8);border-color:#fff;color:#fff;cursor:default;box-shadow:0 0 12px rgba(0,104,200,.5)}
.si-choice.wrong{background:linear-gradient(135deg,#7f1d1d,#991b1b);border-color:#ef4444;color:#fca5a5;animation:shake .3s ease;cursor:default}
.si-choice.used{opacity:.35;cursor:default}
.si-hud{display:flex;justify-content:space-between;align-items:center;font-size:13px;font-weight:700;background:linear-gradient(135deg,#001a3d,#003070);border-radius:10px;padding:8px 14px;border:1px solid #004B9D;margin-bottom:10px;color:#a8d4ff}
.si-hud .si-lives{color:#f87171}.si-hud .si-score{color:#fff}.si-hud .si-wave{color:#60a5fa}
.si-game-over{position:absolute;top:0;left:0;right:0;bottom:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;background:rgba(0,26,61,.94);z-index:10;border-radius:14px;padding:16px 20px;overflow-y:auto;-webkit-overflow-scrolling:touch}
.si-game-over h3{font-size:20px;font-weight:900;color:#fff;margin:0 0 6px}
.si-start-screen{position:absolute;top:0;left:0;right:0;bottom:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(0,26,61,.85);z-index:10;border-radius:14px;padding:20px;text-align:center}
.si-start-screen h3{font-size:22px;font-weight:900;color:#fff;margin:0 0 6px}
.si-start-screen p{font-size:13px;color:#a8d4ff;margin:4px 0;line-height:1.5}
.si-start-btn{border:none;border-radius:14px;padding:14px 40px;font-weight:900;font-size:18px;cursor:pointer;background:linear-gradient(135deg,#004B9D,#0068c8);color:#fff;box-shadow:0 4px 16px rgba(0,75,157,.5);transition:.2s;margin-top:14px;letter-spacing:.5px}
.si-start-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,75,157,.6)}
.si-game-over p{font-size:14px;color:#a8d4ff;margin:4px 0}
.si-level{display:flex;gap:8px;justify-content:center;margin:10px 0 14px}
.si-level button{border:2px solid #e2e8f0;border-radius:12px;padding:10px 16px;font-weight:700;font-size:14px;cursor:pointer;background:#fff;transition:.15s;flex:1;max-width:140px;text-align:center}
.si-level button:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.si-level .si-easy{border-color:#86efac;color:#166534;background:#f0fdf4}
.si-level .si-easy:hover,.si-level .si-easy.active{background:#2e7d32;color:#fff;border-color:#2e7d32}
.si-level .si-medium{border-color:#60a5fa;color:#004B9D;background:#eff6ff}
.si-level .si-medium:hover,.si-level .si-medium.active{background:#004B9D;color:#fff;border-color:#004B9D}
.si-level .si-hard{border-color:#fca5a5;color:#991b1b;background:#fef2f2}
