<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Possessivbegleiter – Hellweg-Realschule</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 40'><clipPath id='c'><path d='M0 0h60v40H0z'/></clipPath><rect width='60' height='40' fill='%23012169'/><g clip-path='url(%23c)'><path d='M0 0l60 40M60 0L0 40' stroke='white' stroke-width='8'/><path d='M0 0l60 40M60 0L0 40' stroke='%23C8102E' stroke-width='4'/><path d='M30 0v40M0 20h60' stroke='white' stroke-width='10'/><path d='M30 0v40M0 20h60' stroke='%23C8102E' stroke-width='6'/></g></svg>">
<style>
/* ============================================================
   SLATE-GOLD DESIGN SYSTEM (Pilot 05_to_be.html, Apr 2026)
   ============================================================ */
:root{
  --bg:#f8fafc;
  --bg-card:#ffffff;
  --bg-card-hover:#f1f5f9;
  --bg-input:#ffffff;
  --border:#e5e7eb;
  --border-strong:#d1d5db;
  --text:#1f2937;
  --text-dim:#4b5563;
  --accent:#d4a017;
  --accent-soft:rgba(212,160,23,0.10);
  --accent-strong:#a07408;
  --accent-tint:#e2e8f0;
  --success:#16a34a;
  --success-soft:rgba(22,163,74,0.08);
  --success-tint:#bbf7d0;
  --warn:#ea580c;
  --warn-soft:rgba(234,88,12,0.08);
  --warn-tint:#fed7aa;
  --error:#dc2626;
  --error-soft:rgba(220,38,38,0.08);
  --error-tint:#fecaca;
  --info:#2563eb;
  --info-soft:rgba(37,99,235,0.08);
  --info-tint:#bfdbfe;
  --indigo:#4f46e5;
  --indigo-soft:rgba(79,70,229,0.08);
  --indigo-tint:#ddd6fe;
  --teal:#0d9488;
  --teal-soft:rgba(13,148,136,0.08);
  --teal-tint:#f0fdfa;
  /* Pill-Tokens */
  --pill-subj-bg:rgba(37,99,235,0.10);
  --pill-subj-bd:#2563eb;
  --pill-subj-tx:#1e40af;
  --pill-do-bg:rgba(212,160,23,0.14);
  --pill-do-bd:#d4a017;
  --pill-do-tx:#7c5e0a;
  --pill-verb-bg:rgba(8,145,178,0.10);
  --pill-verb-bd:#0891b2;
  --pill-verb-tx:#155e6e;
  --pill-neg-bg:rgba(220,38,38,0.10);
  --pill-neg-bd:#dc2626;
  --pill-neg-tx:#991b1b;
  --pill-wh-bg:rgba(234,88,12,0.10);
  --pill-wh-bd:#ea580c;
  --pill-wh-tx:#9a3a0e;
  --pill-sig-bg:rgba(124,58,237,0.10);
  --pill-sig-bd:#7c3aed;
  --pill-sig-tx:#5b21b6;
  --pill-s-bg:rgba(22,163,74,0.10);
  --pill-s-bd:#16a34a;
  --pill-s-tx:#15803d;
  /* Karten-Akzent-Streifen pro Kategorie */
  --card-aus:#16a34a;
  --card-kf:#d4a017;
  --card-vern:#dc2626;
  --card-frag:#2563eb;
  --card-ka:#7c3aed;
  /* Saturierte Karten-Akzente (für Top-Stripe, Titel, Underlines pro Karte) */
  --card-amber-strong:#475569;
  --card-green-strong:#059669;
  --card-teal-strong:#ea580c;
  --card-red-strong:#dc2626;
  --card-blue-strong:#2563eb;
  --card-indigo-strong:#7c3aed;
}
body.dark-mode{
  --bg:#0f1117;
  --bg-card:#1a1d28;
  --bg-card-hover:#232634;
  --bg-input:#14161e;
  --border:#2a2e3d;
  --border-strong:#3a3f52;
  --text:#e8e9ed;
  --text-dim:#9ba0b3;
  --accent:#f4c430;
  --accent-soft:rgba(244,196,48,0.12);
  --accent-strong:#facc15;
  --success:#4ade80;
  --success-soft:rgba(74,222,128,0.10);
  --warn:#fb923c;
  --warn-soft:rgba(251,146,60,0.10);
  --error:#f87171;
  --error-soft:rgba(248,113,113,0.10);
  --info:#60a5fa;
  --info-soft:rgba(96,165,250,0.10);
  --pill-subj-bg:rgba(96,165,250,0.12);
  --pill-subj-bd:#60a5fa;
  --pill-subj-tx:#bfdbfe;
  --pill-do-bg:rgba(244,196,48,0.12);
  --pill-do-bd:#f4c430;
  --pill-do-tx:#fde68a;
  --pill-verb-bg:rgba(34,211,238,0.12);
  --pill-verb-bd:#22d3ee;
  --pill-verb-tx:#a5f3fc;
  --pill-neg-bg:rgba(248,113,113,0.12);
  --pill-neg-bd:#f87171;
  --pill-neg-tx:#fca5a5;
  --pill-wh-bg:rgba(251,146,60,0.12);
  --pill-wh-bd:#fb923c;
  --pill-wh-tx:#fdba74;
  --pill-sig-bg:rgba(167,139,250,0.12);
  --pill-sig-bd:#a78bfa;
  --pill-sig-tx:#d8b4fe;
  --pill-s-bg:rgba(74,222,128,0.12);
  --pill-s-bd:#4ade80;
  --pill-s-tx:#86efac;
  --card-aus:#4ade80;
  --card-kf:#f4c430;
  --card-vern:#f87171;
  --card-frag:#60a5fa;
  --card-ka:#a78bfa;
}

/* === Layout Basics === */
html,body{margin:0;padding:0;font-family:'Baloo 2',system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--text);line-height:1.55;font-size:18px;transition:background .25s,color .25s}
.container{max-width:1100px;margin:0 auto;padding:16px 20px 96px}

/* === Header (zentriert gestapelt: Logo · H1 · Subtitle) === */
header{
  text-align:center;
  padding:36px 16px 24px;
}
.hdr-logo-link{
  display:block;
  text-decoration:none;
  margin:0 auto 16px;
}
header img{
  display:block;
  margin:0 auto;
  height:60px;
  max-width:100%;
  filter:drop-shadow(0 2px 6px rgba(15,23,42,0.10));
  cursor:pointer;
}
header h1{
  margin:0 0 8px;
  font-size:clamp(26px,5vw,36px);
  color:var(--text);
  letter-spacing:.2px;
  font-weight:700;
  display:inline-block;
  position:relative;
}
header h1::after{
  content:"";
  display:block;
  width:56px;
  height:3px;
  background:var(--accent);
  border-radius:2px;
  margin:10px auto 0;
}
header p.sub{
  margin:14px 0 0;
  color:var(--text-dim);
  font-size:13px;
  font-weight:600;
  letter-spacing:1.5px;
  text-transform:uppercase;
}
@media(max-width:600px){
  header{padding:24px 12px 18px}
  header img{height:50px}
}

/* === Regelkarten-Container === */
.rules-combined{margin-top:14px;background:var(--bg-card);border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.04);padding:22px 20px 18px;border:1px solid var(--border)}
.rules-combined h2{font-size:13px;color:var(--accent-strong);margin:0 0 16px;font-weight:800;text-transform:uppercase;letter-spacing:.6px;display:flex;align-items:center;gap:6px}
body.dark-mode .rules-combined h2{color:var(--accent)}
.rc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.rc-card{
  border-radius:14px;
  padding:0;
  display:flex;
  flex-direction:column;
  overflow:hidden;
  position:relative;
  background:var(--bg-card-hover);
  border:1px solid var(--border);
  border-top:6px solid var(--accent);
  transition:transform .2s ease, box-shadow .2s ease;
}
.rc-card.c-green{border-top-color:var(--success)}
.rc-card.c-red{border-top-color:var(--error)}
.rc-card.c-blue{border-top-color:var(--info)}
.rc-card.c-indigo{border-top-color:var(--indigo)}
.rc-card.c-amber{border-top-color:var(--accent)}
.rc-card.c-teal{border-top-color:var(--warn)}
body.dark-mode .rc-card.c-indigo{border-top-color:#a78bfa}
body.dark-mode .rc-card.c-teal{border-top-color:#22d3ee}
.rc-card-full{display:none}
.rc-card-topbar{display:none}
.rc-card-body{padding:24px;display:flex;flex-direction:column;gap:16px;flex:1}
.rc-card-label{
  font-size:17px;
  font-weight:700;
  letter-spacing:.2px;
  display:flex;
  align-items:center;
  gap:8px;
  color:var(--text);
  text-transform:none;
  line-height:1.25;
}
.rc-card-num{position:absolute;top:6px;right:10px;font-size:52px;font-weight:900;line-height:1;opacity:.06;pointer-events:none;user-select:none;color:var(--accent)}

/* === Pill-Formeln === */
.rc-formula{display:flex;flex-wrap:wrap;align-items:center;gap:6px 4px}
.fc-pair{display:inline-flex;align-items:center;gap:3px;white-space:nowrap;flex-shrink:0}
.fc{display:inline-flex;align-items:center;justify-content:center;border-radius:7px;padding:3px 7px;font-size:11px;font-weight:800;white-space:nowrap;flex-shrink:0}
.fc-subj{background:var(--pill-subj-bg);border:2px solid var(--pill-subj-bd);color:var(--pill-subj-tx)}
.fc-do{background:var(--pill-do-bg);border:2px solid var(--pill-do-bd);color:var(--pill-do-tx)}
.fc-verb{background:var(--pill-verb-bg);border:2px solid var(--pill-verb-bd);color:var(--pill-verb-tx)}
.fc-neg{background:var(--pill-neg-bg);border:2px solid var(--pill-neg-bd);color:var(--pill-neg-tx)}
.fc-sig{background:var(--pill-sig-bg);border:1.5px dashed var(--pill-sig-bd);color:var(--pill-sig-tx);font-style:italic}
.fc-wh{background:var(--pill-wh-bg);border:2px solid var(--pill-wh-bd);color:var(--pill-wh-tx)}
.fc-punct{background:transparent;border:none;font-size:16px;font-weight:900;color:var(--text-dim);padding:0 2px}
.fc-short{background:var(--bg-input);border:2px solid var(--accent);color:var(--accent-strong);font-size:12px}
body.dark-mode .fc-short{color:var(--accent)}
.fc-plus{font-size:11px;color:var(--text-dim);font-weight:700;padding:0}
.fc-s{background:var(--pill-s-bg);border:2px solid var(--pill-s-bd);color:var(--pill-s-tx);font-size:12px}

/* === Regel-Text & Beispiele === */
.rc-rule{font-size:13px;color:var(--text);line-height:1.55;padding:7px 10px;border-radius:8px;background:var(--bg-card);border:1px solid var(--border)}
.rc-card.c-green .rc-rule{border-left:3px solid var(--success)}
.rc-card.c-red .rc-rule{border-left:3px solid var(--error)}
.rc-card.c-blue .rc-rule{border-left:3px solid var(--info)}
.rc-card.c-indigo .rc-rule{border-left:3px solid #7c3aed}
.rc-card.c-amber .rc-rule{border-left:3px solid var(--accent)}
.rc-card.c-teal .rc-rule{border-left:3px solid #0891b2}
body.dark-mode .rc-card.c-indigo .rc-rule{border-left-color:#a78bfa}
body.dark-mode .rc-card.c-teal .rc-rule{border-left-color:#22d3ee}
.rc-examples-new{font-size:12.5px;color:var(--text-dim);line-height:1.75;padding:7px 10px;border-radius:8px;background:var(--bg-card);border:1px solid var(--border)}
.rc-examples-new b{color:var(--text)}

/* === Highlight-Spans === */
.hl-subj{color:var(--pill-subj-tx);font-weight:800;background:var(--pill-subj-bg);border-radius:4px;padding:0 3px}
.hl-do{color:var(--pill-do-tx);font-weight:800;background:var(--pill-do-bg);border-radius:4px;padding:0 3px}
.hl-verb{color:var(--pill-verb-tx);font-weight:800;background:var(--pill-verb-bg);border-radius:4px;padding:0 3px}
.hl-neg{color:var(--pill-neg-tx);font-weight:800;background:var(--pill-neg-bg);border-radius:4px;padding:0 3px}
.hl-sig{color:var(--pill-sig-tx);font-weight:700;background:var(--pill-sig-bg);border-radius:4px;padding:0 3px}
.hl-wh{color:var(--pill-wh-tx);font-weight:800;background:var(--pill-wh-bg);border-radius:4px;padding:0 3px}
.hl-s{color:var(--pill-s-tx);font-weight:800;background:var(--pill-s-bg);border-radius:4px;padding:0 3px}

/* === Signalwort-Chips === */
.fc-tz{background:var(--success-soft);border:1.5px solid var(--success);color:var(--success);border-radius:999px;font-style:normal;font-weight:700;padding:3px 10px;font-size:11.5px}
body.dark-mode .fc-tz{color:#86efac}
.signal-box{display:none}

/* === Akkordeons === */
details.accordion{background:var(--bg-card);border-radius:12px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.04);margin:16px 0;overflow:hidden;transition:border-color .2s}
details.accordion[open]{border-color:var(--border-strong)}
details.accordion summary{list-style:none;cursor:pointer;padding:14px 18px;outline:none;display:flex;align-items:center;gap:10px;font-weight:700;font-size:16px;color:var(--text);border-left:4px solid transparent;transition:background .2s,border-color .2s}
.acc-num{display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:50%;font-size:13px;font-weight:900;flex-shrink:0;background:var(--accent-soft);color:var(--accent-strong)}
body.dark-mode .acc-num{color:var(--accent)}
.acc-num-pair{display:inline-flex;align-items:center;gap:3px;flex-shrink:0}
.acc-num-sub{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;font-size:11px;font-weight:900;background:var(--accent-soft);color:var(--accent-strong)}
body.dark-mode .acc-num-sub{color:var(--accent)}
details.accordion[open] summary{border-bottom:1px solid var(--border)}
details.accordion summary:hover{background:var(--bg-card-hover)}

/* Akkordeon-Akzentstreifen pro Sektion */
#acc-aus summary{border-left-color:var(--card-aus)}
#acc-aus .acc-num{background:var(--success-soft);color:var(--success)}
#acc-kf summary{border-left-color:var(--card-kf)}
#acc-kf .acc-num{background:var(--accent-soft);color:var(--accent-strong)}
body.dark-mode #acc-kf .acc-num{color:var(--accent)}
#acc-vern summary{border-left-color:var(--card-vern)}
#acc-vern .acc-num{background:var(--error-soft);color:var(--error)}
#acc-frag summary{border-left-color:var(--card-frag)}
#acc-frag .acc-num{background:var(--info-soft);color:var(--info)}
#acc-ka summary{border-left-color:var(--card-ka)}
#acc-ka .acc-num{background:rgba(124,58,237,0.10);color:#7c3aed}
body.dark-mode #acc-ka .acc-num{background:rgba(167,139,250,0.12);color:#a78bfa}

.content{padding:18px 20px}

/* === Note-Box === */
.note{background:var(--accent-soft);border:1px solid var(--border-strong);border-left:4px solid var(--accent);padding:11px 14px;border-radius:10px;margin:6px 0 16px;color:var(--text);font-size:14px;line-height:1.6}
.highlight{font-weight:600}

/* === Level-Switch === */
.level-switch{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 16px}
.level-switch button{border:1.5px solid var(--border);border-radius:999px;padding:8px 20px;font-weight:700;cursor:pointer;background:var(--bg-card);color:var(--text);transition:.2s all;font-size:14px;letter-spacing:.2px;outline:none}
.level-switch button:hover{background:var(--bg-card-hover);border-color:var(--accent);transform:translateY(-1px)}
.level-switch button.active{background:var(--accent);color:#1a1d28;border-color:var(--accent);box-shadow:0 2px 8px var(--accent-soft);transform:translateY(-1px)}
body.dark-mode .level-switch button.active{color:#0f1117}

/* === Aufgaben-Karten === */
.task{border:1px solid var(--border);border-top:3px solid var(--accent);background:var(--bg-card);border-radius:12px;padding:16px 18px;margin:12px 0;scroll-margin-top:80px;line-height:1.6;box-shadow:0 1px 4px rgba(0,0,0,.04);transition:box-shadow .2s,border-color .2s}
#acc-aus .task{border-top-color:var(--card-aus)}
#acc-kf .task{border-top-color:var(--card-kf)}
#acc-vern .task{border-top-color:var(--card-vern)}
#acc-frag .task{border-top-color:var(--card-frag)}
#acc-ka .task{border-top-color:var(--card-ka)}
.task:hover{box-shadow:0 4px 12px rgba(0,0,0,.07)}
.task.task--solved{border:2px solid var(--success);box-shadow:0 0 0 3px var(--success-soft)}
.task.task--solved .task-solved-label{display:block}
.task-solved-label{display:none;font-size:12px;font-weight:700;color:var(--success);margin-bottom:4px}
.task-type-badge{display:inline-block;font-size:10px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;border-radius:999px;padding:2px 10px;margin-bottom:6px}
.task-type-badge.badge-mc{background:var(--info-soft);color:var(--info);border:1px solid var(--info)}
.task-type-badge.badge-ordne{background:var(--accent-soft);color:var(--accent-strong);border:1px solid var(--accent)}
body.dark-mode .task-type-badge.badge-ordne{color:var(--accent)}
.task-type-badge.badge-frei{background:rgba(124,58,237,0.10);color:#7c3aed;border:1px solid #7c3aed}
body.dark-mode .task-type-badge.badge-frei{background:rgba(167,139,250,0.12);color:#a78bfa;border-color:#a78bfa}
.task.task--wrong{border-color:var(--error);border-top-color:var(--error);background:var(--error-soft)!important}
.task.task--wrong .prompt{color:var(--error)}
.task .prompt{margin:0 0 12px;font-weight:600;color:var(--text);line-height:1.6;font-size:15.5px}
.task input[type="text"]{width:100%;padding:11px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:16px;outline:none;transition:.2s all;box-sizing:border-box;background:var(--bg-input);color:var(--text)}
.task input[type="text"]:focus{border-color:var(--accent);background:var(--bg-card);box-shadow:0 0 0 3px var(--accent-soft)}
.task input[type="text"]:disabled{background:var(--bg-card-hover);color:var(--text-dim)}
.task .controls{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;align-items:center}

/* === Buttons === */
.btn{border:1px solid var(--border);border-radius:999px;padding:9px 18px;font-weight:700;cursor:pointer;background:var(--bg-card);color:var(--text);font-size:14px;transition:.15s all;letter-spacing:.1px}
.btn:hover{transform:translateY(-1px);background:var(--bg-card-hover);border-color:var(--accent)}
.btn:active{transform:translateY(0)}
.btn.primary{background:var(--accent);color:#1a1d28;border-color:var(--accent);box-shadow:0 2px 6px var(--accent-soft)}
body.dark-mode .btn.primary{color:#0f1117}
.btn.primary:hover{background:var(--accent-strong);border-color:var(--accent-strong)}
.btn.blue{background:var(--info);color:#fff;border-color:var(--info);box-shadow:0 2px 6px var(--info-soft)}
.btn.green{background:var(--success);color:#fff;border-color:var(--success);box-shadow:0 2px 6px var(--success-soft)}
.btn.gray{background:var(--bg-card-hover);color:var(--text);border-color:var(--border)}
.btn.gray:hover{background:var(--accent-soft);border-color:var(--accent)}
.btn.ghost{background:transparent;color:var(--text-dim);border:1px solid var(--border)}

/* === Feedback / Solution / Hint === */
.feedback{margin-top:8px;font-size:14px;font-weight:700;padding:4px 0;letter-spacing:.1px}
.solution{margin-top:8px;font-size:14px;background:var(--info-soft);border:1px solid var(--info);border-left:3px solid var(--info);padding:10px 14px;border-radius:10px;display:none;line-height:1.65;color:var(--text)}
.hint-box{margin-top:8px;font-size:14px;background:var(--accent-soft);border:1px dashed var(--accent);color:var(--text);padding:10px 14px;border-radius:10px;display:none;line-height:1.55}
.ok{color:var(--success)}.warn{color:var(--warn)}.bad{color:var(--error)}

/* === MC-Optionen === */
.mc-options{display:flex;flex-direction:column;gap:8px;margin:4px 0 8px}
.mc-opt{display:flex;align-items:center;gap:10px;background:var(--bg-card);border:1.5px solid var(--border);border-radius:10px;padding:10px 14px;cursor:pointer;font-size:15px;font-weight:500;transition:.15s all;color:var(--text);-webkit-tap-highlight-color:transparent}
.mc-opt:hover{background:var(--bg-card-hover);border-color:var(--accent)}
.mc-opt:active{transform:scale(.98)}
.mc-opt.mc-selected{border-color:var(--accent);background:var(--accent-soft);font-weight:700}
.mc-opt.mc-correct{border-color:var(--success);background:var(--success-soft);color:var(--success)}
body.dark-mode .mc-opt.mc-correct{color:#86efac}
.mc-opt.mc-wrong{border-color:var(--error);background:var(--error-soft);color:var(--error);text-decoration:line-through;opacity:.75}
.mc-opt.mc-disabled{pointer-events:none;cursor:default}
.mc-letter{width:28px;height:28px;border-radius:50%;background:var(--bg-card-hover);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;flex-shrink:0;color:var(--text-dim);border:1px solid var(--border)}
.mc-opt.mc-selected .mc-letter{background:var(--accent);color:#1a1d28;border-color:var(--accent)}
body.dark-mode .mc-opt.mc-selected .mc-letter{color:#0f1117}
.mc-opt.mc-correct .mc-letter{background:var(--success);color:#fff;border-color:var(--success)}
.mc-opt.mc-wrong .mc-letter{background:var(--error);color:#fff;border-color:var(--error)}

/* === Word-Tiles === */
.word-tiles-wrap{margin:4px 0 8px}
.word-tiles-label{font-size:11px;font-weight:700;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:.4px}
.word-tiles{display:flex;flex-wrap:wrap;gap:8px;min-height:42px;padding:8px;border-radius:10px;background:var(--bg-card-hover);border:1.5px dashed var(--border-strong);transition:.2s all}
.word-tiles.wt-source{background:var(--bg-card);border-color:var(--border)}
.word-tiles.wt-target{background:var(--accent-soft);border-color:var(--accent);border-style:solid;min-height:46px}
.word-tiles.wt-target:empty::before{content:"Tippe die Wörter in der richtigen Reihenfolge an ↑";color:var(--text-dim);font-size:13px;font-style:italic;padding:6px}
.word-tile{display:inline-flex;align-items:center;padding:8px 14px;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer;transition:.15s all;-webkit-tap-highlight-color:transparent;user-select:none;border:1.5px solid var(--border);background:var(--bg-card);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.04)}
.word-tile:hover{transform:translateY(-1px);box-shadow:0 3px 8px rgba(0,0,0,.08);border-color:var(--accent)}
.word-tile:active{transform:scale(.95)}
.word-tile.wt-placed{background:var(--accent-soft);border-color:var(--accent);color:var(--text)}
.word-tile.wt-used{opacity:.3;pointer-events:none;transform:scale(.9)}
.word-tile.wt-correct{background:var(--success-soft);border-color:var(--success);color:var(--success);pointer-events:none}
body.dark-mode .word-tile.wt-correct{color:#86efac}
.word-tile.wt-wrong{background:var(--error-soft);border-color:var(--error);color:var(--error);animation:wt-shake .4s}
@keyframes wt-shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-4px)}40%,80%{transform:translateX(4px)}}

/* === Section-Actions / Progress === */
.section-actions{display:flex;gap:8px;margin:14px 0 10px;flex-wrap:wrap}
.progress-wrap{display:flex;align-items:center;gap:12px;margin:12px 0 10px}
.progress{position:relative;width:260px;height:14px;background:var(--bg-card-hover);border-radius:999px;overflow:hidden;border:1px solid var(--border)}
.progress-fill{position:absolute;left:0;top:0;bottom:0;width:0%;background:var(--accent);transition:width .3s ease;border-radius:999px}
.progress.red .progress-fill{background:var(--error)}
.progress.green .progress-fill{background:var(--success)}
.progress.mixed .progress-fill{background:linear-gradient(90deg,var(--error) 0%,var(--accent) 100%)}
.progress-text{font-size:13.5px;color:var(--text-dim);font-weight:600}

/* === Result-Cards === */
.result-card{margin-top:14px;border:1px solid var(--border);background:var(--bg-card);border-radius:14px;padding:14px;box-shadow:0 4px 14px rgba(0,0,0,.05)}
.score{font-size:22px;font-weight:800;margin:6px 0;color:var(--text)}
.celebrate-banner{background:var(--success-soft);border:2px solid var(--success);border-radius:12px;padding:16px 14px;margin-bottom:12px;text-align:center;color:var(--success);font-weight:700;font-size:16px;animation:celebrate-pop .5s ease}
body.dark-mode .celebrate-banner{color:#86efac}
@keyframes celebrate-pop{0%{transform:scale(.8);opacity:0}50%{transform:scale(1.05)}100%{transform:scale(1);opacity:1}}
.result-banner{background:var(--bg-card-hover);border:2px solid var(--border-strong);border-radius:12px;padding:12px 14px;margin-bottom:10px;text-align:center;font-weight:700;color:var(--text)}
.result-banner.result-green{border-color:var(--success);background:var(--success-soft);color:var(--success)}
body.dark-mode .result-banner.result-green{color:#86efac}
.result-banner.result-orange{border-color:var(--warn);background:var(--warn-soft);color:var(--warn)}
.result-banner.result-red{border-color:var(--error);background:var(--error-soft);color:var(--error)}
.error-list{margin-top:10px;padding:10px 14px;background:var(--error-soft);border:1px dashed var(--error);border-radius:10px;font-size:13px;color:var(--error)}
.error-list li{margin:4px 0}

/* === Floating Buttons === */
.dark-toggle{position:fixed;top:14px;right:16px;z-index:100;border:1px solid var(--border);border-radius:999px;padding:8px 14px;font-weight:700;font-size:14px;cursor:pointer;background:var(--bg-card);color:var(--text);box-shadow:0 2px 10px rgba(0,0,0,.12);transition:.2s all}
.dark-toggle:hover{transform:translateY(-1px);background:var(--accent-soft);border-color:var(--accent)}
.tts-toggle{position:fixed;bottom:46px;left:16px;z-index:99;border:1px solid var(--border);border-radius:999px;padding:7px 12px;font-weight:700;font-size:12px;cursor:pointer;background:var(--bg-card);color:var(--text);box-shadow:0 2px 10px rgba(0,0,0,.12);transition:.2s}
.tts-toggle:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.16)}
.tts-on{background:var(--accent);color:#1a1d28;border-color:var(--accent)}
body.dark-mode .tts-on{color:#0f1117}
.reset-all-btn{position:fixed;bottom:14px;left:16px;z-index:99;border:1px solid var(--border);border-radius:999px;padding:7px 12px;font-weight:700;font-size:12px;cursor:pointer;background:var(--bg-card);color:var(--text);box-shadow:0 2px 10px rgba(0,0,0,.12);transition:.2s}
.reset-all-btn:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.16)}

/* === Quiz-Divider === */
.quiz-divider{display:flex;align-items:center;gap:12px;margin:22px 0 6px;padding:0 4px}
.quiz-divider::before,.quiz-divider::after{content:"";flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:.55}
.quiz-divider span{font-size:13px;font-weight:800;color:var(--accent-strong);white-space:nowrap;letter-spacing:.5px;text-transform:uppercase}
body.dark-mode .quiz-divider span{color:var(--accent)}

/* === WWM-Quiz (thematisches Dunkelblau-Gold, mit neuem Token-System harmonisiert) === */
#wwm-quiz{background:linear-gradient(180deg,#0a1840 0%,#040c24 100%);border-radius:14px;border:1px solid rgba(244,196,48,.35);overflow:hidden}
#wwm-quiz>summary{color:var(--accent);border-left-color:var(--accent)!important;background:linear-gradient(90deg,rgba(244,196,48,.10),rgba(244,196,48,.02))!important;font-size:17px}
#wwm-quiz>summary .acc-num{background:linear-gradient(135deg,#b8860b,#daa520);color:#0f1117}
.wwm-layout{display:grid;grid-template-columns:1fr 160px;gap:20px;align-items:start}
.wwm-ladder{background:linear-gradient(180deg,#0c2056,#061840);border:1px solid rgba(244,196,48,.3);border-radius:12px;padding:10px 8px;display:flex;flex-direction:column;gap:3px}
.wwm-ladder-row{display:flex;align-items:center;gap:6px;padding:4px 8px;border-radius:6px;font-size:11.5px;font-weight:700;color:rgba(255,255,255,.45);border:1px solid transparent;transition:.2s all;cursor:default}
.wwm-ladder-row .wwm-qnum{width:18px;text-align:right;flex-shrink:0;font-size:10px;opacity:.6}
.wwm-ladder-row .wwm-amount{flex:1;text-align:right;letter-spacing:.2px}
.wwm-ladder-row.milestone{color:rgba(244,196,48,.6);border-color:rgba(244,196,48,.2);background:rgba(244,196,48,.05)}
.wwm-ladder-row.done{color:rgba(100,220,120,.55)}
.wwm-ladder-row.current{background:linear-gradient(90deg,rgba(244,196,48,.18),rgba(244,196,48,.08));border-color:rgba(244,196,48,.7);color:#f4c430;box-shadow:0 0 10px rgba(244,196,48,.25);font-size:12.5px}
.wwm-ladder-row.current .wwm-amount{text-shadow:0 0 8px rgba(244,196,48,.6)}
.wwm-ladder-row.milestone.current{background:linear-gradient(90deg,rgba(244,196,48,.28),rgba(244,196,48,.12))}
@media(max-width:640px){.wwm-ladder{display:none}.wwm-layout{display:block}}
.wwm-qbadge{display:inline-flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0d2a6e,#061840);border:2px solid rgba(244,196,48,.6);border-radius:999px;padding:4px 14px;font-size:12px;font-weight:800;color:#f4c430;letter-spacing:.8px;text-transform:uppercase;margin-bottom:10px;box-shadow:0 0 12px rgba(244,196,48,.2)}
#wwm-quiz .wwm-lifelines{display:flex;gap:8px;margin:10px 0 14px;justify-content:center;flex-wrap:wrap}
#wwm-quiz .wwm-lifelines .chip{padding:6px 14px;border-radius:999px;border:2px solid rgba(244,196,48,.75);color:#f4c430;background:radial-gradient(circle at 40% 35%,#1a3a8a,#061840);font-weight:900;letter-spacing:.5px;font-size:12px;box-shadow:0 0 14px rgba(244,196,48,.2),inset 0 1px 0 rgba(255,255,255,.1);text-shadow:0 0 8px rgba(244,196,48,.4);cursor:pointer;transition:.2s all}
#wwm-quiz .wwm-lifelines .chip:hover:not(.chip-used){background:radial-gradient(circle at 40% 35%,#2a4faa,#0d2060);box-shadow:0 0 22px rgba(244,196,48,.45),inset 0 1px 0 rgba(255,255,255,.15);transform:translateY(-2px) scale(1.05)}
#wwm-quiz .task,#wwm-quiz .wwm-stage{background:transparent;border:none;border-radius:0;box-shadow:none;padding:0;margin:0}
#wwm-quiz .task:hover,#wwm-quiz .wwm-stage:hover{box-shadow:none}
#wwm-quiz .task .prompt,#wwm-quiz .wwm-stage .prompt{background:linear-gradient(180deg,#0f2d72 0%,#091e50 100%);color:#fff;border:2px solid #f4c430;border-radius:14px;padding:18px 22px;text-align:center;font-weight:800;font-size:19px;box-shadow:0 0 0 4px rgba(244,196,48,.12),0 6px 28px rgba(0,0,0,.5);line-height:1.6;margin-bottom:14px;position:relative;overflow:hidden}
#wwm-quiz .task .prompt::before,#wwm-quiz .wwm-stage .prompt::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(244,196,48,.07),transparent 70%);pointer-events:none}
#wwm-quiz .task .controls .btn.primary,#wwm-quiz .wwm-stage .controls .btn.primary{background:linear-gradient(135deg,#0f3080,#1a4db5);color:#ffecb3;border:1px solid rgba(244,196,48,.5);box-shadow:0 3px 14px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.1)}
#wwm-quiz .task .controls .btn.green,#wwm-quiz .wwm-stage .controls .btn.green{background:linear-gradient(135deg,#1b5e20,#2e7d32);color:#b9f6ca;border:1px solid rgba(0,230,118,.45);box-shadow:0 3px 12px rgba(0,0,0,.4)}
#wwm-quiz .task .controls .btn.gray,#wwm-quiz .wwm-stage .controls .btn.gray{background:linear-gradient(135deg,#1e2a38,#2d3d50);color:#90a4ae;border:1px solid rgba(255,255,255,.15)}
#wwm-quiz .section-actions .btn{background:linear-gradient(135deg,#0c2a66,#163a8a);color:#ffecb3;border:1px solid rgba(244,196,48,.4);box-shadow:0 3px 10px rgba(0,0,0,.4)}
#wwm-quiz .section-actions .btn:hover{background:linear-gradient(135deg,#163a8a,#1e4db5)}
#wwm-quiz .feedback{color:#ffecb3;font-size:15px;margin-top:10px}
#wwm-quiz .feedback.ok{color:#00e676;text-shadow:0 0 10px rgba(0,230,118,.5)}
#wwm-quiz .feedback.bad{color:#ff6b6b;text-shadow:0 0 10px rgba(255,80,80,.4)}
#wwm-quiz .feedback.warn{color:#f4c430}
#wwm-quiz .controls .btn:focus{outline:2px solid rgba(255,255,255,.9);outline-offset:3px}
#wwm-quiz .controls .btn.green:focus{outline:2px solid #fff;outline-offset:3px;box-shadow:0 0 0 5px rgba(255,255,255,.2),0 3px 12px rgba(0,0,0,.4)}
.quiz-tip-box{margin-top:12px;padding:12px 16px;background:rgba(244,196,48,.08);border:1px solid rgba(244,196,48,.45);border-left:3px solid #f4c430;border-radius:10px;color:#fde68a;font-size:14px;line-height:1.6}
.quiz-explanation-box{margin-top:12px;padding:12px 16px;background:rgba(0,230,118,.07);border:1px solid rgba(0,230,118,.3);border-left:3px solid #00e676;border-radius:10px;color:#b9f6ca;font-size:14px;line-height:1.6}
.quiz-streak{text-align:center;font-size:22px;font-weight:900;color:#f4c430;letter-spacing:.5px;min-height:32px;margin-bottom:10px;text-shadow:0 0 16px rgba(244,196,48,.7)}
#wwm-quiz .result-card{background:linear-gradient(160deg,#1a4faa 0%,#0d3080 50%,#071d55 100%);border:3px solid #f4c430;box-shadow:0 0 60px rgba(244,196,48,.35),0 20px 60px rgba(0,0,0,.7);color:#fff;border-radius:20px;overflow:hidden}
#wwm-quiz .score{color:#f4c430}
#wwm-quiz{overflow:visible!important}
@keyframes quizFadeIn{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
.quiz-question-enter{animation:quizFadeIn .45s cubic-bezier(.22,1,.36,1) forwards}
#wwm-quiz .wwm-lifelines .chip-used{opacity:.35;cursor:not-allowed;border-color:rgba(244,196,48,.25);color:rgba(244,196,48,.4);text-decoration:line-through;box-shadow:none}
.wwm-joker-options{display:flex;flex-direction:column;gap:8px;margin-top:12px}
.wwm-option-btn{display:flex;align-items:center;gap:12px;background:linear-gradient(90deg,rgba(10,30,90,.9),rgba(5,18,60,.9));border:2px solid rgba(244,196,48,.5);border-radius:999px;color:#fff;font-size:15px;font-weight:600;cursor:pointer;padding:10px 18px;text-align:left;transition:.2s all;box-shadow:0 2px 12px rgba(0,0,0,.4)}
.wwm-option-btn:hover{background:linear-gradient(90deg,rgba(30,70,180,.9),rgba(15,45,130,.9));border-color:#f4c430;box-shadow:0 0 16px rgba(244,196,48,.3);transform:scale(1.01)}
.wwm-opt-letter{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:50%;background:rgba(244,196,48,.15);border:2px solid rgba(244,196,48,.6);color:#f4c430;font-size:13px;font-weight:900;flex-shrink:0}
.wwm-phone-bubble{margin-top:14px;display:flex;align-items:flex-start;gap:12px;background:linear-gradient(135deg,rgba(5,20,60,.95),rgba(3,12,40,.95));border:2px solid rgba(100,180,255,.4);border-radius:14px;padding:14px 16px;box-shadow:0 4px 20px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.06)}
.wwm-phone-icon{font-size:32px;flex-shrink:0;filter:drop-shadow(0 0 8px rgba(100,180,255,.5))}
.wwm-phone-text{font-size:14px;color:#c5deff;line-height:1.7}
.wwm-phone-text b{color:#f4c430}
.wwm-phone-text em{display:inline-block;margin-top:6px;font-style:normal;background:rgba(255,255,255,.08);border:1px solid rgba(100,180,255,.3);border-radius:8px;padding:4px 10px;color:#fff;font-weight:700;font-size:15px}
.wwm-audience-box{margin-top:14px;background:linear-gradient(180deg,rgba(5,18,55,.95),rgba(3,10,36,.95));border:2px solid rgba(244,196,48,.35);border-radius:14px;padding:14px 16px;box-shadow:0 4px 20px rgba(0,0,0,.5)}
.wwm-audience-title{text-align:center;font-size:13px;font-weight:800;color:#f4c430;letter-spacing:.6px;text-transform:uppercase;margin-bottom:12px;text-shadow:0 0 8px rgba(244,196,48,.4)}
.wwm-audience-bars{display:flex;gap:16px;align-items:flex-end;justify-content:center;height:110px}
.wwm-audience-col{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;max-width:160px;height:100%}
.wwm-audience-pct{font-size:13px;font-weight:900;color:#f4c430;min-height:18px}
.wwm-audience-bar{width:100%;min-height:4px;border-radius:6px 6px 0 0;cursor:pointer;transition:filter .2s}
.wwm-audience-bar:hover{filter:brightness(1.2)}
.wwm-audience-label{font-size:11px;color:rgba(255,255,255,.65);text-align:center;line-height:1.3;max-width:100%;word-break:break-word;margin-top:4px}

/* === Responsive === */
@media(max-width:600px){.level-switch button,.btn{padding:7px 13px;font-size:13px}.progress{width:160px}}
@media(max-width:768px){.rc-grid{grid-template-columns:1fr;gap:16px}.rc-card-mid-left,.rc-card-mid-right,.rc-card-top,.rc-card-full{grid-column:auto;grid-row:auto}}
@media(max-width:600px){.dark-toggle{position:static;display:block;margin:0 auto 8px;box-shadow:0 1px 6px rgba(0,0,0,.10)}}


/* === Neue Karten-Zonen (v2 Refactor) === */
.rc-zone-core{font-size:17px;font-weight:500;color:var(--text);line-height:1.5;padding:4px 0;letter-spacing:.1px}
.rc-zone-core b{font-weight:700;color:var(--accent-strong)}
body.dark-mode .rc-zone-core b{color:var(--accent)}
.rc-zone-table{background:var(--accent-soft);padding:16px;border-radius:8px;font-size:15px;line-height:1.65}
.rc-zone-table-title{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--accent-strong);margin-bottom:8px}
body.dark-mode .rc-zone-table-title{color:var(--accent)}
.rc-zone-examples{background:var(--bg-input);border:1px solid var(--border);padding:12px 16px;border-radius:8px;font-size:16px;line-height:1.7;display:flex;gap:10px;align-items:flex-start}
.rc-zone-examples-icon{flex-shrink:0;font-size:18px;line-height:1.4;padding-top:1px}
.rc-zone-examples-body{flex:1;font-style:italic;color:var(--text)}
.rc-zone-examples-body .ex-line{display:block;margin:2px 0}
.rc-zone-examples-body .ex-de{font-style:normal;color:var(--text-dim);font-size:14px;margin-left:4px}
/* Akzent-Highlight (reduzierter Pill-Style — nur EIN Wort hervorgehoben) */
.hl-accent{font-weight:700;color:var(--accent-strong);background:var(--accent-soft);border-radius:4px;padding:0 4px;font-style:normal}
body.dark-mode .hl-accent{color:var(--accent)}
.hl-accent-error{font-weight:700;color:var(--error);background:var(--error-soft);border-radius:4px;padding:0 4px;font-style:normal}
.hl-accent-info{font-weight:700;color:var(--info);background:var(--info-soft);border-radius:4px;padding:0 4px;font-style:normal}
/* Pronomen-Tabelle (Karten 2, 3, 4) */
.rc-table-pron{width:100%;border-collapse:collapse;font-size:15px;line-height:1.4}
.rc-table-pron th,.rc-table-pron td{padding:8px 12px;text-align:left;vertical-align:middle;border:none}
.rc-table-pron th{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--text-dim);border-bottom:1px solid var(--border);padding-bottom:6px}
.rc-table-pron tbody tr:nth-child(even){background:var(--accent-soft)}
.rc-table-pron td:first-child{font-weight:600;color:var(--text);width:80px}
.rc-table-pron td:nth-child(2){font-weight:700;color:var(--accent-strong);width:140px;font-family:'Baloo 2',monospace}
body.dark-mode .rc-table-pron td:nth-child(2){color:var(--accent)}
.rc-table-pron td:nth-child(3){color:var(--text-dim);font-size:14px}
.rc-table-pron tbody tr.is-plural td:first-child::after{content:" (Pl.)";font-size:11px;font-weight:500;color:var(--text-dim);font-style:italic}
/* Detail-Liste für Karten ohne Tabelle (Frage, Kurzantwort) */
.rc-detail-list{margin:0;padding:0;list-style:none;font-size:15px;line-height:1.7;color:var(--text)}
.rc-detail-list li{padding:4px 0;border-bottom:1px dashed var(--border)}
.rc-detail-list li:last-child{border-bottom:none}
.rc-detail-list .qa-q{font-weight:700;color:var(--info)}
.rc-detail-list .qa-a{color:var(--text-dim);margin-left:6px}
@media(max-width:480px){
  .rc-card-body{padding:18px 16px;gap:12px}
  .rc-zone-table{padding:12px}
  .rc-zone-examples{padding:10px 12px;font-size:15px}
  .rc-zone-core{font-size:16px}
  .rc-table-pron{font-size:14px}
  .rc-table-pron th,.rc-table-pron td{padding:6px 8px}
  .rc-table-pron td:first-child{width:60px}
  .rc-table-pron td:nth-child(2){width:90px}
}

/* ============================================================
   LIGHT-MODE v8 — Soft-Pastel-Karten pro Kategorie, weiße Tabellen-Boxen
   Dark-Mode bleibt separat unverändert.
   ============================================================ */

/* === Page-BG (subtiler Slate-Gradient für Tiefe) === */
body:not(.dark-mode){
  background:linear-gradient(180deg, #f0f4f8 0%, #f8fafc 60%, #f8fafc 100%);
  background-attachment:fixed;
}

/* === Karten: Default weiß + Hover-Lift === */
body:not(.dark-mode) .rc-card{
  background:var(--bg-card);
  box-shadow:0 1px 3px rgba(15,23,42,0.06),0 1px 2px rgba(15,23,42,0.04);
  border:1px solid var(--border);
}
body:not(.dark-mode) .rc-card:hover{
  transform:translateY(-2px);
