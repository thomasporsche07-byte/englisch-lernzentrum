(function(){
  const fab=document.getElementById('rules-fab');
  const rules=document.querySelector('.rules-combined');
  const modal=document.getElementById('rules-modal');
  const box=document.getElementById('rules-modal-box');
  const header=document.getElementById('rules-modal-header');
  const modalBody=document.getElementById('rules-modal-body');
  const modalTitle=modal.querySelector('.rules-modal-header h3');
  const closeBtn=document.getElementById('rules-modal-close');
  if(!fab||!rules||!modal)return;

  // FAB nur sichtbar wenn Regelkarten außerhalb Viewport UND ein Akkordeon offen ist
  let rulesVisible=true;
  function updateFabVisibility(){
    const anyOpen=['acc-aus','acc-kurz','acc-vern','acc-frag','acc-short','acc-signal']
      .some(id=>{const el=document.getElementById(id);return el&&el.open;});
    fab.style.display=(!rulesVisible&&anyOpen)?'block':'none';
  }
  const obs=new IntersectionObserver(([e])=>{rulesVisible=e.isIntersecting;updateFabVisibility();},{threshold:0});
  obs.observe(rules);
  ['acc-aus','acc-kurz','acc-vern','acc-frag','acc-short','acc-signal'].forEach(id=>{
    const el=document.getElementById(id);if(el)el.addEventListener('toggle',updateFabVisibility);
  });

  // Mapping: Akkordeon-ID → Kartenindizes (0-basiert) + Titel
  const ACC_MAP={
    'acc-aus':   {indices:[0],   title:'Regel: Aussagesatz'},
    'acc-kurz':  {indices:[4,0], title:'Regel: Kurzformen (I\'ll / won\'t)'},
    'acc-vern':  {indices:[1],   title:'Regel: Verneinung (won\'t)'},
    'acc-frag':  {indices:[2,3], title:'Regel: Fragen (Will …? / W-Fragen)'},
    'acc-short': {indices:[2],   title:'Regel: Short Answers'},
    'acc-signal':{indices:[5],   title:'Regel: Signalwörter'},
  };

  function getActiveAccordion(){
    return ['acc-aus','acc-kurz','acc-vern','acc-frag','acc-short','acc-signal']
      .map(id=>document.getElementById(id))
      .find(el=>el&&el.open)||null;
  }

  function openModal(){
    // Vorherigen Inhalt leeren
    modalBody.innerHTML='';
    const allCards=Array.from(rules.querySelectorAll('.rc-card'));
    const activeAcc=getActiveAccordion();
    const accId=activeAcc?activeAcc.id:null;
    const map=accId&&ACC_MAP[accId]?ACC_MAP[accId]:null;

    const wrapper=document.createElement('div');
    wrapper.style.cssText='display:flex;flex-direction:column;gap:12px;';

    if(map){
      // Nur relevante Karte(n)
      modalTitle.textContent=map.title;
      map.indices.forEach(i=>{
        if(allCards[i]){
          const clone=allCards[i].cloneNode(true);
          clone.querySelectorAll('.tts-btn').forEach(b=>b.remove());
          // Karte in voller Breite zeigen
          clone.style.cssText='width:100%;max-width:520px;margin:0 auto;';
          wrapper.appendChild(clone);
        }
      });
    }else{
      // Kein Akkordeon offen → alle Karten (Quiz oder Anfang)
      modalTitle.textContent='⚡ Alle Regeln';
      const grid=document.createElement('div');
      grid.style.cssText='display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;';
      allCards.forEach(card=>{
        const clone=card.cloneNode(true);
        clone.querySelectorAll('.tts-btn').forEach(b=>b.remove());
        grid.appendChild(clone);
      });
      wrapper.appendChild(grid);
    }

    modalBody.appendChild(wrapper);
    // Position zurücksetzen wenn noch nie verschoben
    if(!box.dataset.dragged){box.style.top='80px';box.style.right='20px';box.style.left='';}
    modal.classList.add('show');
    if(closeBtn)closeBtn.focus();
  }

  function closeModal(){
    modal.classList.remove('show');
    fab.focus();
  }

  fab.addEventListener('click',openModal);
  closeBtn.addEventListener('click',closeModal);
  document.addEventListener('keydown',(e)=>{if(e.key==='Escape'&&modal.classList.contains('open'))closeModal();});
})();

