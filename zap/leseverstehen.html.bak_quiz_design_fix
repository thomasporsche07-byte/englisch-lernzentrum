<style>
/* ============================================================
   SLATE-GOLD DESIGN SYSTEM (Pilot 05_to_be.html, Apr 2026)
   ============================================================ */
:root{
  --bg:#f8fafc;
  --bg-card:#ffffff;
  --bg-card-hover:#f1f5f9;
  --bg-input:#ffffff;
  --border:#e5e7eb;
  --border-strong:#d1d5db;
  --text:#1f2937;
  --text-dim:#4b5563;
  --accent:#d4a017;
  --accent-soft:rgba(212,160,23,0.10);
  --accent-strong:#a07408;
  --accent-tint:#e2e8f0;
  --success:#16a34a;
  --success-soft:rgba(22,163,74,0.08);
  --success-tint:#bbf7d0;
  --warn:#ea580c;
  --warn-soft:rgba(234,88,12,0.08);
  --warn-tint:#fed7aa;
  --error:#dc2626;
  --error-soft:rgba(220,38,38,0.08);
  --error-tint:#fecaca;
  --info:#2563eb;
  --info-soft:rgba(37,99,235,0.08);
  --info-tint:#bfdbfe;
  --indigo:#4f46e5;
  --indigo-soft:rgba(79,70,229,0.08);
  --indigo-tint:#ddd6fe;
  --teal:#0d9488;
  --teal-soft:rgba(13,148,136,0.08);
  --teal-tint:#f0fdfa;
  /* Pill-Tokens */
  --pill-subj-bg:rgba(37,99,235,0.10);
  --pill-subj-bd:#2563eb;
  --pill-subj-tx:#1e40af;
  --pill-do-bg:rgba(212,160,23,0.14);
  --pill-do-bd:#d4a017;
  --pill-do-tx:#7c5e0a;
  --pill-verb-bg:rgba(8,145,178,0.10);
  --pill-verb-bd:#0891b2;
  --pill-verb-tx:#155e6e;
  --pill-neg-bg:rgba(220,38,38,0.10);
  --pill-neg-bd:#dc2626;
  --pill-neg-tx:#991b1b;
  --pill-wh-bg:rgba(234,88,12,0.10);
  --pill-wh-bd:#ea580c;
  --pill-wh-tx:#9a3a0e;
  --pill-sig-bg:rgba(124,58,237,0.10);
  --pill-sig-bd:#7c3aed;
  --pill-sig-tx:#5b21b6;
  --pill-s-bg:rgba(22,163,74,0.10);
  --pill-s-bd:#16a34a;
  --pill-s-tx:#15803d;
  /* Karten-Akzent-Streifen pro Kategorie */
  --card-aus:#16a34a;
  --card-kf:#d4a017;
  --card-vern:#dc2626;
  --card-frag:#2563eb;
  --card-ka:#7c3aed;
  /* Saturierte Karten-Akzente (für Top-Stripe, Titel, Underlines pro Karte) */
  --card-amber-strong:#475569;
  --card-green-strong:#059669;
  --card-teal-strong:#ea580c;
  --card-red-strong:#dc2626;
  --card-blue-strong:#2563eb;
  --card-indigo-strong:#7c3aed;
}
body.dark-mode{
  --bg:#0f1117;
  --bg-card:#1a1d28;
  --bg-card-hover:#232634;
  --bg-input:#14161e;
  --border:#2a2e3d;
  --border-strong:#3a3f52;
  --text:#e8e9ed;
  --text-dim:#9ba0b3;
  --accent:#f4c430;
  --accent-soft:rgba(244,196,48,0.12);
  --accent-strong:#facc15;
  --success:#4ade80;
  --success-soft:rgba(74,222,128,0.10);
  --warn:#fb923c;
  --warn-soft:rgba(251,146,60,0.10);
  --error:#f87171;
  --error-soft:rgba(248,113,113,0.10);
  --info:#60a5fa;
  --info-soft:rgba(96,165,250,0.10);
  --pill-subj-bg:rgba(96,165,250,0.12);
  --pill-subj-bd:#60a5fa;
  --pill-subj-tx:#bfdbfe;
  --pill-do-bg:rgba(244,196,48,0.12);
  --pill-do-bd:#f4c430;
  --pill-do-tx:#fde68a;
  --pill-verb-bg:rgba(34,211,238,0.12);
  --pill-verb-bd:#22d3ee;
  --pill-verb-tx:#a5f3fc;
  --pill-neg-bg:rgba(248,113,113,0.12);
  --pill-neg-bd:#f87171;
  --pill-neg-tx:#fca5a5;
  --pill-wh-bg:rgba(251,146,60,0.12);
  --pill-wh-bd:#fb923c;
  --pill-wh-tx:#fdba74;
  --pill-sig-bg:rgba(167,139,250,0.12);
  --pill-sig-bd:#a78bfa;
  --pill-sig-tx:#d8b4fe;
  --pill-s-bg:rgba(74,222,128,0.12);
  --pill-s-bd:#4ade80;
  --pill-s-tx:#86efac;
  --card-aus:#4ade80;
  --card-kf:#f4c430;
  --card-vern:#f87171;
  --card-frag:#60a5fa;
  --card-ka:#a78bfa;
}
/* ===== ZP-Spezifische Styles (zusätzlich zum Master) ===== */
.task{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:14px 16px;margin:12px 0;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.task[data-done="1"]{border-color:var(--success-tint);background:var(--success-soft)}
.task-prompt{font-weight:600;margin-bottom:10px;color:var(--text);line-height:1.5}
.task-num{display:inline-block;background:var(--accent);color:#fff;border-radius:50%;width:24px;height:24px;text-align:center;font-size:13px;line-height:24px;margin-right:8px;font-weight:700}
.mc-options{display:flex;flex-direction:column;gap:6px;margin-top:8px}
.mc-opt{background:var(--bg-input);border:1.5px solid var(--border-strong);border-radius:8px;padding:9px 14px;text-align:left;cursor:pointer;font:inherit;color:var(--text);transition:.15s}
.mc-opt:hover:not([disabled]){background:var(--bg-card-hover);border-color:var(--accent)}
.mc-opt.correct{background:var(--success-soft);border-color:var(--success);color:var(--success)}
.mc-opt.wrong{background:var(--error-soft);border-color:var(--error);color:var(--error)}
.mc-opt[disabled]{cursor:default;opacity:.7}
.feedback{margin-top:10px;padding:8px 12px;border-radius:8px;font-size:14px}
.feedback.ok{background:var(--success-soft);color:var(--success);border-left:3px solid var(--success)}
.feedback.bad{background:var(--error-soft);color:var(--error);border-left:3px solid var(--error)}
.ft-wrap{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}
.ft-input{flex:1;min-width:200px;padding:9px 12px;border:1.5px solid var(--border-strong);border-radius:8px;font:inherit;background:var(--bg-input);color:var(--text)}
.ft-input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft)}
.btn{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:9px 16px;cursor:pointer;font:inherit;font-weight:600;transition:.15s}
.btn:hover{background:var(--accent-strong)}
.btn.gray{background:var(--text-dim)}
.btn.gray:hover{background:var(--text)}
.tf-list{display:flex;flex-direction:column;gap:10px;margin-top:8px}
.tf-row{background:var(--bg-input);border:1px solid var(--border);border-radius:10px;padding:10px 14px}
.tf-row[data-done="1"]{background:var(--bg-card-hover)}
.tf-stmt{margin-bottom:8px;font-size:15px;line-height:1.5}
.tf-btns{display:flex;gap:6px;flex-wrap:wrap}
.tf-btn{flex:1;min-width:90px;padding:7px 10px;font-size:13px}
.section-actions{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0 14px}
.note{background:var(--info-soft);border-left:3px solid var(--info);padding:10px 14px;border-radius:6px;margin-bottom:14px;font-size:14px;line-height:1.55}
/* WWM-Quiz */
.wwm-ladder{display:none}
@media(min-width:900px){.wwm-ladder{display:block;float:right;width:200px;margin-left:18px;font-size:12px;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:8px 0;box-shadow:0 2px 8px rgba(0,0,0,.04)}}
.wwm-rung{padding:4px 12px;color:var(--text-dim);border-left:3px solid transparent}
.wwm-rung.milestone{font-weight:700;color:var(--accent-strong);border-left-color:var(--accent)}
.wwm-rung.active{background:var(--accent-soft);color:var(--accent-strong);font-weight:700}
.wwm-rung.won{color:var(--success);text-decoration:line-through;opacity:.7}
.wwm-card{background:var(--bg-card);border:2px solid var(--accent);border-radius:14px;padding:18px 20px;margin-top:14px;box-shadow:0 3px 14px rgba(212,160,23,.15)}
.wwm-q{font-size:17px;font-weight:600;margin-bottom:14px;line-height:1.5;color:var(--text)}
.wwm-jokers{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.jk{background:var(--bg-input);border:1.5px solid var(--accent);color:var(--accent-strong);border-radius:20px;padding:6px 14px;cursor:pointer;font:inherit;font-size:13px;font-weight:600}
.jk:hover:not([disabled]){background:var(--accent);color:#fff}
.jk[disabled]{opacity:.4;cursor:default}
.streak-box{background:linear-gradient(135deg,#ea580c,#dc2626);color:#fff;border-radius:8px;padding:6px 12px;display:inline-block;margin-bottom:10px;font-weight:700;font-size:13px}
.wwm-options{display:flex;flex-direction:column;gap:8px}
.wwm-fb{margin-top:14px;padding:10px 14px;border-radius:8px;font-size:14px}
.wwm-fb.ok{background:var(--success-soft);color:var(--success);border-left:3px solid var(--success)}
.wwm-fb.bad{background:var(--error-soft);color:var(--error);border-left:3px solid var(--error)}
.result-card{text-align:center;background:var(--bg-card);border:2px solid var(--accent);border-radius:14px;padding:24px;margin-top:18px}
.result-card h3{margin:8px 0;color:var(--accent-strong)}
.result-card details{margin-top:14px;text-align:left}
.result-card summary{cursor:pointer;font-weight:600;color:var(--accent-strong)}
/* Quiz divider */
.quiz-divider{text-align:center;margin:30px 0 16px;position:relative}
.quiz-divider::before{content:'';position:absolute;left:0;top:50%;width:100%;height:1px;background:var(--border);z-index:0}
.quiz-divider span{position:relative;background:var(--bg);padding:0 18px;color:var(--accent-strong);font-weight:700;font-size:15px;z-index:1}
/* Section divider */
.section-divider{text-align:center;margin:24px 0 14px;color:var(--text-dim);font-size:14px;font-weight:600;text-transform:uppercase;letter-spacing:1px}
/* Strategien-Karten Grid */
.strat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;margin-top:14px}
.strat-card{background:var(--bg-card);border:1px solid var(--border);border-top:4px solid var(--accent);border-radius:12px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.strat-card.s-green{border-top-color:var(--success)}
.strat-card.s-red{border-top-color:var(--error)}
.strat-card.s-blue{border-top-color:var(--info)}
.strat-card.s-amber{border-top-color:var(--accent)}
.strat-card.s-teal{border-top-color:var(--teal)}
.strat-card.s-indigo{border-top-color:var(--indigo)}
.strat-card h3{margin:0 0 8px;font-size:16px;color:var(--text)}
.strat-card p{margin:6px 0;font-size:14px;line-height:1.55;color:var(--text)}
.strat-card .ex{background:var(--accent-soft);padding:6px 10px;border-radius:6px;margin-top:8px;font-size:13px;font-style:italic;color:var(--text-dim)}
/* Reading text box */
.read-text{background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:14px 18px;margin:10px 0;line-height:1.7;font-size:15px;max-height:none}
.read-text h4{margin:0 0 8px;color:var(--accent-strong)}
.read-text .meta{font-size:12px;color:var(--text-dim);font-style:italic;margin-bottom:8px}
/* Audio script box */
.audio-controls{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:10px 0;padding:10px 12px;background:var(--accent-soft);border-radius:10px}
.audio-controls label{font-size:13px;color:var(--text-dim)}
.audio-controls select,.audio-controls button{padding:6px 12px;border-radius:6px;border:1px solid var(--border-strong);background:var(--bg-input);color:var(--text);font:inherit;font-size:13px;cursor:pointer}
.audio-controls button.play-btn{background:var(--accent);color:#fff;border-color:var(--accent);font-weight:600}
.script-box{background:var(--bg-input);border:1px dashed var(--border-strong);border-radius:8px;padding:12px 14px;font-size:14px;line-height:1.6;margin:10px 0;display:none}
.script-box.show{display:block}
/* Vocabulary list */
.vocab-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:8px;margin-top:10px}
.vocab-item{background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:8px 12px;display:flex;justify-content:space-between;align-items:center;font-size:13px}
.vocab-item .en{font-weight:600;color:var(--accent-strong)}
.vocab-item .de{color:var(--text-dim);font-style:italic}
/* Floating Buttons */
.dark-toggle,.tts-toggle,.reset-all-btn{position:fixed;top:14px;background:var(--bg-card);border:1.5px solid var(--accent);color:var(--accent-strong);border-radius:24px;padding:8px 14px;cursor:pointer;font:inherit;font-size:13px;font-weight:600;z-index:50;box-shadow:0 2px 10px rgba(0,0,0,.08)}
.dark-toggle{right:14px}
.tts-toggle{right:140px}
.reset-all-btn{right:265px}
.dark-toggle:hover,.tts-toggle:hover,.reset-all-btn:hover{background:var(--accent);color:#fff}
@media(max-width:700px){.dark-toggle,.tts-toggle,.reset-all-btn{position:static;display:inline-block;margin:4px}.dark-toggle{margin-top:8px}}
header{text-align:center;padding:24px 20px 16px;border-bottom:1px solid var(--border);margin-bottom:18px}
header h1{margin:8px 0 4px;color:var(--accent-strong);font-size:26px}
header .sub{color:var(--text-dim);font-size:14px;margin:0}
.hdr-logo-link img{max-height:48px;display:block;margin:0 auto 6px}
.crosslinks{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;margin:12px 0}
.crosslink{background:var(--bg-card);border:1.5px solid var(--accent);border-radius:10px;padding:12px 16px;text-decoration:none;color:var(--text);transition:.15s;display:block}
.crosslink:hover{background:var(--accent-soft);border-color:var(--accent-strong);transform:translateY(-2px)}
.crosslink .ic{font-size:20px;margin-right:8px}
.crosslink .ttl{font-weight:700;color:var(--accent-strong);font-size:15px}
.crosslink .desc{font-size:12px;color:var(--text-dim);margin-top:3px}
.checklist{margin:14px 0;padding:0;list-style:none}
.checklist li{padding:8px 0;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:10px;cursor:pointer;font-size:14px}
.checklist li:hover{background:var(--bg-card-hover)}
.checklist input[type="checkbox"]{margin-top:2px;width:18px;height:18px;accent-color:var(--accent);cursor:pointer}
.checklist li.done{opacity:.55;text-decoration:line-through}
body{background:var(--bg);color:var(--text);font-family:'Baloo 2',sans-serif;margin:0;padding:0;min-height:100vh}
html:has(body.dark-mode){background:var(--bg)}
.container{max-width:1100px;margin:0 auto;padding:0 16px 60px}
.accordion{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;margin:14px 0;overflow:hidden}
.accordion[open]{box-shadow:0 4px 18px rgba(0,0,0,.06)}
.accordion summary{padding:14px 18px;font-weight:700;cursor:pointer;font-size:16px;color:var(--text);list-style:none;display:flex;justify-content:space-between;align-items:center}
.accordion summary::-webkit-details-marker{display:none}
.accordion summary::after{content:'▾';color:var(--accent);transition:.2s}
.accordion[open] summary::after{transform:rotate(180deg)}
.accordion .content{padding:0 18px 18px;border-top:1px solid var(--border)}
.progress-wrap{margin:10px 0 14px}
.progress{background:var(--bg-input);border-radius:6px;height:10px;overflow:hidden}
.progress-fill{background:linear-gradient(90deg,var(--success),var(--accent));height:100%;width:0%;transition:.3s}
.progress-text{font-size:12px;color:var(--text-dim);margin-top:4px}
footer{text-align:center;color:var(--text-dim);font-size:12px;margin-top:30px;padding:16px 20px 4px;border-top:1px solid var(--border)}
.acc-num{display:inline-block;background:var(--accent);color:#fff;border-radius:50%;width:26px;height:26px;text-align:center;line-height:26px;margin-right:8px;font-size:14px}
</style>

</head>
