      const placed=[];
      const srcTiles=[];
      const tgtTiles=[];
      let locked=false;
      let failCount=0,hintShown=false;

      mixed.forEach((word,wi)=>{
        const tile=document.createElement("button");tile.className="word-tile";tile.type="button";tile.textContent=word;tile.dataset.idx=wi;
        tile.addEventListener('click',()=>{
          if(locked)return;
