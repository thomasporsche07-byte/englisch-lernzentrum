  const types = TEXT_TYPES[cls] || TEXT_TYPES['56'];
  sel.innerHTML = types.map(t =>
    `<option value="${t.value}">${t.label}</option>`
  ).join('');
  // Auswahl beibehalten wenn Textsorte in neuer Klasse vorhanden, sonst erste Option
  if (keepSelection && types.find(t => t.value === prev)) {
    sel.value = prev;
  } else {
    sel.selectedIndex = 0;
  }
  updateWritingTips();
}

