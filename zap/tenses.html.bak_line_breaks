    const solBox=document.createElement('div');solBox.className='solution';solBox.style.display='none';
    const ctrl=document.createElement('div');ctrl.className='controls';
    const checkBtn=document.createElement('button');checkBtn.className='btn primary';checkBtn.textContent='Pr\u00fcfen';
    ctrl.appendChild(checkBtn);ctrl.appendChild(hintBtn);ctrl.appendChild(hintBox);ctrl.appendChild(solBtn);ctrl.appendChild(solBox);
    wrap.appendChild(ctrl);
    let failCount=0,hintShown=false;
    const notify=()=>{if(typeof onStatusChange==='function')onStatusChange();};
    function checkOne(silent){
      const val=inp.value.trim();
      if(!val){if(!silent){feedback.textContent='Bitte gib eine Antwort ein.';feedback.className='feedback warn';}return false;}
      const normUser=normalizeAnswer(val);
      const isOk=answers.some(a=>normalizeAnswer(a)===normUser);
      inp._correct=isOk;inp._done=true;
      if(isOk){
        feedback.textContent='\u2713 Richtig!';feedback.className='feedback ok';
        inp.disabled=true;hintBtn.style.display='none';hintBox.style.display='none';solBtn.style.display='none';solBox.style.display='none';
        if(!isSolved){const updated=[...solvedTasks,tHash];saveProgress(progressKey,updated);savedAnswers[tHash]=val;saveProgress(answersKey,savedAnswers);wrap.classList.add('task--solved');solvedLabel.innerHTML='\u2713 Bereits gel\u00f6st: <i>'+val+'</i>';}
        notify();return true;
      }else{
        failCount++;
        const hint=analyzeError(val,answers);
        feedback.innerHTML=('\u2717 Leider nicht richtig.'+(hint?' '+hint:''));feedback.className='feedback bad';
        if(failCount>=1&&enableSolution){hintBtn.style.display='';hintBox.innerHTML=t.explanation||'';}
        if(failCount>=2&&enableSolution){solBtn.style.display='';}
        notify();return false;
      }
    }
    if(isSolved){feedback.textContent='\u2713 Bereits gel\u00f6st';feedback.className='feedback ok';checkBtn.style.display='none';}
    checkBtn.addEventListener('click',()=>checkOne(false));
    inp.addEventListener('keydown',(e)=>{if(e.key==='Enter'){e.preventDefault();checkOne(false);}});
    hintBtn.addEventListener('click',()=>{hintBox.style.display='block';hintBtn.style.display='none';});
    solBtn.addEventListener('click',()=>{
      solBtn.style.display='none';solBox.style.display='block';
      const ans=normalizeAnswer(Array.isArray(t.answer)?t.answer[0]:t.answer);
      let html='<b>L\u00f6sung:</b> '+(Array.isArray(t.answer)?t.answer[0]:t.answer);
      if(/^did\s/.test(ans)||/^(where|when|what|why|who|how)\s+did\b/.test(ans))html+='<div style="margin-top:6px;font-size:13px;color:#4b5563;">\u{1f4a1} <b>Frage im Simple Past:</b> (W-Wort +) <b>did</b> + Subjekt + Grundform?</div>';
      else if(/^(was|were)\b/.test(ans))html+='<div style="margin-top:6px;font-size:13px;color:#4b5563;">\u{1f4a1} <b>Frage mit be:</b> Was/Were + Subjekt + …?</div>';
      else if(/\bdidn't\b/.test(ans)||/\bdid not\b/.test(ans))html+='<div style="margin-top:6px;font-size:13px;color:#4b5563;">\u{1f4a1} <b>Verneinung:</b> Subjekt + <b>didn\'t</b> + <b>Grundform</b>.</div>';
      else if(/\b(wasn't|weren't|was not|were not)\b/.test(ans))html+='<div style="margin-top:6px;font-size:13px;color:#4b5563;">\u{1f4a1} <b>Verneinung mit be:</b> Subjekt + <b>wasn\'t / weren\'t</b>.</div>';
      else html+='<div style="margin-top:6px;font-size:13px;color:#4b5563;">\u{1f4a1} <b>Grundregel:</b> Simple Past = Subjekt + <b>Verb in V2</b> (regelmäßig +ed, unregelmäßig eigene Form).</div>';
      solBox.innerHTML=html;
      if(typeof TTS!=='undefined'&&TTS.enabled){const sb=TTS.createBtn(answers[0]||'','en-GB','font-size:14px;margin-left:6px;');const bEl=solBox.querySelector('b');if(bEl)bEl.insertAdjacentElement('afterend',sb);}
    });
    inp._check=checkOne;
    inp._reset=()=>{inp.value='';inp._correct=false;inp._done=false;inp.disabled=false;failCount=0;hintShown=false;notify();feedback.textContent='';feedback.className='feedback';hintBtn.style.display='none';hintBox.style.display='none';hintBox.textContent='';solBtn.style.display='none';solBox.style.display='none';solBox.textContent='';solvedLabel.textContent='';wrap.classList.remove('task--solved');checkBtn.style.display='';};
    container.appendChild(wrap);
  });
  if(typeof TTS!=='undefined'&&TTS.enabled)setTimeout(()=>TTS.injectAll(),50);
}

// ===== SETUP SECTION (with level buttons) =====
function setupSection(sectionKey,levelButtons,container,pools,checkAllBtn,resetBtn,enableSolution){
  const progressRoot=document.querySelector('#'+sectionKey+'-progress .progress');
  const progressCtrl=initProgressBar(progressRoot,15);
  let currentLevel=1;const levelCache={};
  function updateProgress(){
    const inputs=container.querySelectorAll('.task input');let correct=0,done=0;
    inputs.forEach(inp=>{if(inp._correct)correct++;if(inp._done)done++;});
    progressCtrl.update(correct,done);
    const total=inputs.length;
    const activeBtn=levelButtons.querySelector('button[data-level="'+currentLevel+'"]');
    if(activeBtn&&total>0){const base=activeBtn.dataset.label||activeBtn.textContent.replace(' \u2713','');activeBtn.dataset.label=base;activeBtn.textContent=correct===total?base+' \u2713':base;}
    if(correct===total&&total>0)checkCelebration(container,progressCtrl);
  }
  const renderLevel=(lvl)=>{
    currentLevel=lvl;
    levelButtons.querySelectorAll('button').forEach(b=>{const isActive=+b.dataset.level===lvl;b.classList.toggle('active',isActive);b.setAttribute('aria-pressed',isActive?'true':'false');if(!b.dataset.label)b.dataset.label=b.textContent.replace(' \u2713','');});
    container.querySelectorAll('.result-banner').forEach(b=>b.remove());container.querySelectorAll('.error-list').forEach(b=>b.remove());
    if(!levelCache[lvl]){const pickKey=sectionKey+'_L'+lvl;const div=document.createElement('div');renderTasks(div,pickRandom(pools[lvl],15,pickKey),sectionKey,{enableSolution,onStatusChange:updateProgress,currentLevel:lvl});levelCache[lvl]=div;}
    Object.values(levelCache).forEach(div=>{if(div.parentNode===container)container.removeChild(div);});
    container.appendChild(levelCache[lvl]);
    progressCtrl.setTotal(levelCache[lvl].querySelectorAll('.task input').length);
    updateProgress();
    const hasFreitext=levelCache[lvl].querySelector('input[type="text"]')!==null;
    checkAllBtn.style.display=hasFreitext?'':'none';
  };
  levelButtons.addEventListener('click',(e)=>{const b=e.target.closest('button[data-level]');if(!b)return;renderLevel(+b.dataset.level);});
  checkAllBtn.addEventListener('click',()=>{
    const inputs=container.querySelectorAll('.task input');let ok=0,total=0;const wrongItems=[];
    inputs.forEach(inp=>{if(typeof inp._check==='function'){total++;if(inp._check(true))ok++;}});
    updateProgress();
    if(total>0){
      container.querySelectorAll('.result-banner').forEach(b=>b.remove());container.querySelectorAll('.error-list').forEach(b=>b.remove());
      inputs.forEach(inp=>{const wrap=inp.closest('.task');if(!wrap)return;if(inp._correct){wrap.classList.remove('task--wrong');}else if(inp.value&&inp.value.trim()){wrap.classList.add('task--wrong');const pEl=wrap.querySelector('.prompt');const nEl=wrap.querySelector('div[style*="color:#9ca3af"]');wrongItems.push({num:nEl?nEl.textContent:'',prompt:pEl?pEl.textContent:'',userVal:inp.value.trim()});}});
      const pct=Math.round(ok/total*100);const banner=document.createElement('div');banner.className='result-banner';
      const col=pct===100?'#3d7a2e':pct>=60?'#d4a017':'#b83a22';const em=pct===100?'\U0001f3c6':pct>=60?'\U0001f44d':'\U0001f4aa';
      banner.style.cssText='margin:10px 0 6px;padding:12px 16px;border-radius:12px;border:2px solid '+col+';background:'+col+'18;font-size:15px;font-weight:700;color:'+col+';display:flex;align-items:center;gap:10px;';
      banner.innerHTML='<span style="font-size:22px">'+em+'</span><span>Ergebnis: <b>'+ok+' / '+total+'</b> richtig ('+pct+'%)</span>';
      container.prepend(banner);
      if(wrongItems.length>0){const el=document.createElement('div');el.className='error-list';el.style.cssText='margin:0 0 12px;padding:10px 14px;border-radius:10px;border:1px solid #fca5a5;background:#fff5f5;font-size:13px;';el.innerHTML='<div style="font-weight:800;color:#b91c1c;margin-bottom:6px;">\u2717 Noch nicht richtig ('+wrongItems.length+'):</div>'+wrongItems.map(w=>'<div style="padding:3px 0;border-top:1px solid #fee2e2;color:#374151;"><span style="color:#9ca3af;font-size:11px;">'+w.num+'</span> <span>'+w.prompt+'</span></div>').join('');container.insertBefore(el,banner.nextSibling);}
      setTimeout(()=>banner.scrollIntoView({behavior:'smooth',block:'nearest'}),80);
    }
  });
  resetBtn.addEventListener('click',()=>{customConfirm('Fortschritt zur\u00fccksetzen?',()=>{container.querySelectorAll('.result-banner,.celebrate-banner').forEach(b=>b.remove());container.querySelectorAll('.error-list').forEach(b=>b.remove());container.querySelectorAll('.task--wrong').forEach(t=>t.classList.remove('task--wrong'));container.querySelectorAll('.task input').forEach(inp=>{if(typeof inp._reset==='function')inp._reset();});[1,2,3].forEach(function(l){saveProgress(sectionKey+'_L'+l,[]);saveProgress(sectionKey+'_L'+l+'_ans',{});});updateProgress();});});
  const rerollBtn=document.getElementById(sectionKey+'-reroll');
  if(rerollBtn)rerollBtn.addEventListener('click',()=>{
    progressCtrl.resetAnimated();
    const old=levelCache[currentLevel];if(old&&old.parentNode===container)container.removeChild(old);delete levelCache[currentLevel];
    const pKey=sectionKey+'_L'+currentLevel;saveProgress('pick_'+pKey,null);saveProgress(pKey,[]);saveProgress(pKey+'_ans',{});
    renderLevel(currentLevel);
    container.querySelectorAll('.celebrate-banner').forEach(b=>b.remove());
    setTimeout(()=>{container.querySelectorAll('.task input').forEach(inp=>{inp._correct=false;inp._done=false;});updateProgress();},10);
  });
  renderLevel(1);
}

