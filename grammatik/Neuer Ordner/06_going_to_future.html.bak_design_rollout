      input._check=checkTiles;
      input._reset=()=>{locked=false;placed.length=0;target.innerHTML='';tgtTiles.length=0;srcTiles.forEach(t=>t.classList.remove('wt-used'));input._correct=false;input._done=false;failCount=0;hintShown=false;feedback.textContent='';feedback.className='feedback';hintBtn.style.display='none';hintBox.style.display='none';hintBox.textContent='';solBtn.style.display='none';solBox.style.display='none';solBox.textContent='';solvedLabel.textContent='';wrap.classList.remove('task--solved');notify();};
      return;
    }

    // ========== Freitext-Aufgabe ==========
    let promptHTML=t.prompt||"";
    // Wortreihenfolge in <i>...</i>-Listen mischen, damit die Aufgabe nicht trivial wird.
    promptHTML=shufflePromptSlashList(promptHTML);
    const prompt=document.createElement("p");prompt.className="prompt";prompt.innerHTML=promptHTML;
    const input=document.createElement("input");input.type="text";input.id=`${sectionKey}-input-${idx}`;input.setAttribute("aria-label","Antwort eingeben");input.placeholder="Vollständigen Satz eingeben …";
    
    if(isSolved){input._correct=true;input._done=true;}
    const controls=document.createElement("div");controls.className="controls";
    const checkBtn=document.createElement("button");checkBtn.className="btn primary";checkBtn.textContent="Prüfen";
    const hintBtn=document.createElement("button");hintBtn.className="btn ghost";hintBtn.textContent="💡 Tipp zeigen";hintBtn.style.display='none';
    const solBtn=document.createElement("button");solBtn.className="btn ghost";solBtn.textContent="Lösung anzeigen";solBtn.style.display='none';
    const feedback=document.createElement("div");feedback.className="feedback";
    const hintBox=document.createElement("div");hintBox.className="hint-box";
    const solBox=document.createElement("div");solBox.className="solution";
    controls.appendChild(checkBtn);
    if(enableSolution){controls.appendChild(hintBtn);controls.appendChild(solBtn);}
    wrap.appendChild(prompt);wrap.appendChild(input);wrap.appendChild(controls);wrap.appendChild(feedback);wrap.appendChild(hintBox);wrap.appendChild(solBox);
    container.appendChild(wrap);
    const answers=Array.isArray(t.answer)?t.answer:[t.answer];
    const notify=()=>{if(typeof onStatusChange==='function')onStatusChange();};
    let failCount=0,hintShown=false;
    function checkOne(batchMode){
      const user=normalizeAnswer(input.value);
      const okSet=answers.map(normalizeAnswer);
      if(!user){feedback.textContent="Bitte gib eine Lösung ein.";feedback.className="feedback warn";input._correct=false;notify();return false;}
      if(okSet.some(a=>a===user)){
        feedback.textContent="✓ Richtig!";feedback.className="feedback ok";
        input._correct=true;input._done=true;failCount=0;
        if(!isSolved){
          const updated=[...solvedTasks,tHash];
          saveProgress(progressKey,updated);
          savedAnswers[tHash]=input.value.trim();
          saveProgress(answersKey,savedAnswers);
          wrap.classList.add('task--solved');
          solvedLabel.innerHTML=`✓ Bereits gelöst: <i>${input.value.trim()}</i>`;
        }
        // TTS-Button am "Bereits gelöst"-Label nachinjizieren
        if(typeof TTS!=='undefined'&&TTS.enabled){delete solvedLabel.dataset.ttsReady;setTimeout(()=>TTS.injectAll(),30);}
        notify();
        if(!batchMode){const all=Array.from(container.querySelectorAll("input[type='text']"));const next=all[all.indexOf(input)+1];if(next)setTimeout(()=>{next.focus();next.scrollIntoView({behavior:'smooth',block:'nearest'});},150);}
        return true;
      }
      failCount++;
      // Fehleranalyse
